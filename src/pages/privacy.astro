---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildBreadcrumbSchema } from '../lib/seo';
import siteSettings from '../data/site-settings.json';
import privacyPage from '../data/privacy-page.json';
const breadcrumbs = buildBreadcrumbSchema([
  { name: privacyPage.breadcrumbs.home, path: '/' },
  { name: privacyPage.breadcrumbs.current }
]);
---

<Layout title={privacyPage.metaTitle} description={privacyPage.metaDescription} canonicalPath="/privacy/" frPath="/privacy/" enPath="/en/privacy/" schemas={[breadcrumbs]}>
  <Header />

  <main>
    <section class="interior-hero">
      <div class="container interior-hero-grid">
        <div class="interior-hero-copy">
          <p class="interior-eyebrow">Confidentialité et protection</p>
          <h1>{privacyPage.hero.title}</h1>
          <p class="interior-lead">{privacyPage.hero.body}</p>
        </div>

        <aside class="interior-hero-card">
          <div class="interior-hero-icon">
            <i class="fas fa-shield-halved"></i>
          </div>
          <h2>Besoin d'un point de départ clair?</h2>
          <p>On peut vous aider à comprendre la situation, à choisir le bon service et à décider de la prochaine étape utile pour votre VR.</p>
          <a class="interior-hero-link" href="/contact/">Parler de votre VR</a>
        </aside>
      </div>
    </section>

    <section class="interior-section">
      <div class="container interior-body-grid">
        <article class="content-main policy-grid">
          {privacyPage.sections.map((section) => (
          <article class="interior-card">
            <h2>{section.heading}</h2>
            {section.heading === 'Questions' ? (
              <p>
                Pour toute question liée à la confidentialité ou à vos renseignements, écrivez à <a href={`mailto:${siteSettings.email}`}>{siteSettings.email}</a> ou appelez au <a href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>.
              </p>
            ) : (
              <p>{section.body}</p>
            )}
          </article>
        ))}
        </article>

        <aside class="interior-side-panel">
          <div class="interior-side-card interior-side-card-primary">
            <h3>Besoin d'un avis rapide?</h3>
            <p>On peut vous orienter vers une inspection, un entretien ou une réparation selon l'état du véhicule.</p>
            <a class="interior-side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
            <a class="interior-side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">Réserver en ligne</a>
          </div>

          <div class="interior-side-card">
            <h3>Autres services</h3>
            <nav class="interior-service-nav" aria-label="Autres services">
              <a href="/services/inspection/"><i class="fas fa-clipboard-check"></i><span>Inspection</span></a>
              <a href="/services/entretien/"><i class="fas fa-screwdriver-wrench"></i><span>Entretien</span></a>
              <a href="/services/reparation/"><i class="fas fa-toolbox"></i><span>Réparation</span></a>
              <a href="/services/esthetique/"><i class="fas fa-spray-can-sparkles"></i><span>Esthétique VR</span></a>
            </nav>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .content-main { display: grid; gap: 1.5rem; }
  .policy-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; }

  .interior-card h2 {
    margin-bottom: 0.75rem;
    font-size: 1.45rem;
  }

  @media (max-width: 768px) {
    .interior-hero-copy h1 {
      font-size: 2rem;
    }

    .interior-lead {
      font-size: 1rem;
    }
  }
</style>
