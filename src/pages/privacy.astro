---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildBreadcrumbSchema } from '../lib/seo';
import siteSettings from '../data/site-settings.json';
import privacyPage from '../data/privacy-page.json';
const breadcrumbs = buildBreadcrumbSchema([
  { name: privacyPage.breadcrumbs.home, path: '/' },
  { name: privacyPage.breadcrumbs.current }
]);
---

<Layout title={privacyPage.metaTitle} description={privacyPage.metaDescription} canonicalPath="/privacy/" frPath="/privacy/" enPath="/en/privacy/" schemas={[breadcrumbs]}>
  <Header />

  <main>
    <section class="policy-hero">
      <div class="container">
        <h1>{privacyPage.hero.title}</h1>
        <p>{privacyPage.hero.body}</p>
      </div>
    </section>

    <section class="policy-body">
      <div class="container policy-grid">
        {privacyPage.sections.map((section) => (
          <article class="policy-card">
            <h2>{section.heading}</h2>
            {section.heading === 'Questions' ? (
              <p>
                Pour toute question liée à la confidentialité ou à vos renseignements, écrivez à <a href={`mailto:${siteSettings.email}`}>{siteSettings.email}</a> ou appelez au <a href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>.
              </p>
            ) : (
              <p>{section.body}</p>
            )}
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .policy-hero {
    padding: 4rem 0 2rem;
    background: linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 100%);
    color: white;
  }

  .policy-hero h1 {
    color: white;
    margin-bottom: 0.75rem;
  }

  .policy-body {
    padding: 3rem 0 4rem;
    background: #f4f6f8;
  }

  .policy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .policy-card {
    background: white;
    border-radius: 18px;
    padding: 1.5rem;
    box-shadow: 0 14px 28px rgba(20, 36, 55, 0.08);
  }

  .policy-card h2 {
    margin-bottom: 0.75rem;
    font-size: 1.45rem;
  }
</style>
