---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import servicePagesData from '../data/service-pages.json';
import { localAreaPagesFr } from '../data/local-area-pages';
import { buildBreadcrumbSchema, buildCollectionPageSchema, buildFAQSchema, buildWebSiteSchema } from '../lib/seo';
import type { ServicePage } from '../data/service-page-types';
import siteSettings from '../data/site-settings.json';

const servicePages = servicePagesData.items as ServicePage[];
const faqItems = [
  ...servicePages.flatMap((service) => service.faqs),
  ...localAreaPagesFr.flatMap((page) => page.faqs),
  {
    question: 'Travaillez-vous seulement à Gatineau?',
    answer: "Notre atelier est à Gatineau, mais nous accompagnons aussi des clients de l'Outaouais, d'Ottawa et des Laurentides selon le type de demande."
  },
  {
    question: "Quand faut-il réserver une inspection plutôt qu'une réparation?",
    answer: "Quand la source du problème n'est pas encore claire, l'inspection est souvent la meilleure première étape. Quand les dommages sont déjà visibles ou confirmés, la réparation devient généralement la bonne suite."
  }
];

const schemas = [
  buildWebSiteSchema(),
  buildCollectionPageSchema({
    name: 'FAQ Clinique du VR',
    description: "Questions fréquentes sur l'inspection, l'entretien, la réparation et les zones desservies par Clinique du VR.",
    path: '/faq/'
  }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Accueil', path: '/' },
    { name: 'FAQ' }
  ])
];
---

<Layout
  title="FAQ VR à Gatineau | Inspection, entretien, réparation | Clinique du VR"
  description="FAQ Clinique du VR sur l'inspection, l'entretien, la réparation de fuite d'eau, les zones desservies et la meilleure prochaine étape pour votre VR à Gatineau."
  canonicalPath="/faq/"
  frPath="/faq/"
  enPath="/en/faq/"
  schemas={schemas}
>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Questions fréquentes</p>
          <h1>FAQ sur les services VR à Gatineau</h1>
          <p class="lead">Cette page regroupe les questions les plus fréquentes sur les fuites d’eau, l’entretien, la réparation, l’inspection avant achat et les zones desservies autour de Gatineau.</p>
        </div>

        <aside class="hero-card">
          <div class="hero-icon">
            <i class="fas fa-circle-question"></i>
          </div>
          <h2>Besoin d'un point de départ clair?</h2>
          <p>On peut vous aider à comprendre la situation, à choisir le bon service et à décider de la prochaine étape utile pour votre VR.</p>
          <a class="hero-link" href="/contact/">Parler de votre VR</a>
        </aside>
      </div>
    </section>

    <section class="faq-section">
      <div class="container faq-layout">
        <div class="faq-list">
          {faqItems.map((item) => (
            <details class="faq-item">
              <summary><h2>{item.question}</h2></summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>

        <aside class="side-panel">
          <div class="side-card side-card-primary">
            <h3>Besoin d'un avis rapide?</h3>
            <p>On peut vous orienter vers une inspection, un entretien ou une réparation selon l'état du véhicule.</p>
            <a class="side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
            <a class="side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">Réserver en ligne</a>
          </div>

          <div class="side-card">
            <h3>Autres services</h3>
            <nav class="service-nav" aria-label="Autres services">
              <a href="/services/inspection/"><i class="fas fa-clipboard-check"></i><span>Inspection</span></a>
              <a href="/services/entretien/"><i class="fas fa-screwdriver-wrench"></i><span>Entretien</span></a>
              <a href="/services/reparation/"><i class="fas fa-toolbox"></i><span>Réparation</span></a>
              <a href="/services/esthetique/"><i class="fas fa-spray-can-sparkles"></i><span>Esthétique VR</span></a>
            </nav>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-hero { position: relative; overflow: hidden; padding: 4.5rem 0 4rem; background: radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 32%), linear-gradient(135deg, var(--brand-navy-dark) 0%, #23476f 58%, #f4f6f8 58%, #f4f6f8 100%); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr); gap: 2rem; align-items: stretch; }
  .hero-copy { color: white; }
  .eyebrow { display: inline-flex; margin-bottom: 1.25rem; padding: 0.45rem 0.85rem; border-radius: 999px; background: rgba(255,255,255,0.12); color: var(--brand-gold); font-size: 0.85rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .page-hero h1 { color: white; margin-bottom: 1rem; max-width: 14ch; line-height: 1.05; }
  .lead { max-width: 62ch; color: #f5f7fa; font-size: 1.2rem; line-height: 1.7; }
  .hero-card { align-self: end; background: white; border-radius: 24px; padding: 2rem; box-shadow: 0 22px 44px rgba(16, 35, 56, 0.22); }
  .hero-icon { width: 4rem; height: 4rem; display: inline-flex; align-items: center; justify-content: center; border-radius: 18px; background: linear-gradient(135deg, var(--brand-green), #57af49); color: white; font-size: 1.5rem; margin-bottom: 1rem; }
  .hero-card h2 { font-size: 1.5rem; margin-bottom: 0.75rem; }
  .hero-card p { color: var(--brand-muted); margin-bottom: 1.25rem; }
  .hero-link { display: inline-flex; align-items: center; justify-content: center; width: 100%; min-height: 48px; padding: 0.85rem 1rem; border-radius: 999px; background: var(--brand-navy); color: white; font-weight: 700; text-decoration: none; }
  .hero-link:hover { text-decoration: none; background: var(--brand-navy-dark); }
  .faq-section { padding: 4rem 0; background: linear-gradient(180deg, #ffffff 0%, #ffffff 42%, #f3f5f8 42%, #f3f5f8 100%); }
  .faq-layout { display: grid; grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr); gap: 2rem; align-items: start; }
  .faq-list { display: grid; gap: 1rem; }
  .faq-item { background: white; border-radius: 22px; padding: 1.75rem; box-shadow: 0 16px 34px rgba(24, 40, 61, 0.08); }
  .faq-item h2 { font-size: 1.15rem; letter-spacing: 0.04em; margin: 0; }
  .faq-item p { margin-top: 0.8rem; color: var(--brand-muted); }
  .faq-item summary { list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; flex: 0 0 auto; font-size: 1.4rem; font-weight: 700; line-height: 1; color: var(--brand-navy); }
  .faq-item[open] summary::after { content: '-'; }
  .side-panel { display: grid; gap: 1.5rem; position: sticky; top: 7rem; align-self: start; }
  .side-card { background: white; border-radius: 22px; padding: 1.75rem; box-shadow: 0 16px 34px rgba(24, 40, 61, 0.08); }
  .side-card h3 { margin-bottom: 1rem; }
  .side-card-primary { background: var(--brand-navy-dark); color: white; }
  .side-card-primary h3 { color: white; }
  .side-card-primary p { color: #dbe4ee; }
  .side-button { display: inline-flex; align-items: center; justify-content: center; width: 100%; min-height: 48px; border-radius: 999px; background: var(--brand-gold); color: var(--brand-navy-dark); font-weight: 700; text-decoration: none; margin: 0.25rem 0 0.75rem; }
  .side-button:hover { text-decoration: none; background: #e2c417; }
  .side-link { display: inline-flex; align-items: center; justify-content: center; width: 100%; min-height: 48px; padding: 0.55rem 1rem; border-radius: 999px; background: var(--brand-gold); border: 2px solid var(--brand-gold); color: var(--brand-navy-dark); font-weight: 700; text-decoration: none; }
  .side-link:hover { text-decoration: none; background: #e1c317; border-color: #e1c317; }
  .service-nav { display: grid; gap: 0.7rem; }
  .service-nav a { display: flex; align-items: center; gap: 0.8rem; min-height: 54px; padding: 0.9rem 1rem; border-radius: 16px; background: var(--brand-surface); color: var(--brand-ink); text-decoration: none; font-weight: 700; }
  .service-nav a:hover { text-decoration: none; background: #eaf1e6; }
  .service-nav i { color: var(--brand-green); }
  @media (max-width: 768px) { .page-hero { background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%); padding: 3.8rem 0 2.8rem; } .hero-grid, .faq-layout { grid-template-columns: 1fr; } .side-panel { position: static; } }
</style>
