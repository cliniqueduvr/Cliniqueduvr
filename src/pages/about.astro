---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildAboutPageSchema, buildBreadcrumbSchema, buildWebSiteSchema } from '../lib/seo';
import siteSettings from '../data/site-settings.json';
import aboutPage from '../data/about-page.json';

const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Accueil', path: '/' },
  { name: 'À propos' }
]);
const schemas = [
  buildWebSiteSchema(),
  buildAboutPageSchema({
    name: aboutPage.metaTitle,
    description: aboutPage.metaDescription,
    path: '/about/'
  }),
  breadcrumbs
];
---

<Layout
  title={aboutPage.metaTitle}
  description={aboutPage.metaDescription}
  canonicalPath="/about/"
  frPath="/about/"
  enPath="/en/about/"
  schemas={schemas}
>
  <Header />

  <main>
    <section class="about-hero">
      <div class="container hero-grid">
        <div>
          <h1>{aboutPage.hero.title}</h1>
          <p>{aboutPage.hero.body}</p>
        </div>
        <figure class="brand-card">
          <img src={siteSettings.brandImage} alt={aboutPage.hero.imageAlt} />
          <figcaption>{aboutPage.hero.caption}</figcaption>
        </figure>
      </div>
    </section>

    <section class="about-body">
      <div class="container about-grid">
        {aboutPage.sections.map((section) => (
          <article class="about-card">
            <h2>{section.heading}</h2>
            <p>{section.body}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .about-hero {
    padding: 4rem 0;
    background: linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 60%, #f4f6f8 60%, #f4f6f8 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.8fr);
    gap: 2rem;
    align-items: center;
  }

  .about-hero h1 {
    color: white;
  }

  .about-hero .hero-grid > div > p {
    color: white;
    max-width: 54ch;
  }

  .brand-card {
    margin: 0;
    background: white;
    border-radius: 20px;
    padding: 1.5rem;
    box-shadow: 0 16px 30px rgba(18, 35, 54, 0.18);
  }

  .brand-card img {
    width: 100%;
    height: auto;
    display: block;
  }

  .brand-card figcaption {
    margin-top: 1rem;
    color: var(--brand-muted);
    font-size: 0.95rem;
  }

  .about-body {
    padding: 4rem 0;
    background: #f4f6f8;
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .about-card {
    background: white;
    border-radius: 18px;
    padding: 1.5rem;
    box-shadow: 0 14px 28px rgba(20, 36, 55, 0.08);
  }

  .about-card p {
    margin-top: 0.75rem;
    color: var(--brand-muted);
  }

  @media (max-width: 900px) {
    .about-hero {
      background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
