---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';
import servicePagesData from '../data/service-pages.json';
import type { ServicePage } from '../data/service-page-types';
import { buildBreadcrumbSchema, buildFAQSchema } from '../lib/seo';
const servicePages = servicePagesData.items as ServicePage[];
const visibleServicePages = servicePages.filter((service) => service.slug !== 'vente-achat');
const serviceAreas = [
  { name: 'Outaouais', href: '/zones/inspection-vr-outaouais/' },
  { name: 'Ottawa', href: '/zones/reparation-vr-ottawa/' },
  { name: 'Laurentides', href: '/zones/infiltration-eau-roulotte-laurentides/' }
];
const serviceFaqs = [
  {
    question: 'Comment choisir le bon service pour mon VR?',
    answer: "Le bon service dépend surtout de l'état réel du véhicule. Si vous voyez des signes d'infiltration, de joints fatigués, de dommages intérieurs ou si vous préparez un achat ou une vente, nous pouvons vous orienter vers l'inspection, l'entretien, la réparation, l'esthétique ou la vente selon le besoin."
  },
  {
    question: 'Travaillez-vous seulement à Gatineau?',
    answer: "Non. L'atelier est à Gatineau, mais nous accompagnons aussi des clients d'Ottawa, de l'Outaouais, des Laurentides ainsi que d'autres secteurs du Québec et de l'Ontario selon le type de dossier."
  },
  {
    question: 'Offrez-vous des services mobiles et en atelier?',
    answer: "Oui, selon le service demandé. Certaines interventions se font très bien en atelier, alors que d'autres peuvent aussi être offertes sur la route ou avec déplacement selon la situation."
  }
];
const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Accueil', path: '/' },
  { name: 'Services' }
]);
---

<Layout title="Services VR à Gatineau-Ottawa | Entretien, réparation et esthétique VR et auto" description="Services de VR à Gatineau-Ottawa: inspection, entretien, réparation, esthétique VR et auto et vente." canonicalPath="/services/" frPath="/services/" enPath="/en/services/" schemas={[breadcrumbs, buildFAQSchema(serviceFaqs)]}>
  <Header />

  <main>
    <section class="page-header">
      <div class="container">
        <p class="eyebrow">Pour chaque besoin de votre VR</p>
        <h1>Nos Services</h1>
        <p>Inspection, entretien, réparation et esthétique VR et auto selon l'état réel du véhicule.</p>
      </div>
    </section>

    <section class="services-grid-section">
      <div class="container services-grid">
        {visibleServicePages.map((service) => (
          <a class="service-card" href={`/services/${service.slug}/`}>
            <p class="card-eyebrow">{service.eyebrow}</p>
            <h2 class="card-title">{service.navLabel}</h2>
            <p class="card-copy">{service.lead}</p>
            <span>En savoir plus</span>
          </a>
        ))}
      </div>
    </section>

    <section class="seo-copy">
      <div class="container seo-columns">
        <div>
          <h2>Un service adapté à votre situation</h2>
          <p>Que vous soyez en préparation avant la saison, en évaluation avant achat ou en pleine réparation, nous vous orientons vers le bon service selon l'état du véhicule et l'urgence de la situation. L'objectif est de vous faire gagner du temps et d'éviter les mauvaises surprises.</p>
        </div>
        <div>
          <h2>Ce que nous couvrons</h2>
          <p>Nos interventions touchent les infiltrations d'eau, la toiture, les joints, les composantes électriques et propane, la remise en état intérieure, l'esthétique VR et auto, ainsi que les inspections avant transaction. Si vous n'êtes pas certain du bon service, contactez-nous et nous vous guiderons.</p>
        </div>
      </div>
    </section>

    <section class="service-areas-section">
      <div class="container">
        <h2>Zones desservies</h2>
        <p class="section-intro">Nous recevons des demandes provenant de l'Outaouais, d'Ottawa et des Laurentides selon le type de service et la situation du véhicule.</p>
        <div class="info-card-grid">
          {serviceAreas.map((area) => (
            <details class="info-card accordion-card">
              <summary>
                <h3>{area.name}</h3>
              </summary>
              <div class="accordion-content">
                <p>Demandes fréquentes en inspection, entretien, réparation, esthétique ou préparation avant transaction.</p>
                <a href={area.href}>Voir la page locale</a>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="service-links-section">
      <div class="container info-card-grid">
        <details class="info-card accordion-card">
          <summary>
            <h2>Nous contacter</h2>
          </summary>
          <div class="accordion-content">
            <p>Décrivez le problème, le véhicule et votre priorité pour être orienté vers le bon service.</p>
            <a href="/contact/">Contacter l'atelier</a>
          </div>
        </details>
        <details class="info-card accordion-card">
          <summary>
            <h2>Cas réels</h2>
          </summary>
          <div class="accordion-content">
            <p>Consultez des exemples d'interventions avant-après pour mieux situer votre besoin.</p>
            <a href="/realisations/">Voir les réalisations</a>
          </div>
        </details>
        <details class="info-card accordion-card">
          <summary>
            <h2>Avant achat ou vente</h2>
          </summary>
          <div class="accordion-content">
            <p>Si votre situation touche une transaction, commencez par l’inspection pour clarifier l’état réel du véhicule.</p>
            <a href="/services/inspection/">Voir le service d'inspection</a>
          </div>
        </details>
        <details class="info-card accordion-card">
          <summary>
            <h2>Choisir un service</h2>
          </summary>
          <div class="accordion-content">
            <p>Si vous n’êtes pas certain du bon point de départ, voyez notre page d’orientation par symptôme et par situation.</p>
            <a href="/choisir-service/">Voir la page d'orientation</a>
          </div>
        </details>
      </div>
    </section>

    <section class="service-faq-section">
      <div class="container">
        <h2>Questions fréquentes</h2>
        <div class="faq-list">
          {serviceFaqs.map((item) => (
            <details class="faq-item accordion-card">
              <summary>
                <h3>{item.question}</h3>
              </summary>
              <div class="accordion-content">
                <p>{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CTABanner
      heading="Un besoin précis sur votre VR?"
      subheading="Choisissez le service le plus proche de votre besoin ou contactez-nous pour être orienté."
    />
  </main>

  <Footer />
</Layout>

<style>
  .page-header {
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 25%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 58%, #eef3f7 58%, #eef3f7 100%);
    color: white;
    padding: 4.5rem 0 3.8rem;
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: var(--brand-gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-header h1 {
    color: white;
    margin-bottom: 0.75rem;
    font-size: 3rem;
  }

  .page-header p:last-child {
    margin: 0;
    max-width: 55ch;
    font-size: 1.08rem;
    color: #e7edf4;
  }

  .services-grid-section {
    padding: 4rem 0;
    background: linear-gradient(180deg, white 0%, #f3f5f8 100%);
  }

  .seo-copy {
    padding: 0 0 4rem;
    background: #f3f5f8;
  }

  .service-areas-section,
  .service-links-section,
  .service-faq-section {
    padding: 0 0 4rem;
    background: #f3f5f8;
  }

  .section-intro {
    max-width: 62ch;
    color: var(--brand-muted);
    margin: 0.75rem 0 1.5rem;
  }

  .seo-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .seo-columns p {
    margin-top: 0.75rem;
    color: var(--brand-muted);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .info-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    display: grid;
    grid-template-rows: auto minmax(3.6rem, auto) 1fr auto;
    gap: 0.9rem;
    padding: 1.6rem;
    border-radius: 22px;
    background: white;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .info-card {
    background: white;
    border-radius: 22px;
    padding: 1.6rem;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .accordion-card summary {
    list-style: none;
    cursor: pointer;
  }

  .accordion-card summary::-webkit-details-marker {
    display: none;
  }

  .info-card h2,
  .info-card h3 {
    margin: 0;
    color: var(--brand-navy);
  }

  .accordion-card h2,
  .accordion-card h3 {
    font-size: 1.3rem;
    line-height: 1.1;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .info-card p {
    margin: 0;
    color: var(--brand-muted);
  }

  .accordion-content {
    display: grid;
    gap: 0.85rem;
    padding-top: 1rem;
  }

  .accordion-content a {
    color: var(--brand-navy);
    font-weight: 700;
    text-decoration: none;
  }

  .accordion-content a:hover {
    text-decoration: underline;
  }

  .accordion-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 44px rgba(21, 38, 58, 0.14);
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .faq-item {
    background: white;
    border-radius: 22px;
    padding: 1.6rem;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
  }

  .faq-item h3 {
    margin: 0;
    color: var(--brand-navy);
  }

  .faq-item p {
    margin: 0;
    color: var(--brand-muted);
  }

  .service-card:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: 0 24px 44px rgba(21, 38, 58, 0.14);
  }

  .card-eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-green-dark);
    font-weight: 700;
  }

  .service-card h2,
  .card-title {
    font-size: 1.55rem;
    line-height: 1.1;
    color: var(--brand-navy);
    margin: 0;
  }

  .service-card p,
  .card-copy {
    color: var(--brand-muted);
    margin: 0;
  }

  .service-card span {
    color: var(--brand-navy);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .page-header {
      background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
      padding: 3.6rem 0 3rem;
    }

    .page-header h1 {
      font-size: 2.2rem;
    }

    .accordion-card h2,
    .accordion-card h3 {
      font-size: 1.05rem;
    }

    .service-faq-section {
      display: none;
    }
  }
</style>
