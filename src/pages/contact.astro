---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildBreadcrumbSchema } from '../lib/seo';

const rawFormspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || '';
const isFormConfigured = Boolean(rawFormspreeId && rawFormspreeId.startsWith('f/'));
const formAction = isFormConfigured ? `https://formspree.io/f/${rawFormspreeId}` : undefined;
const squareBookingUrl = 'https://app.squareup.com/appointments/book/lgocu4o42jy5zu/LGZ9VNRVZ6XXM/start';
const mapAddress = encodeURIComponent('11 rue de Granby, Unité 18, Gatineau, QC');
const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Accueil', path: '/' },
  { name: 'Contact' }
]);
---

<Layout title="Contact Clinique du VR | Soumission, Rendez-vous et Atelier Gatineau-Ottawa" description="Contactez Clinique du VR a Gatineau-Ottawa pour une soumission, un rendez-vous ou une demande d'inspection, entretien ou reparation." canonicalPath="/contact/" frPath="/contact/" enPath="/en/contact/" schemas={[breadcrumbs]}>
  <Header />

  <main>
    <section class="contact-container">
      <div class="container contact-layout">
        <div class="contact-form-section">
          <h1>Contactez-Nous</h1>
          <p class="intro-copy">Vous pouvez nous joindre pour une inspection de VR, un entretien, une reparation de fuite d'eau, un probleme de toiture, un service esthetique ou une question avant achat et vente. Plus votre message est precis, plus le retour sera utile.</p>
          <!-- TODO: Replace with actual Formspree form ID -->
          {!isFormConfigured && (
            <p class="intro-copy">Le formulaire sera active des que le vrai Formspree sera configure. En attendant, appelez-nous ou utilisez Square.</p>
          )}
          <form action={formAction} method="POST">
            <div class="form-group">
              <label for="name">Nom Complet *</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="phone">Téléphone</label>
              <input type="tel" id="phone" name="phone" />
            </div>
            <div class="form-group">
              <label for="subject">Sujet *</label>
              <input type="text" id="subject" name="subject" required />
            </div>
            <div class="form-group">
              <label for="message">Message *</label>
              <textarea id="message" name="message" rows="6" required></textarea>
            </div>
            <button type="submit" class="btn" disabled={!isFormConfigured}>Envoyer</button>
          </form>
        </div>

        <div class="contact-info-section">
          <h2>Informations de Contact</h2>

          <div class="info-block">
            <h3>Téléphone</h3>
            <div class="phone-actions">
              <a href="tel:+15813373366" class="phone-link">(581) 337-3366</a>
              <a href={squareBookingUrl} target="_blank" rel="noopener" class="square-button">Rendez-vous Square</a>
            </div>
          </div>

          <div class="info-block">
            <h3>Email</h3>
            <p><a href="mailto:info@demosolution.ca">info@demosolution.ca</a></p>
          </div>

          <div class="info-block">
            <h3>Localisation</h3>
            <p>11 rue de Granby, Unite 18, Gatineau, QC<br>Service: Gatineau, Ottawa, Laurentides, Outaouais, Quebec et Ontario</p>
          </div>

          <div class="info-block">
            <h3>Identite d'entreprise</h3>
            <p><strong>RBQ:</strong> 5824-9764-01<br>
            <strong>Professionnels depuis 2013</strong></p>
          </div>

          <div class="info-block">
            <h3>Valeurs cles</h3>
            <p>Rapidite • Transparence • Conformite reglementaire • Professionnels certifies</p>
          </div>

          <div class="info-block cta">
            <p>Demandez votre <strong>soumission gratuite</strong> par téléphone ou formulaire.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="contact-seo">
      <div class="container seo-columns">
        <div>
          <h2>Atelier VR a Gatineau-Ottawa</h2>
          <p>Clinique du VR dessert Gatineau, Ottawa, l'Outaouais et les environs pour les demandes de service reliees aux VR, roulottes et caravanes. Le formulaire et la prise de rendez-vous Square servent autant aux demandes simples qu'aux dossiers plus complexes.</p>
        </div>
        <div>
          <h2>Avant de nous ecrire</h2>
          <p>Si vous avez des photos, des signes d'infiltration, des details sur la toiture, les joints, les appareils 12V ou propane, mentionnez-les dans votre message. Cela aide a orienter plus rapidement vers une inspection, un entretien ou une reparation ciblee.</p>
        </div>
      </div>
    </section>

    <section class="map-section">
      <iframe
        title="Clinique du VR - 11 rue de Granby, Unite 18, Gatineau, QC"
        src={`https://www.google.com/maps?q=${mapAddress}&output=embed`}
        width="100%" height="400" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .contact-container {
    padding: 4rem 0;
    background: white;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .contact-form-section h1 {
    margin-bottom: 2rem;
  }

  .intro-copy {
    margin: -1rem 0 1.5rem;
    color: var(--brand-muted);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    margin-bottom: 1.5rem;
  }

  .form-group label {
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--brand-ink);
  }

  .form-group input,
  .form-group textarea {
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--brand-green);
    box-shadow: 0 0 0 3px rgba(61, 152, 47, 0.12);
  }

  .contact-info-section h2 {
    margin-bottom: 2rem;
  }

  .info-block {
    margin-bottom: 2rem;
  }

  .info-block h3 {
    color: var(--brand-navy);
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }

  .info-block.cta {
    background: var(--brand-surface);
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid var(--brand-green);
    margin-top: 3rem;
  }

  .map-section {
    width: 100%;
    margin-top: 3rem;
  }

  .contact-seo {
    padding: 0 0 4rem;
    background: white;
  }

  .seo-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .seo-columns p {
    margin-top: 0.75rem;
    color: var(--brand-muted);
  }

  .phone-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .phone-link {
    font-weight: 700;
  }

  .square-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-gold);
    color: var(--brand-navy-dark);
    border: 2px solid var(--brand-gold);
    border-radius: 999px;
    padding: 0.55rem 1rem;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .square-button:hover {
    text-decoration: none;
    background: #e1c317;
    border-color: #e1c317;
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
