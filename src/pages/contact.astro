---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactMap from '../components/ContactMap.astro';
import { buildBreadcrumbSchema, buildContactPageSchema, buildWebSiteSchema } from '../lib/seo';
import siteSettings from '../data/site-settings.json';
import contactPage from '../data/contact-page.json';

const isFormConfigured = Boolean(siteSettings.email?.trim());
const successUrl = '/merci/';
const formName = 'contact-fr-v2';
const breadcrumbs = buildBreadcrumbSchema([
  { name: contactPage.breadcrumbs.home, path: '/' },
  { name: contactPage.breadcrumbs.current }
]);
const schemas = [
  buildWebSiteSchema(),
  buildContactPageSchema({
    name: contactPage.metaTitle,
    description: contactPage.metaDescription,
    path: '/contact/'
  }),
  breadcrumbs
];
---

<Layout title={contactPage.metaTitle} description={contactPage.metaDescription} canonicalPath="/contact/" frPath="/contact/" enPath="/en/contact/" schemas={schemas}>
  <Header />

  <main>
    <section class="interior-hero">
      <div class="container interior-hero-grid">
        <div class="interior-hero-copy">
          <p class="interior-eyebrow">Parlez-nous de votre VR</p>
          <h1>{contactPage.formSection.title}</h1>
          <p class="interior-lead">{contactPage.formSection.intro}</p>
        </div>

        <aside class="interior-hero-card">
          <div class="interior-hero-icon">
            <i class="fas fa-envelope-open-text"></i>
          </div>
          <h2>Pour aller plus vite</h2>
          <p>Envoyez le type de véhicule, la ville, quelques photos et ce que vous voyez déjà. Cela aide à orienter la demande dès le premier contact.</p>
          <a class="interior-hero-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">Réserver en ligne</a>
        </aside>
      </div>
    </section>

    <section class="interior-section">
      <div class="container interior-body-grid contact-layout">
        <div class="contact-form-section">
          <section class="interior-card interior-card-alt quick-guide-card">
            <h2>Quoi envoyer pour obtenir une meilleure réponse</h2>
            <div class="guide-grid">
              <article class="guide-item">
                <h3>Le véhicule</h3>
                <p>Marque, année, modèle et si possible numéro de série.</p>
              </article>
              <article class="guide-item">
                <h3>Le problème</h3>
                <p>Fuite d’eau, joints, toit, entretien, esthétique ou préparation avant vente.</p>
              </article>
              <article class="guide-item">
                <h3>Le contexte</h3>
                <p>Ville, atelier ou mobile, urgence réelle et quelques photos utiles.</p>
              </article>
            </div>
          </section>

          <section class="interior-card">
            <h2>{contactPage.formSection.title}</h2>
            {!isFormConfigured && (
              <p class="intro-copy">{contactPage.formSection.unconfiguredNote}</p>
            )}
            <form name={formName} action={isFormConfigured ? successUrl : undefined} method="POST" enctype="multipart/form-data" data-netlify="true" netlify-honeypot="bot-field" data-netlify-form>
              <input type="hidden" name="form-name" value={formName} />
              <input type="hidden" name="bot-field" />
              <input type="hidden" name="Page" value="Contact FR" />
              <input type="hidden" name="Services demandés" data-services-output />
              <input type="hidden" name="Type d’intervention" data-worktype-output />
              <div class="form-group">
                <label for="name">{contactPage.formSection.fields.name}</label>
                <input type="text" id="name" name="Nom complet" required />
              </div>
              <div class="form-group">
                <label for="email">{contactPage.formSection.fields.email}</label>
                <input type="email" id="email" name="Courriel" required />
              </div>
              <div class="form-group">
                <label for="phone">{contactPage.formSection.fields.phone}</label>
                <input type="tel" id="phone" name="Téléphone" />
              </div>
              <fieldset class="form-group form-fieldset">
                <legend>{contactPage.formSection.fields.services}</legend>
                <div class="checkbox-grid">
                  {contactPage.formSection.fields.serviceOptions.map((option, index) => (
                    <label class="check-option" for={`service-${index}`}>
                      <input type="checkbox" id={`service-${index}`} value={option} data-service-option />
                      <span>{option}</span>
                    </label>
                  ))}
                </div>
              </fieldset>
              <fieldset class="form-group form-fieldset">
                <legend>{contactPage.formSection.fields.workType}</legend>
                <div class="checkbox-grid checkbox-grid--two">
                  <label class="check-option" for="workshop">
                    <input type="radio" id="workshop" name="workTypeChoiceFr" value={contactPage.formSection.fields.workshopOption} data-worktype-option />
                    <span>{contactPage.formSection.fields.workshopOption}</span>
                  </label>
                  <label class="check-option" for="mobile">
                    <input type="radio" id="mobile" name="workTypeChoiceFr" value={contactPage.formSection.fields.mobileOption} data-worktype-option />
                    <span>{contactPage.formSection.fields.mobileOption}</span>
                  </label>
                </div>
              </fieldset>
              <div class="form-group">
                <label for="work-address">{contactPage.formSection.fields.workAddress}</label>
                <input type="text" id="work-address" name="Adresse des travaux" />
              </div>
              <div class="form-group">
                <label for="vehicle-info">{contactPage.formSection.fields.vehicleInfo}</label>
                <input type="text" id="vehicle-info" name="Marque et année du VR" />
              </div>
              <div class="form-group">
                <label for="serial-number">{contactPage.formSection.fields.serialNumber}</label>
                <input type="text" id="serial-number" name="Numéro de série" />
              </div>
              <div class="form-group">
                <label for="attachments">{contactPage.formSection.fields.attachments}</label>
                <input type="file" id="attachments" name="Pièce jointe" multiple accept="image/*,.pdf,.doc,.docx" />
              </div>
              <div class="form-group">
                <label for="message">{contactPage.formSection.fields.message}</label>
                <textarea id="message" name="Message" rows="6" required></textarea>
              </div>
              <button type="submit" class="btn" disabled={!isFormConfigured}>{contactPage.formSection.submitLabel}</button>
            </form>
          </section>
        </div>

        <aside class="interior-side-panel contact-info-section">
          <div class="interior-side-card interior-side-card-primary">
            <h3>Besoin d’un avis rapide?</h3>
            <p>On peut vous orienter vers une inspection, un entretien ou une réparation selon ce que vous observez déjà sur le véhicule.</p>
            <a class="interior-side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
            <a class="interior-side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">{contactPage.infoSection.squareLabel}</a>
          </div>

          <div class="interior-side-card">
            <h3>{contactPage.infoSection.title}</h3>
            <div class="info-block">
              <h3>{contactPage.infoSection.phoneTitle}</h3>
              <div class="phone-actions">
                <a href={`tel:${siteSettings.phone.href}`} class="phone-link">{siteSettings.phone.display}</a>
                <a href={siteSettings.squareBookingUrl} target="_blank" rel="noopener" class="square-button">{contactPage.infoSection.squareLabel}</a>
              </div>
            </div>

            <div class="info-block">
              <h3>{contactPage.infoSection.emailTitle}</h3>
              <p><a href={`mailto:${siteSettings.email}`}>{siteSettings.email}</a></p>
            </div>

            <div class="info-block">
              <h3>{contactPage.infoSection.locationTitle}</h3>
              <p>{siteSettings.address.fr}<br>Service: {siteSettings.serviceArea.fr}</p>
            </div>

            <div class="info-block">
              <h3>{contactPage.infoSection.identityTitle}</h3>
              <p set:html={contactPage.infoSection.identityBody} />
            </div>

            <div class="info-block">
              <h3>{contactPage.infoSection.valuesTitle}</h3>
              <p>{contactPage.infoSection.valuesBody}</p>
            </div>

            <div class="info-block cta">
              <p set:html={contactPage.infoSection.ctaBody} />
            </div>
          </div>

          <div class="interior-side-card">
            <h3>À quoi vous attendre</h3>
            <nav class="interior-service-nav" aria-label="Prochaines étapes">
              <a href="/services/inspection/"><i class="fas fa-clipboard-check"></i><span>Si la source n’est pas claire: inspection</span></a>
              <a href="/services/entretien/"><i class="fas fa-screwdriver-wrench"></i><span>Si c’est surtout préventif: entretien</span></a>
              <a href="/services/reparation/"><i class="fas fa-toolbox"></i><span>Si des dommages sont visibles: réparation</span></a>
              <a href="/realisations/"><i class="fas fa-images"></i><span>Voir des cas réels</span></a>
            </nav>
          </div>
        </aside>
      </div>
    </section>

    <section class="contact-seo">
      <div class="container seo-columns">
        {contactPage.seoSections.map((section) => (
          <div class="interior-card">
            <h2>{section.heading}</h2>
            <p>{section.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="map-section">
      <ContactMap title={contactPage.mapTitle} />
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.querySelector('form[data-netlify-form][name="contact-fr-v2"]');

  if (form instanceof HTMLFormElement) {
    const syncFields = () => {
      const servicesOutput = form.querySelector('[data-services-output]');
      const workTypeOutput = form.querySelector('[data-worktype-output]');
      const selectedServices = Array.from(form.querySelectorAll('[data-service-option]:checked'))
        .map((input) => input instanceof HTMLInputElement ? input.value : '')
        .filter(Boolean);
      const selectedWorkType = form.querySelector('[data-worktype-option]:checked');

      if (servicesOutput instanceof HTMLInputElement) {
        servicesOutput.value = selectedServices.join(', ');
      }

      if (workTypeOutput instanceof HTMLInputElement && selectedWorkType instanceof HTMLInputElement) {
        workTypeOutput.value = selectedWorkType.value;
      }
    };

    form.addEventListener('change', syncFields);
    form.addEventListener('submit', syncFields);
    syncFields();
  }
</script>

<style>
  .interior-hero-copy h1 { max-width: 12ch; }
  .contact-form-section { display: grid; gap: 1.5rem; }
  .intro-copy { color: var(--brand-muted); margin-bottom: 1rem; }
  .guide-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; }
  .guide-item { background: var(--brand-surface); border-radius: 16px; padding: 1rem; }
  .guide-item h3 { font-size: 1rem; margin-bottom: 0.35rem; }
  .guide-item p { color: var(--brand-muted); }
  .form-group { display: flex; flex-direction: column; margin-bottom: 1.5rem; }
  .form-group label { font-weight: 600; margin-bottom: 0.5rem; color: var(--brand-ink); }
  .form-fieldset { border: 1px solid rgba(23, 48, 79, 0.12); border-radius: 16px; padding: 1rem; }
  .form-fieldset legend { padding: 0 0.35rem; font-weight: 600; color: var(--brand-ink); }
  .form-group input, .form-group textarea { padding: 12px; border: 1px solid rgba(23, 48, 79, 0.14); border-radius: 12px; font-family: inherit; font-size: 1rem; }
  .checkbox-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.75rem; }
  .checkbox-grid--two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .check-option { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 0; font-weight: 400; }
  .check-option input { width: auto; margin: 0; }
  .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--brand-green); box-shadow: 0 0 0 3px rgba(61, 152, 47, 0.12); }
  .info-block { margin-bottom: 1.5rem; }
  .info-block h3 { color: var(--brand-navy); margin-bottom: 0.5rem; font-size: 1rem; }
  .interior-side-card .info-block.cta { background: var(--brand-surface); padding: 1.5rem; border-radius: 16px; border-left: 4px solid var(--brand-green); margin-top: 2rem; }
  .contact-seo { padding: 0 0 4rem; background: white; }
  .seo-columns { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
  .seo-columns p { margin-top: 0.75rem; color: var(--brand-muted); }
  .phone-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
  .phone-link { font-weight: 700; }
  .square-button { display: inline-flex; align-items: center; justify-content: center; background: var(--brand-gold); color: var(--brand-navy-dark); border: 2px solid var(--brand-gold); border-radius: 999px; padding: 0.55rem 1rem; font-weight: 700; font-size: 0.95rem; }
  .square-button:hover { text-decoration: none; background: #e1c317; border-color: #e1c317; }
  .map-section { width: 100%; margin-top: 3rem; }
  @media (max-width: 768px) {
    .guide-grid,
    .checkbox-grid,
    .checkbox-grid--two {
      grid-template-columns: 1fr;
    }

    .map-section { margin-top: 2rem; }
  }
</style>
