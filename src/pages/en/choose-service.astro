---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';

const symptomCards = [
  {
    title: 'Water intrusion or moisture',
    copy: 'If you notice water stains, suspicious seals, or moisture, inspection is often the best first step to confirm the RV’s actual condition.',
    href: '/en/services/inspection/',
    linkLabel: 'View inspection service'
  },
  {
    title: 'Worn seals or roof concerns',
    copy: 'When seals are drying out, cracking, or lifting, maintenance helps preserve the seal and prevent more expensive damage.',
    href: '/en/services/maintenance/',
    linkLabel: 'View maintenance service'
  },
  {
    title: 'Damage already visible',
    copy: 'If water has already damaged the floor, walls, roof, or interior finishes, repair becomes the right next step.',
    href: '/en/services/repair/',
    linkLabel: 'View repair service'
  },
  {
    title: 'Before buying or selling',
    copy: 'To clarify an RV’s actual condition before a transaction, inspection is usually the best first step to identify strengths, risks, and useful corrections.',
    href: '/en/services/inspection/',
    linkLabel: 'View transaction inspection'
  },
  {
    title: 'Vehicle looks tired or needs presentation work',
    copy: 'For an RV or motorhome that needs real cleaning, polishing, or waxing, detailing helps restore presentation, cleanliness, and finish quality either at the workshop or on the road.',
    href: '/en/services/detailing/',
    linkLabel: 'View RV detailing'
  },
  {
    title: 'You are hesitating between two services',
    copy: 'When the situation is not clear, contact us with photos and a short description of the issue. We can point you to the most useful first step.',
    href: '/en/contact/',
    linkLabel: 'Contact the workshop'
  }
];

const serviceAreas = [
  { name: 'Gatineau | Water leak', href: '/en/areas/rv-water-leak-gatineau/' },
  { name: 'Gatineau | Maintenance', href: '/en/areas/rv-maintenance-gatineau/' },
  { name: 'Outaouais', href: '/en/areas/rv-inspection-outaouais/' },
  { name: 'Ottawa', href: '/en/areas/rv-repair-ottawa/' },
  { name: 'Laurentides', href: '/en/areas/trailer-water-intrusion-laurentides/' }
];
const faqs = [
  {
    question: 'What is the best first step if I am not sure what the problem is?',
    answer: 'When the problem is not clear, inspection is often the best starting point. It helps confirm the vehicle’s actual condition and avoids going in the wrong direction.'
  },
  {
    question: 'When should I choose maintenance instead of repair?',
    answer: 'Maintenance is generally the right fit when you want to prevent water intrusion, refresh seals, or care for the roof before significant damage appears. If damage is already visible, repair is often the better direction.'
  },
  {
    question: 'Can detailing help before selling an RV?',
    answer: 'Yes. Detailing can improve presentation, but if the goal is to clarify the true condition of the vehicle before a transaction, inspection is usually the most useful first step.'
  }
];

const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Home', path: '/en/' },
  { name: 'Which service should you choose?' }
]);
---

<Layout
  title="Which RV service should you choose in Gatineau | Clinique du VR"
  description="Choose the right RV service in Gatineau based on visible symptoms: water leaks, seal and roof maintenance, repair, detailing, or inspection before buying."
  lang="en-CA"
  canonicalPath="/en/choose-service/"
  frPath="/choisir-service/"
  enPath="/en/choose-service/"
  schemas={[breadcrumbs, buildFAQSchema(faqs)]}
>
  <Header lang="en" />

  <main>
    <section class="page-header">
      <div class="container">
        <p class="eyebrow">Practical guidance</p>
        <h1>Which service should you choose for your RV?</h1>
        <p>Use this page to identify the right starting point based on visible symptoms, the vehicle’s actual condition, and your situation.</p>
      </div>
    </section>

    <section class="chooser-section">
      <div class="container">
        <div class="section-intro">
          <h2>Start with the right service</h2>
          <p>When an RV shows more than one issue at the same time, it is not always obvious whether you should begin with inspection, maintenance, repair, or detailing. The cards below help point you to the most useful next step for an RV or motorhome.</p>
        </div>

        <div class="card-grid">
          {symptomCards.map((item) => (
            <a class="choice-card" href={item.href}>
              <h2>{item.title}</h2>
              <p>{item.copy}</p>
              <span>{item.linkLabel}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="areas-section">
      <div class="container">
        <h2>Areas served</h2>
        <p class="section-copy">We receive requests from Outaouais, Ottawa, and the Laurentides depending on the type of need and the vehicle’s situation.</p>
        <div class="card-grid areas-grid">
          {serviceAreas.map((area) => (
            <a class="info-card choice-card" href={area.href}>
              <h3>{area.name}</h3>
              <p>Common requests include inspection, maintenance, repair, detailing, and support before a transaction.</p>
              <span>View local page</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="faq-section">
      <div class="container">
        <h2>Frequently asked questions</h2>
        <div class="faq-list">
          {faqs.map((item) => (
            <details class="faq-card">
              <summary><h3>{item.question}</h3></summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer lang="en" />
</Layout>

<style>
  .page-header {
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 25%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 58%, #eef3f7 58%, #eef3f7 100%);
    color: white;
    padding: 4.5rem 0 3.8rem;
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: var(--brand-gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-header h1 {
    color: white;
    margin-bottom: 0.75rem;
    font-size: 3rem;
    max-width: 14ch;
  }

  .page-header p:last-child {
    margin: 0;
    max-width: 55ch;
    font-size: 1.08rem;
    color: #e7edf4;
  }

  .chooser-section,
  .areas-section,
  .faq-section {
    padding: 4rem 0;
    background: #f3f5f8;
  }

  .areas-section,
  .faq-section {
    padding-top: 0;
  }

  .section-intro {
    max-width: 64ch;
    margin-bottom: 1.5rem;
  }

  .section-intro p,
  .section-copy,
  .info-card p,
  .faq-card p,
  .choice-card p {
    color: var(--brand-muted);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .choice-card,
  .info-card,
  .faq-card {
    background: white;
    border-radius: 22px;
    padding: 1.6rem;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
  }

  .faq-card summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .faq-card summary::-webkit-details-marker {
    display: none;
  }

  .faq-card summary::after {
    content: '+';
    flex: 0 0 auto;
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1;
    color: var(--brand-navy);
  }

  .faq-card[open] summary::after {
    content: '-';
  }

  .choice-card {
    display: grid;
    gap: 0.9rem;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .choice-card:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: 0 24px 44px rgba(21, 38, 58, 0.14);
  }

  .choice-card h2,
  .info-card h3,
  .faq-card h3 {
    margin: 0;
    color: var(--brand-navy);
  }

  .choice-card span {
    color: var(--brand-navy);
    font-weight: 700;
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .page-header {
      background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
      padding: 3.6rem 0 3rem;
    }

    .page-header h1 {
      font-size: 2.2rem;
      max-width: none;
    }

    .chooser-section,
    .areas-section,
    .faq-section {
      padding: 3rem 0;
      background: #f3f5f8;
    }

    .areas-section,
    .faq-section {
      padding-top: 0;
    }
  }
</style>
