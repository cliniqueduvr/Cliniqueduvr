---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactMap from '../../components/ContactMap.astro';
import { buildBreadcrumbSchema, buildContactPageSchema, buildWebSiteSchema } from '../../lib/seo';
import siteSettings from '../../data/site-settings.json';
import contactPage from '../../data/contact-page-en.json';

const isFormConfigured = Boolean(siteSettings.email?.trim());
const formAction = isFormConfigured ? `https://formsubmit.co/${siteSettings.email}` : undefined;
const successUrl = 'https://www.cliniqueduvr.ca/en/contact/?sent=1';
const messageSent = Astro.url.searchParams.get('sent') === '1';
const breadcrumbs = buildBreadcrumbSchema([
  { name: contactPage.breadcrumbs.home, path: '/en/' },
  { name: contactPage.breadcrumbs.current }
]);
const schemas = [
  buildWebSiteSchema(),
  buildContactPageSchema({
    name: contactPage.metaTitle,
    description: contactPage.metaDescription,
    path: '/en/contact/'
  }),
  breadcrumbs
];
---

<Layout title={contactPage.metaTitle} description={contactPage.metaDescription} lang="en-CA" canonicalPath="/en/contact/" frPath="/contact/" enPath="/en/contact/" schemas={schemas}>
  <Header lang="en" />

  <main>
    <section class="page-header">
      <div class="container">
        <p class="eyebrow">Tell us about your RV</p>
        <h1>{contactPage.formSection.title}</h1>
        <p>{contactPage.formSection.intro}</p>
      </div>
    </section>

    <section class="contact-container">
      <div class="container contact-layout">
        <div class="contact-form-section">
          {messageSent && (
            <p class="success-copy">We have received your request. We will reply within 24 hours. For urgent matters, please contact us by phone.</p>
          )}
          {!isFormConfigured && (
            <p class="intro-copy">{contactPage.formSection.unconfiguredNote}</p>
          )}
          <form action={formAction} method="POST" enctype="multipart/form-data">
            <input type="hidden" name="_next" value={successUrl} />
            <input type="hidden" name="_subject" value="New message from Clinique du VR website form" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_autoresponse" value="We have received your request at Clinique du VR. We will reply within 24 hours. For urgent matters, please contact us by phone." />
            <input type="text" name="_honey" class="sr-only" tabindex="-1" autocomplete="off" />
            <div class="form-group">
              <label for="name">{contactPage.formSection.fields.name}</label>
              <input type="text" id="name" name="Full name" required />
            </div>
            <div class="form-group">
              <label for="email">{contactPage.formSection.fields.email}</label>
              <input type="email" id="email" name="Email" required />
            </div>
            <div class="form-group">
              <label for="phone">{contactPage.formSection.fields.phone}</label>
              <input type="tel" id="phone" name="Phone" />
            </div>
            <fieldset class="form-group form-fieldset">
              <legend>{contactPage.formSection.fields.services}</legend>
              <div class="checkbox-grid">
                {contactPage.formSection.fields.serviceOptions.map((option, index) => (
                  <label class="check-option" for={`service-${index}`}>
                    <input type="checkbox" id={`service-${index}`} name="Requested services[]" value={option} />
                    <span>{option}</span>
                  </label>
                ))}
              </div>
            </fieldset>
            <fieldset class="form-group form-fieldset">
              <legend>{contactPage.formSection.fields.workType}</legend>
              <div class="checkbox-grid checkbox-grid--two">
                <label class="check-option" for="workshop">
                  <input type="radio" id="workshop" name="Type of work" value={contactPage.formSection.fields.workshopOption} />
                  <span>{contactPage.formSection.fields.workshopOption}</span>
                </label>
                <label class="check-option" for="mobile">
                  <input type="radio" id="mobile" name="Type of work" value={contactPage.formSection.fields.mobileOption} />
                  <span>{contactPage.formSection.fields.mobileOption}</span>
                </label>
              </div>
            </fieldset>
            <div class="form-group">
              <label for="work-address">{contactPage.formSection.fields.workAddress}</label>
              <input type="text" id="work-address" name="Work address" />
            </div>
            <div class="form-group">
              <label for="vehicle-info">{contactPage.formSection.fields.vehicleInfo}</label>
              <input type="text" id="vehicle-info" name="RV make and year" />
            </div>
            <div class="form-group">
              <label for="serial-number">{contactPage.formSection.fields.serialNumber}</label>
              <input type="text" id="serial-number" name="Serial number" />
            </div>
            <div class="form-group">
              <label for="attachments">{contactPage.formSection.fields.attachments}</label>
              <input type="file" id="attachments" name="Attachment" multiple accept="image/*,.pdf,.doc,.docx" />
            </div>
            <div class="form-group">
              <label for="message">{contactPage.formSection.fields.message}</label>
              <textarea id="message" name="Message" rows="6" required></textarea>
            </div>
            <button type="submit" class="btn" disabled={!isFormConfigured}>{contactPage.formSection.submitLabel}</button>
          </form>
        </div>

        <div class="contact-info-section">
          <h2>{contactPage.infoSection.title}</h2>

          <div class="info-block">
            <h3>{contactPage.infoSection.phoneTitle}</h3>
            <div class="phone-actions">
              <a href={`tel:${siteSettings.phone.href}`} class="phone-link">{siteSettings.phone.display}</a>
              <a href={siteSettings.squareBookingUrl} target="_blank" rel="noopener" class="square-button">{contactPage.infoSection.squareLabel}</a>
            </div>
          </div>

          <div class="info-block">
            <h3>{contactPage.infoSection.emailTitle}</h3>
            <p><a href={`mailto:${siteSettings.email}`}>{siteSettings.email}</a></p>
          </div>

          <div class="info-block">
            <h3>{contactPage.infoSection.locationTitle}</h3>
            <p>{siteSettings.address.en}<br>Service area: {siteSettings.serviceArea.en}</p>
          </div>

          <div class="info-block">
            <h3>{contactPage.infoSection.identityTitle}</h3>
            <p set:html={contactPage.infoSection.identityBody} />
          </div>

          <div class="info-block">
            <h3>{contactPage.infoSection.valuesTitle}</h3>
            <p>{contactPage.infoSection.valuesBody}</p>
          </div>

          <div class="info-block cta">
            <p set:html={contactPage.infoSection.ctaBody} />
          </div>
        </div>
      </div>
    </section>

    <section class="contact-seo">
      <div class="container seo-columns">
        {contactPage.seoSections.map((section) => (
          <div>
            <h2>{section.heading}</h2>
            <p>{section.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="map-section">
      <ContactMap title={contactPage.mapTitle} lang="en" />
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .page-header { background: radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 25%), linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 58%, #eef3f7 58%, #eef3f7 100%); color: white; padding: 4.5rem 0 3.8rem; }
  .eyebrow { display: inline-flex; margin-bottom: 1rem; padding: 0.45rem 0.85rem; border-radius: 999px; background: rgba(255, 255, 255, 0.12); color: var(--brand-gold); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .page-header h1 { max-width: 12ch; color: white; margin-bottom: 0.9rem; }
  .page-header p:last-child { max-width: 58ch; color: #e7edf4; font-size: 1.08rem; }
  .contact-container { padding: 4rem 0; background: #eef3f7; }
  .contact-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
  .contact-form-section h1 { margin-bottom: 2rem; }
  .intro-copy { margin: -1rem 0 1.5rem; color: var(--brand-muted); }
  .success-copy { margin: -1rem 0 1.5rem; padding: 0.9rem 1rem; border-radius: 12px; background: rgba(58, 141, 47, 0.1); color: var(--brand-green-dark); font-weight: 700; }
  .form-group { display: flex; flex-direction: column; margin-bottom: 1.5rem; }
  .form-group label { font-weight: 600; margin-bottom: 0.5rem; color: var(--brand-ink); }
  .form-fieldset { border: 1px solid #ddd; border-radius: 8px; padding: 1rem; }
  .form-fieldset legend { padding: 0 0.35rem; font-weight: 600; color: var(--brand-ink); }
  .form-group input, .form-group textarea { padding: 12px; border: 1px solid #ddd; border-radius: 4px; font-family: inherit; font-size: 1rem; }
  .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--brand-green); box-shadow: 0 0 0 3px rgba(61, 152, 47, 0.12); }
  .checkbox-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.75rem; }
  .checkbox-grid--two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .check-option { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 0; font-weight: 400; }
  .check-option input { width: auto; margin: 0; }
  .contact-info-section h2 { margin-bottom: 2rem; }
  .info-block { margin-bottom: 2rem; }
  .info-block h3 { color: var(--brand-navy); margin-bottom: 0.5rem; font-size: 1rem; }
  .info-block.cta { background: var(--brand-surface); padding: 1.5rem; border-radius: 8px; border-left: 4px solid var(--brand-green); margin-top: 3rem; }
  .map-section { width: 100%; margin-top: 3rem; }
  .contact-seo { padding: 0 0 4rem; background: white; }
  .seo-columns { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
  .seo-columns p { margin-top: 0.75rem; color: var(--brand-muted); }
  .phone-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
  .phone-link { font-weight: 700; }
  .square-button { display: inline-flex; align-items: center; justify-content: center; background: var(--brand-gold); color: var(--brand-navy-dark); border: 2px solid var(--brand-gold); border-radius: 999px; padding: 0.55rem 1rem; font-weight: 700; font-size: 0.95rem; }
  .square-button:hover { text-decoration: none; background: #e1c317; border-color: #e1c317; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  @media (max-width: 768px) { .page-header { background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%); padding: 3.6rem 0 3rem; } .contact-layout { grid-template-columns: 1fr; gap: 2rem; } }
</style>
