---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTABanner from '../../components/CTABanner.astro';
import services from '../../data/services-en.json';
---

<Layout title="Services | Clinique du VR" description="RV maintenance, repair and detailing services in Gatineau-Ottawa">
  <Header lang="en" />

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Our Services</h1>
        <p>Practical solutions for RV upkeep, repairs and detailing</p>
      </div>
    </section>

    {services.map((service) => (
      <ServiceCard
        id={service.id}
        title={service.title}
        icon={service.icon}
        description={service.description}
        details={service.details}
      />
    ))}

    <CTABanner
      lang="en"
      heading="Ready to get started?"
      subheading="Contact us for a free and confidential estimate."
      squareLabel="Book now"
    />
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .page-header { background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/clinique-du-vr-brand.jpg'); background-size: cover; background-position: center; color: white; padding: 4rem 0; text-align: center; }
  .page-header h1 { color: white; margin-bottom: 0.5rem; font-size: 2.5rem; }
  .page-header p { margin: 0; font-size: 1.1rem; color: #ffffff; }
  @media (max-width: 768px) { .page-header { padding: 3rem 1.5rem; } .page-header h1 { font-size: 2rem; } .page-header p { font-size: 1rem; } }
</style>
