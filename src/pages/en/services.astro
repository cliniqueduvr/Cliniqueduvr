---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';
import servicePagesData from '../../data/service-pages-en.json';
import type { ServicePage } from '../../data/service-page-types';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';

const servicePagesEn = servicePagesData.items as ServicePage[];
const visibleServicePagesEn = servicePagesEn.filter((service) => service.slug !== 'buying-selling');
const serviceAreas = [
  {
    name: 'Outaouais',
    href: '/en/areas/rv-inspection-outaouais/',
    body: 'Inspection, pre-purchase review, and a fast read on the real condition of the RV.'
  },
  {
    name: 'Ottawa',
    href: '/en/areas/rv-repair-ottawa/',
    body: 'Repair work tied to water intrusion, roofing, walls, floors, and visible damage.'
  },
  {
    name: 'Laurentides',
    href: '/en/areas/trailer-water-intrusion-laurentides/',
    body: 'Trailer water intrusion, worn seals, and moisture concerns that need a clear starting point.'
  }
];
const serviceGuides = [
  {
    title: 'Contact us',
    body: 'Describe the issue, the vehicle, and your priority so we can direct you to the right service.',
    href: '/en/contact/',
    label: 'Contact the workshop'
  },
  {
    title: 'Real examples',
    body: 'Review before-and-after workshop cases to better understand what kind of help you need.',
    href: '/en/realisations/',
    label: 'View projects'
  },
  {
    title: 'Before buying or selling',
    body: 'If your situation involves a transaction, start with inspection to clarify the real condition of the vehicle.',
    href: '/en/services/inspection/',
    label: 'View inspection service'
  },
  {
    title: 'Choose a service',
    body: 'If you are not sure where to start, use our guidance page by symptom and situation.',
    href: '/en/choose-service/',
    label: 'View guidance page'
  }
];
const serviceFaqs = [
  {
    question: 'How do I choose the right service for my RV?',
    answer: 'The right service depends on the actual condition of the vehicle. If you notice water intrusion, worn seals, interior damage, or if you are preparing for a purchase or sale, we can guide you toward inspection, maintenance, repair, detailing, or buying and selling support.'
  },
  {
    question: 'Do you only work in Gatineau?',
    answer: 'No. The workshop is in Gatineau, but we also help clients in Ottawa, Outaouais, and Laurentides depending on the type of request.'
  },
  {
    question: 'Do you offer both shop and mobile services?',
    answer: 'Yes, depending on the service. Some work is best handled in the shop, while other situations may also allow mobile service or travel support depending on the request.'
  }
];
const quickSteps = [
  'Choose the main type of need first.',
  'Open only the service or area that matches your situation.',
  'Use inspection as the starting point for buying, selling, or uncertainty.'
];
const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Home', path: '/en/' },
  { name: 'Services' }
]);
---

<Layout title="RV Services in Gatineau | Maintenance, Repair, and Detailing" description="RV services in Gatineau, with support for Ottawa, Outaouais and Laurentides: inspection, maintenance, repair, RV and auto detailing, and buying and selling support." lang="en-CA" canonicalPath="/en/services/" frPath="/services/" enPath="/en/services/" schemas={[breadcrumbs, buildFAQSchema(serviceFaqs)]}>
  <Header lang="en" />

  <main>
    <section class="page-header">
      <div class="container">
        <p class="eyebrow">For every RV situation</p>
        <h1>Our Services</h1>
        <p>Inspection, maintenance, repair, and RV and auto detailing based on the vehicle's real condition.</p>
      </div>
    </section>

    <section class="services-grid-section">
      <div class="container services-grid">
        {visibleServicePagesEn.map((service) => (
          <a class="service-card" href={`/en/services/${service.slug}/`}>
            <p class="card-eyebrow">{service.eyebrow}</p>
            <h2 class="card-title">{service.navLabel}</h2>
            <p class="card-copy">{service.lead}</p>
            <span>Learn more</span>
          </a>
        ))}
      </div>
    </section>

    <section class="seo-copy">
      <div class="container seo-columns">
        <div>
          <h2>The right service for the condition of your RV</h2>
          <p>Whether you are getting ready for the season, reviewing a vehicle before purchase, or dealing with an active repair issue, we can point you toward the right service based on the actual condition of the RV and the urgency of the situation.</p>
        </div>
        <div>
          <h2>What the workshop covers</h2>
          <p>Water leaks, roof issues, seals, propane and electrical systems, interior restoration, detailing, and inspection before a transaction.</p>
        </div>
      </div>
    </section>

    <section class="planning-section">
      <div class="container planning-layout">
        <div class="quick-steps-card">
          <h2>Where to start</h2>
          <div class="quick-steps-list">
            {quickSteps.map((item) => (
              <p>{item}</p>
            ))}
          </div>
        </div>

        <div class="quick-guides-card">
          <h2>Useful shortcuts</h2>
          <div class="guide-list">
            {serviceGuides.map((guide) => (
              <a class="guide-item" href={guide.href}>
                <h3>{guide.title}</h3>
                <p>{guide.body}</p>
                <span>{guide.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="service-areas-section">
      <div class="container">
        <h2>Areas served</h2>
        <p class="section-intro">We receive service requests from Outaouais, Ottawa, and Laurentides depending on the type of work and the condition of the vehicle.</p>
        <div class="area-grid">
          {serviceAreas.map((area) => (
            <a class="area-card" href={area.href}>
              <h3>{area.name}</h3>
              <p>{area.body}</p>
              <span>View local page</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="service-faq-section">
      <div class="container">
        <h2>Frequently asked questions</h2>
        <div class="faq-list">
          {serviceFaqs.map((item) => (
            <details class="faq-item">
              <summary>
                <h3>{item.question}</h3>
              </summary>
              <div class="accordion-content">
                <p>{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CTABanner
      lang="en"
      heading="Need help with a specific RV issue?"
      subheading="Choose the service that matches your situation or contact us and we will point you in the right direction."
      squareLabel="Book now"
    />
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .page-header {
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 25%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 58%, #eef3f7 58%, #eef3f7 100%);
    color: white;
    padding: 4.5rem 0 3.8rem;
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: var(--brand-gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-header h1 {
    color: white;
    margin-bottom: 0.75rem;
    font-size: 3rem;
  }

  .page-header p:last-child {
    margin: 0;
    max-width: 55ch;
    font-size: 1.08rem;
    color: #e7edf4;
  }

  .services-grid-section {
    padding: 4rem 0;
    background: linear-gradient(180deg, white 0%, #f3f5f8 100%);
  }

  .seo-copy,
  .planning-section,
  .service-areas-section,
  .service-faq-section {
    padding: 0 0 4rem;
    background: #f3f5f8;
  }

  .section-intro {
    max-width: 62ch;
    color: var(--brand-muted);
    margin: 0.75rem 0 1.5rem;
  }

  .seo-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
  }

  .seo-columns p {
    margin-top: 0.75rem;
    color: var(--brand-muted);
  }

  .planning-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .quick-steps-card,
  .quick-guides-card {
    display: grid;
    gap: 1rem;
    padding: 1.6rem;
    border-radius: 22px;
    background: white;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
  }

  .quick-steps-list {
    display: grid;
    gap: 0.85rem;
  }

  .quick-steps-list p {
    margin: 0;
    color: var(--brand-muted);
  }

  .guide-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .service-card,
  .guide-item,
  .area-card {
    display: grid;
    gap: 0.85rem;
    padding: 1.5rem;
    border-radius: 22px;
    background: white;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .service-card {
    grid-template-rows: auto minmax(3.6rem, auto) 1fr auto;
  }

  .service-card:hover,
  .guide-item:hover,
  .area-card:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: 0 24px 44px rgba(21, 38, 58, 0.14);
  }

  .card-eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-green-dark);
    font-weight: 700;
  }

  .service-card h2,
  .card-title {
    font-size: 1.55rem;
    line-height: 1.1;
    color: var(--brand-navy);
    margin: 0;
  }

  .guide-item h3,
  .area-card h3,
  .faq-item h3 {
    margin: 0;
    color: var(--brand-navy);
    font-size: 1.08rem;
    line-height: 1.1;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .service-card p,
  .card-copy,
  .guide-item p,
  .area-card p,
  .faq-item p {
    color: var(--brand-muted);
    margin: 0;
  }

  .service-card span,
  .guide-item span,
  .area-card span {
    color: var(--brand-navy);
    font-weight: 700;
  }

  .area-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .faq-item {
    background: white;
    border: none;
    border-radius: 22px;
    padding: 1.35rem 1.5rem;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .accordion-content {
    display: grid;
    gap: 0.85rem;
    padding-top: 1rem;
  }

  @media (max-width: 900px) {
    .seo-columns,
    .planning-layout,
    .guide-list,
    .area-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .page-header {
      background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
      padding: 3.6rem 0 3rem;
    }

    .page-header h1 {
      font-size: 2.2rem;
    }

    .service-faq-section {
      display: none;
    }
  }
</style>
