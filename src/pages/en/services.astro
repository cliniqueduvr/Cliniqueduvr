---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';
import servicePagesData from '../../data/service-pages-en.json';
import type { ServicePage } from '../../data/service-page-types';
import { buildBreadcrumbSchema } from '../../lib/seo';
const servicePagesEn = servicePagesData.items as ServicePage[];
const visibleServicePagesEn = servicePagesEn.filter((service) => service.slug !== 'buying-selling');
const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Home', path: '/en/' },
  { name: 'Services' }
]);
---

<Layout title="RV Services in Gatineau-Ottawa | Maintenance, Repair and RV and Auto Detailing" description="RV services in Gatineau-Ottawa: inspection, maintenance, repair, RV and auto detailing, and buying selling support." lang="en-CA" canonicalPath="/en/services/" frPath="/services/" enPath="/en/services/" schemas={[breadcrumbs]}>
  <Header lang="en" />

  <main>
    <section class="page-header">
      <div class="container">
        <p class="eyebrow">For every RV situation</p>
        <h1>Our Services</h1>
        <p>Inspection, maintenance, repair, and RV and auto detailing based on the real condition of the vehicle.</p>
      </div>
    </section>

    <section class="services-grid-section">
      <div class="container services-grid">
        {visibleServicePagesEn.map((service) => (
          <a class="service-card" href={`/en/services/${service.slug}/`}>
            <p class="card-eyebrow">{service.eyebrow}</p>
            <h2 class="card-title">{service.navLabel}</h2>
            <p class="card-copy">{service.lead}</p>
            <span>Learn more</span>
          </a>
        ))}
      </div>
    </section>

    <section class="seo-copy">
      <div class="container seo-columns">
        <div>
          <h2>The right service for the condition of your RV</h2>
          <p>Whether you are getting ready for the season, reviewing a vehicle before purchase or dealing with an active repair issue, we can point you toward the right service based on the actual condition of the RV and the urgency of the situation.</p>
        </div>
        <div>
          <h2>What the workshop covers</h2>
          <p>Common requests include water leaks, roof issues, seals, propane and electrical systems, interior restoration, RV and auto detailing, pre-sale presentation and pre-purchase inspections. If you are unsure which service fits best, contact us and we will guide you.</p>
        </div>
      </div>
    </section>

    <CTABanner
      lang="en"
      heading="Need help with a specific RV issue?"
      subheading="Choose the service that matches your situation or contact us and we will point you in the right direction."
      squareLabel="Book now"
    />
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .page-header {
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 25%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 62%, #204f32 100%);
    color: white;
    padding: 4.5rem 0;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: var(--brand-gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-header h1 {
    color: white;
    margin-bottom: 0.75rem;
    font-size: 3rem;
  }

  .page-header p:last-child {
    margin: 0 auto;
    max-width: 55ch;
    font-size: 1.08rem;
    color: #edf5d8;
  }

  .services-grid-section {
    padding: 4rem 0;
    background: linear-gradient(180deg, white 0%, #f3f5f8 100%);
  }

  .seo-copy {
    padding: 0 0 4rem;
    background: #f3f5f8;
  }

  .seo-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .seo-columns p {
    margin-top: 0.75rem;
    color: var(--brand-muted);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    display: grid;
    grid-template-rows: auto minmax(3.6rem, auto) 1fr auto;
    gap: 0.9rem;
    padding: 1.6rem;
    border-radius: 22px;
    background: white;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .service-card:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: 0 24px 44px rgba(21, 38, 58, 0.14);
  }

  .card-eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-green-dark);
    font-weight: 700;
  }

  .service-card h2,
  .card-title {
    font-size: 1.55rem;
    line-height: 1.1;
    color: var(--brand-navy);
    margin: 0;
  }

  .service-card p,
  .card-copy {
    color: var(--brand-muted);
    margin: 0;
  }

  .service-card span {
    color: var(--brand-navy);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 3.4rem 0;
    }

    .page-header h1 {
      font-size: 2.2rem;
    }
  }
</style>
