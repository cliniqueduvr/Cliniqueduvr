---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';
import servicePagesData from '../../data/service-pages-en.json';
import type { ServicePage } from '../../data/service-page-types';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';
const servicePagesEn = servicePagesData.items as ServicePage[];
const visibleServicePagesEn = servicePagesEn.filter((service) => service.slug !== 'buying-selling');
const serviceAreas = [
  { name: 'Outaouais', href: '/en/areas/rv-inspection-outaouais/' },
  { name: 'Ottawa', href: '/en/areas/rv-repair-ottawa/' },
  { name: 'Laurentides', href: '/en/areas/trailer-water-intrusion-laurentides/' }
];
const serviceFaqs = [
  {
    question: 'How do I choose the right service for my RV?',
    answer: 'The right service depends on the actual condition of the vehicle. If you notice water intrusion, worn seals, interior damage, or if you are preparing for a purchase or sale, we can guide you toward inspection, maintenance, repair, detailing, or buying and selling support.'
  },
  {
    question: 'Do you only work in Gatineau?',
    answer: 'No. The workshop is in Gatineau, but we also help clients in Ottawa, Outaouais, Laurentides, and other parts of Quebec and Ontario depending on the type of request.'
  },
  {
    question: 'Do you offer both shop and mobile services?',
    answer: 'Yes, depending on the service. Some work is best handled in the shop, while other situations may also allow mobile service or travel support depending on the request.'
  }
];
const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Home', path: '/en/' },
  { name: 'Services' }
]);
---

<Layout title="RV Services in Gatineau-Ottawa | Maintenance, Repair, and RV and Auto Detailing" description="RV services in Gatineau-Ottawa: inspection, maintenance, repair, RV and auto detailing, and buying and selling support." lang="en-CA" canonicalPath="/en/services/" frPath="/services/" enPath="/en/services/" schemas={[breadcrumbs, buildFAQSchema(serviceFaqs)]}>
  <Header lang="en" />

  <main>
    <section class="page-header">
      <div class="container">
        <p class="eyebrow">For every RV situation</p>
        <h1>Our Services</h1>
        <p>Inspection, maintenance, repair, and RV and auto detailing based on the vehicle's real condition.</p>
      </div>
    </section>

    <section class="services-grid-section">
      <div class="container services-grid">
        {visibleServicePagesEn.map((service) => (
          <a class="service-card" href={`/en/services/${service.slug}/`}>
            <p class="card-eyebrow">{service.eyebrow}</p>
            <h2 class="card-title">{service.navLabel}</h2>
            <p class="card-copy">{service.lead}</p>
            <span>Learn more</span>
          </a>
        ))}
      </div>
    </section>

    <section class="seo-copy">
      <div class="container seo-columns">
        <div>
          <h2>The right service for the condition of your RV</h2>
          <p>Whether you are getting ready for the season, reviewing a vehicle before purchase or dealing with an active repair issue, we can point you toward the right service based on the actual condition of the RV and the urgency of the situation.</p>
        </div>
        <div>
          <h2>What the workshop covers</h2>
          <p>Common requests include water leaks, roof issues, seals, propane and electrical systems, interior restoration, RV and auto detailing, pre-sale presentation and pre-purchase inspections. If you are unsure which service fits best, contact us and we will guide you.</p>
        </div>
      </div>
    </section>

    <section class="service-areas-section">
      <div class="container">
        <h2>Areas served</h2>
        <p class="section-intro">We receive service requests from Outaouais, Ottawa, and Laurentides depending on the type of work and the condition of the vehicle.</p>
        <div class="info-card-grid">
          {serviceAreas.map((area) => (
            <details class="info-card accordion-card">
              <summary>
                <h3>{area.name}</h3>
              </summary>
              <div class="accordion-content">
                <p>Common requests include inspection, maintenance, repair, detailing, and support before a transaction.</p>
                <a href={area.href}>View local page</a>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="service-links-section">
      <div class="container info-card-grid">
        <details class="info-card accordion-card">
          <summary>
            <h2>Contact us</h2>
          </summary>
          <div class="accordion-content">
            <p>Describe the issue, the vehicle, and your priority so we can direct you to the right service.</p>
            <a href="/en/contact/">Contact the workshop</a>
          </div>
        </details>
        <details class="info-card accordion-card">
          <summary>
            <h2>Real examples</h2>
          </summary>
          <div class="accordion-content">
            <p>Review before-and-after workshop cases to better understand what kind of help you need.</p>
            <a href="/en/realisations/">View projects</a>
          </div>
        </details>
        <details class="info-card accordion-card">
          <summary>
            <h2>Before buying or selling</h2>
          </summary>
          <div class="accordion-content">
            <p>If your situation involves a transaction, start with inspection to clarify the real condition of the vehicle.</p>
            <a href="/en/services/inspection/">View inspection service</a>
          </div>
        </details>
        <details class="info-card accordion-card">
          <summary>
            <h2>Choose a service</h2>
          </summary>
          <div class="accordion-content">
            <p>If you are not sure where to start, use our guidance page by symptom and situation.</p>
            <a href="/en/choose-service/">View guidance page</a>
          </div>
        </details>
      </div>
    </section>

    <section class="service-faq-section">
      <div class="container">
        <h2>Frequently asked questions</h2>
        <div class="faq-list">
          {serviceFaqs.map((item) => (
            <details class="faq-item accordion-card">
              <summary>
                <h3>{item.question}</h3>
              </summary>
              <div class="accordion-content">
                <p>{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CTABanner
      lang="en"
      heading="Need help with a specific RV issue?"
      subheading="Choose the service that matches your situation or contact us and we will point you in the right direction."
      squareLabel="Book now"
    />
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .page-header {
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 25%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 58%, #eef3f7 58%, #eef3f7 100%);
    color: white;
    padding: 4.5rem 0 3.8rem;
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: var(--brand-gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-header h1 {
    color: white;
    margin-bottom: 0.75rem;
    font-size: 3rem;
  }

  .page-header p:last-child {
    margin: 0;
    max-width: 55ch;
    font-size: 1.08rem;
    color: #e7edf4;
  }

  .services-grid-section {
    padding: 4rem 0;
    background: linear-gradient(180deg, white 0%, #f3f5f8 100%);
  }

  .seo-copy {
    padding: 0 0 4rem;
    background: #f3f5f8;
  }

  .service-areas-section,
  .service-links-section,
  .service-faq-section {
    padding: 0 0 4rem;
    background: #f3f5f8;
  }

  .section-intro {
    max-width: 62ch;
    color: var(--brand-muted);
    margin: 0.75rem 0 1.5rem;
  }

  .seo-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .seo-columns p {
    margin-top: 0.75rem;
    color: var(--brand-muted);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .info-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    display: grid;
    grid-template-rows: auto minmax(3.6rem, auto) 1fr auto;
    gap: 0.9rem;
    padding: 1.6rem;
    border-radius: 22px;
    background: white;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .info-card {
    background: white;
    border-radius: 22px;
    padding: 1.6rem;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .accordion-card summary {
    list-style: none;
    cursor: pointer;
  }

  .accordion-card summary::-webkit-details-marker {
    display: none;
  }

  .info-card h2,
  .info-card h3 {
    margin: 0;
    color: var(--brand-navy);
  }

  .accordion-card h2,
  .accordion-card h3 {
    font-size: 1.3rem;
    line-height: 1.1;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .info-card p {
    margin: 0;
    color: var(--brand-muted);
  }

  .accordion-content {
    display: grid;
    gap: 0.85rem;
    padding-top: 1rem;
  }

  .accordion-content a {
    color: var(--brand-navy);
    font-weight: 700;
    text-decoration: none;
  }

  .accordion-content a:hover {
    text-decoration: underline;
  }

  .accordion-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 44px rgba(21, 38, 58, 0.14);
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .faq-item {
    background: white;
    border-radius: 22px;
    padding: 1.6rem;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
  }

  .faq-item h3 {
    margin: 0;
    color: var(--brand-navy);
  }

  .faq-item p {
    margin: 0;
    color: var(--brand-muted);
  }

  .service-card:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: 0 24px 44px rgba(21, 38, 58, 0.14);
  }

  .card-eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-green-dark);
    font-weight: 700;
  }

  .service-card h2,
  .card-title {
    font-size: 1.55rem;
    line-height: 1.1;
    color: var(--brand-navy);
    margin: 0;
  }

  .service-card p,
  .card-copy {
    color: var(--brand-muted);
    margin: 0;
  }

  .service-card span {
    color: var(--brand-navy);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .page-header {
      background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
      padding: 3.6rem 0 3rem;
    }

    .page-header h1 {
      font-size: 2.2rem;
    }

    .accordion-card h2,
    .accordion-card h3 {
      font-size: 1.05rem;
    }

    .service-faq-section {
      display: none;
    }
  }
</style>
