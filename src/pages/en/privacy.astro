---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { buildBreadcrumbSchema } from '../../lib/seo';
import siteSettings from '../../data/site-settings.json';
import privacyPage from '../../data/privacy-page-en.json';
const breadcrumbs = buildBreadcrumbSchema([
  { name: privacyPage.breadcrumbs.home, path: '/en/' },
  { name: privacyPage.breadcrumbs.current }
]);
---

<Layout title={privacyPage.metaTitle} description={privacyPage.metaDescription} lang="en-CA" canonicalPath="/en/privacy/" frPath="/privacy/" enPath="/en/privacy/" schemas={[breadcrumbs]}>
  <Header lang="en" />

  <main>
    <section class="interior-hero">
      <div class="container interior-hero-grid">
        <div class="interior-hero-copy">
          <p class="interior-eyebrow">Privacy and protection</p>
          <h1>{privacyPage.hero.title}</h1>
          <p class="interior-lead">{privacyPage.hero.body}</p>
        </div>

        <aside class="interior-hero-card">
          <div class="interior-hero-icon">
            <i class="fas fa-shield-halved"></i>
          </div>
          <h2>Need a clear starting point?</h2>
          <p>We can help you understand the situation, choose the right service, and decide on the next useful step for your RV.</p>
          <a class="interior-hero-link" href="/en/contact/">Talk to us about your RV</a>
        </aside>
      </div>
    </section>

    <section class="interior-section">
      <div class="container">
        <div class="policy-grid">
          {privacyPage.sections.map((section) => (
          <article class="interior-card policy-card">
            <h2>{section.heading}</h2>
            {section.heading === 'Questions' ? (
              <p>
                For privacy questions or requests related to your information, email <a href={`mailto:${siteSettings.email}`}>{siteSettings.email}</a> or call <a href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>.
              </p>
            ) : (
              <p>{section.body}</p>
            )}
          </article>
        ))}
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .policy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .policy-card h2 {
    margin-bottom: 0.75rem;
    font-size: 1.45rem;
  }

  @media (max-width: 768px) {
    .interior-hero-copy h1 {
      font-size: 2rem;
    }
  }
</style>
