---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import projectsData from '../../data/projects-en.json';
import siteSettings from '../../data/site-settings.json';
import { buildBreadcrumbSchema } from '../../lib/seo';

const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Home', path: '/en/' },
  { name: 'Projects' }
]);
---

<Layout title="RV projects | Before and after in Gatineau" description="Projects and interventions on RVs in Gatineau, Ottawa, Outaouais, and the Laurentides. Before and after, repair, and refresh work." lang="en-CA" canonicalPath="/en/realisations/" frPath="/realisations/" enPath="/en/realisations/" schemas={[breadcrumbs]}>
  <Header lang="en" />

  <main>
    <section class="interior-hero">
      <div class="container interior-hero-grid">
        <div class="interior-hero-copy">
          <p class="interior-eyebrow">Complete interventions</p>
          <h1>Real RV project examples in Gatineau, Ottawa, and nearby areas</h1>
          <p class="interior-lead">Before and after work, water-intrusion files, interior restoration, seals, and roof-related interventions: this page shows the kind of issues we actually handle.</p>
        </div>

        <aside class="interior-hero-card">
          <div class="interior-hero-icon">
            <i class="fas fa-images"></i>
          </div>
          <h2>What you will find here</h2>
          <ul class="hero-checklist">
            <li>Water-intrusion and watertightness-related work</li>
            <li>Visible before-and-after examples from the workshop</li>
            <li>Direct paths toward inspection, maintenance, and repair</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="interior-section">
      <div class="container interior-body-grid">
        <article class="interior-content-main">
          <section class="interior-card interior-card-alt">
            <h2>What these projects prove</h2>
            <div class="proof-grid">
              <article class="proof-card">
                <h3>Water issues are often bigger than they look</h3>
                <p>Many of the most costly files begin with seals, roofs, or a small visible sign that hides deeper moisture.</p>
              </article>
              <article class="proof-card">
                <h3>Inspection, maintenance, and repair each have a role</h3>
                <p>The real value is knowing when the next useful step is still preventive work and when the file already needs real repair.</p>
              </article>
              <article class="proof-card">
                <h3>Visible proof matters before booking</h3>
                <p>Seeing real workshop examples helps set expectations around scope, presentation, and the level of work involved.</p>
              </article>
            </div>
          </section>

          <section class="interior-card">
            <div class="section-intro">
              <h2>Before and after and real interventions</h2>
              <p>These projects show examples of work carried out on RVs, travel trailers, and caravans: water intrusion, restoration, visual correction, and improvement of the overall condition. This section strengthens proof of work while also supporting searches related to RV repairs in Gatineau, Ottawa, Outaouais, and the Laurentides.</p>
            </div>
            <div class="projects-grid">
              {projectsData.items.map((project) => (
                <ProjectCard
                  id={project.id}
                  title={project.title}
                  location={project.location}
                  category={project.category}
                  beforeImage={project.beforeImage}
                  afterImage={project.afterImage}
                  beforeAlt={project.beforeAlt}
                  afterAlt={project.afterAlt}
                  description={project.description}
                  lang="en"
                />
              ))}
            </div>
          </section>

          <section class="interior-card interior-card-alt">
            <div class="seo-columns">
              <div>
                <h2>Why these projects matter</h2>
                <p>A before-and-after helps explain the type of problem treated, the nature of the damage observed, and the level of restoration possible depending on the vehicle. It also makes the difference between maintenance, repair, and deeper restoration easier to understand.</p>
              </div>
              <div>
                <h2>Frequent work in the workshop</h2>
                <p>Among the most common requests are water leaks, worn seals, roof issues, interior damage, presentation before sale, and restoration after intrusion. If your situation resembles one of these cases, we can point you toward the right service faster.</p>
              </div>
            </div>
          </section>
        </article>

        <aside class="interior-side-panel">
          <div class="interior-side-card interior-side-card-primary">
            <h3>Need a quick opinion?</h3>
            <p>We can point you toward inspection, maintenance, or repair depending on the actual condition of the vehicle and whether water is already involved.</p>
            <a class="interior-side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
            <a class="interior-side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">Book online</a>
          </div>

          <div class="interior-side-card">
            <h3>Useful pages</h3>
            <nav class="interior-service-nav" aria-label="Useful pages">
              <a href="/en/services/inspection/"><i class="fas fa-clipboard-check"></i><span>Inspection</span></a>
              <a href="/en/services/repair/"><i class="fas fa-toolbox"></i><span>Repair</span></a>
              <a href="/en/resources/rv-water-intrusion/"><i class="fas fa-droplet"></i><span>Water intrusion</span></a>
              <a href="/en/contact/"><i class="fas fa-envelope"></i><span>Contact</span></a>
            </nav>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .interior-hero-copy h1 { max-width: 15ch; }
  .hero-checklist { display: grid; gap: 0.65rem; padding-left: 1.2rem; color: var(--brand-muted); }
  .hero-checklist li::marker { color: var(--brand-green); font-weight: 700; }
  .section-intro { margin-bottom: 2rem; }
  .section-intro p { margin-top: 0.75rem; color: var(--brand-muted); }
  .proof-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
  .proof-card { background: var(--brand-surface); border-radius: 16px; padding: 1rem; }
  .proof-card h3 { font-size: 1rem; margin-bottom: 0.45rem; }
  .proof-card p { color: var(--brand-muted); }
  .projects-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2rem; }
  .seo-columns { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
  .seo-columns p { margin-top: 0.75rem; color: var(--brand-muted); }
  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
