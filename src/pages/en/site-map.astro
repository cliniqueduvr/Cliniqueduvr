---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { buildBreadcrumbSchema } from '../../lib/seo';

const sections = [
  {
    title: 'Main pages',
    links: [
      { href: '/en/', label: 'Home' },
      { href: '/en/services/', label: 'Services' },
      { href: '/en/choose-service/', label: 'Which service should you choose?' },
      { href: '/en/sales/', label: 'Sales' },
      { href: '/en/realisations/', label: 'Projects' },
      { href: '/en/about/', label: 'About' },
      { href: '/en/contact/', label: 'Contact' },
      { href: '/en/privacy/', label: 'Privacy Policy' }
    ]
  },
  {
    title: 'Services',
    links: [
      { href: '/en/services/inspection/', label: 'Inspection' },
      { href: '/en/services/maintenance/', label: 'Maintenance' },
      { href: '/en/services/repair/', label: 'Repair' },
      { href: '/en/services/detailing/', label: 'RV detailing' },
      { href: '/en/services/auto-truck-detailing/', label: 'Auto and truck detailing' }
    ]
  },
  {
    title: 'Local pages',
    links: [
      { href: '/en/areas/rv-water-leak-gatineau/', label: 'RV Water Leak in Gatineau' },
      { href: '/en/areas/rv-maintenance-gatineau/', label: 'RV Maintenance in Gatineau' },
      { href: '/en/areas/rv-inspection-outaouais/', label: 'RV Inspection in Outaouais' },
      { href: '/en/areas/rv-repair-ottawa/', label: 'RV Repair in Ottawa' },
      { href: '/en/areas/trailer-water-intrusion-laurentides/', label: 'Trailer Water Intrusion in Laurentides' }
    ]
  }
];

const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Home', path: '/en/' },
  { name: 'Site map' }
]);
---

<Layout
  title="Site map | Clinique du VR"
  description="Site map for Clinique du VR with the main pages, services, and local pages."
  lang="en-CA"
  canonicalPath="/en/site-map/"
  frPath="/plan-du-site/"
  enPath="/en/site-map/"
  schemas={[breadcrumbs]}
>
  <Header lang="en" />

  <main>
    <section class="interior-hero">
      <div class="container interior-hero-grid">
        <div class="interior-hero-copy">
          <p class="interior-eyebrow">Navigation</p>
          <h1>Site map</h1>
          <p class="interior-lead">Find the site’s main pages, the available services, and the local pages related to the areas we serve.</p>
        </div>

        <aside class="interior-hero-card">
          <div class="interior-hero-icon">
            <i class="fas fa-sitemap"></i>
          </div>
          <h2>Need a clear starting point?</h2>
          <p>We can help you understand the situation, choose the right service, and decide on the next useful step for your RV.</p>
          <a class="interior-hero-link" href="/en/contact/">Talk to us about your RV</a>
        </aside>
      </div>
    </section>

    <section class="interior-section">
      <div class="container sitemap-grid">
        {sections.map((section) => (
          <article class="interior-card sitemap-card">
            <h2>{section.title}</h2>
            <ul>
              {section.links.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .interior-hero-copy h1 { max-width: 14ch; }

  .sitemap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .sitemap-card h2 {
    margin-bottom: 1rem;
  }

  .sitemap-card ul {
    display: grid;
    gap: 0.75rem;
    padding-left: 1.2rem;
  }

  .sitemap-card a {
    color: var(--brand-navy);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .interior-hero-copy h1 {
      font-size: 2.2rem;
    }
  }
</style>
