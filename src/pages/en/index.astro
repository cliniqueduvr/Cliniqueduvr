---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { buildLocalBusinessSchema } from '../../lib/seo';

const rawFormspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || '';
const isFormConfigured = Boolean(rawFormspreeId && rawFormspreeId.startsWith('f/'));
const formAction = isFormConfigured ? `https://formspree.io/f/${rawFormspreeId}` : undefined;
const squareBookingUrl = 'https://app.squareup.com/appointments/book/lgocu4o42jy5zu/LGZ9VNRVZ6XXM/start';
const schemas = [buildLocalBusinessSchema()];

const meta = {
  title: 'Clinique du VR | RV inspection, maintenance and repair in Gatineau-Ottawa',
  description: 'Clinique du VR offers RV inspection, maintenance, repair, detailing and buying selling support in Gatineau-Ottawa.'
};
---

<Layout title={meta.title} description={meta.description} lang="en-CA" canonicalPath="/en/" frPath="/" enPath="/en/" schemas={schemas}>
  <Header lang="en" />

  <main>
    <section class="hero">
      <div class="hero-content">
        <img class="hero-logo" src="/clinique-du-vr-brand.jpg" alt="Clinique du VR logo — RV maintenance, repair and detailing" />
        <h1>Clinique du VR — RV inspection, maintenance and repair in Gatineau-Ottawa</h1>
        <p class="hero-tagline">Your water infiltration specialist in Outaouais</p>
      </div>
    </section>

    <section id="about" class="intro-section">
      <div class="container intro-grid">
        <div class="intro-card">
          <div class="card-icon">
            <i class="fas fa-building"></i>
          </div>
          <h2>Why Choose Clinique du VR?</h2>
          <p><strong>Specialized and attentive service</strong> for RV maintenance, repair and detailing. Speed, transparency, regulatory compliance and careful execution from start to finish.</p>
        </div>

        <div class="intro-card">
          <div class="card-icon">
            <i class="fas fa-wrench"></i>
          </div>
          <h2>Our Services</h2>
          <p><strong>Preventive maintenance</strong> • <strong>Mechanical and cosmetic repairs</strong> • <strong>RV inspections</strong> • <strong>Refresh work</strong> • <strong>Cleaning and detailing</strong> • <strong>Custom interventions</strong></p>
        </div>
      </div>
    </section>

    <section class="services-overview">
      <div class="container">
        <h2>Our Specialties</h2>
        <div class="services-grid">
          <a href="/en/services/inspection/" class="service-item"><i class="fas fa-clipboard-check"></i><span>Inspection</span></a>
          <a href="/en/services/maintenance/" class="service-item"><i class="fas fa-screwdriver-wrench"></i><span>Maintenance</span></a>
          <a href="/en/services/repair/" class="service-item"><i class="fas fa-toolbox"></i><span>Repair</span></a>
          <a href="/en/services/detailing/" class="service-item"><i class="fas fa-spray-can-sparkles"></i><span>Detailing</span></a>
          <a href="/en/services/buying-selling/" class="service-item"><i class="fas fa-van-shuttle"></i><span>Buying and Selling</span></a>
        </div>
      </div>
    </section>

    <section class="seo-copy">
      <div class="container seo-grid">
        <div>
          <h2>RV service in Gatineau-Ottawa</h2>
          <p>Clinique du VR supports RV, trailer and caravan owners with common service needs such as pre-purchase inspection, preventive maintenance, water leak repair, roof work, refresh work and detailing. The workshop is based in Gatineau and also serves Ottawa, Outaouais, Laurentides, Quebec and Ontario clients.</p>
        </div>
        <div>
          <h2>A clearer service structure</h2>
          <p>When an RV shows signs of wear, water intrusion or visible deterioration, the first step is to understand the real condition of the vehicle. From there, we help guide you toward inspection, maintenance, repair, detailing or buying and selling support based on what is actually needed.</p>
        </div>
      </div>
    </section>

    <section class="cta-banner">
      <div class="container cta-content">
        <h2>Request your free estimate</h2>
        <p>Inspection and estimate with no obligation</p>
        <div class="cta-actions">
          <a href="tel:+15813373366" class="cta-button"><i class="fas fa-phone"></i> (581) 337-3366</a>
          <a href={squareBookingUrl} target="_blank" rel="noopener" class="square-button"><i class="fas fa-calendar-check"></i> Book now</a>
        </div>
      </div>
    </section>

    <section class="contact-section">
      <div class="container contact-grid">
        <div class="contact-form-wrapper">
          <h2>Contact Us</h2>
          <!-- TODO: Replace with actual Formspree form ID -->
          {!isFormConfigured && (
            <p class="form-note">The contact form is not configured in production yet. Please use the phone number or Square booking link for now.</p>
          )}
          <form action={formAction} method="POST">
            <input type="text" name="name" placeholder="Your name" required />
            <input type="email" name="email" placeholder="Your email" required />
            <input type="text" name="subject" placeholder="Subject" required />
            <textarea name="message" placeholder="Your message" rows="5" required></textarea>
            <button type="submit" disabled={!isFormConfigured}>Send</button>
          </form>
        </div>

        <div class="contact-info">
          <h3>Contact Information</h3>
          <p><strong>Phone:</strong> <a href="tel:+15813373366">(581) 337-3366</a></p>
          <p><strong>Square:</strong> <a href={squareBookingUrl} target="_blank" rel="noopener">Book now</a></p>
          <p><strong>Email:</strong> <a href="mailto:info@demosolution.ca">info@demosolution.ca</a></p>
          <p><strong>Address:</strong> 11 rue de Granby, Unit 18, Gatineau, QC</p>
          <p><strong>Service area:</strong> Gatineau, Ottawa, Laurentides, Outaouais, Quebec and Ontario</p>
          <p><strong>RBQ:</strong> 5824-9764-01 | <strong>Since:</strong> 2013</p>
          <p class="cta-text">Free and confidential estimate. Call us or send us a message.</p>
        </div>
      </div>
    </section>

    <section class="reviews-section">
      <div class="container">
        <h2>Google Reviews</h2>
        <div class="reviews-grid">
          <article class="review-card">
            <p class="review-text">"Cedric was on time, explained everything clearly and delivered the results the next day as promised."</p>
            <p class="review-author">Jesse Brook</p>
          </article>
          <article class="review-card">
            <p class="review-text">"Professional and courteous service."</p>
            <p class="review-author">Stephane Desgagne</p>
          </article>
          <article class="review-card">
            <p class="review-text">"Efficient company, easy to communicate with, and professional work from start to finish."</p>
            <p class="review-author">Philippe Albert</p>
          </article>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .hero { min-height: 640px; display: flex; align-items: center; justify-content: center; text-align: center; color: white; background: radial-gradient(circle at top left, rgba(242, 210, 27, 0.16), transparent 28%), linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 62%, #214f33 100%); padding: 5.5rem 1.5rem 4.5rem; }
  .hero-logo { width: min(760px, 88vw); height: auto; display: block; margin: 0 auto 2rem; filter: drop-shadow(0 18px 35px rgba(0, 0, 0, 0.25)); }
  .hero-content { width: min(980px, 100%); }
  .hero-content h1 { color: white; max-width: 16ch; margin: 0 auto; line-height: 1.12; }
  .hero-tagline { font-size: 1.2rem; letter-spacing: 2px; margin-top: 1rem; line-height: 1.5; }
  .intro-section { padding: 4rem 0; background: white; }
  .intro-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 3rem; }
  .intro-card { text-align: center; }
  .card-icon { font-size: 3rem; color: var(--brand-green); margin-bottom: 1rem; }
  .services-overview { padding: 4rem 0; background: var(--brand-surface); }
  .seo-copy { padding: 4rem 0; background: white; }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
  .seo-grid p { margin-top: 0.75rem; color: var(--brand-muted); }
  .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 2rem; margin-top: 2rem; }
  .service-item { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; padding: 2rem; background: white; border-radius: 8px; transition: all 0.3s; border: 2px solid transparent; }
  .service-item:hover { border-color: var(--brand-green); transform: translateY(-4px); box-shadow: 0 8px 16px rgba(0,0,0,0.1); }
  .service-item i { font-size: 2.5rem; color: var(--brand-navy); }
  .contact-section { padding: 4rem 0; background: var(--brand-navy); color: white; }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
  .contact-form-wrapper h2 { color: white; margin-bottom: 1.5rem; }
  .contact-form-wrapper form { display: flex; flex-direction: column; gap: 1rem; }
  .form-note { margin-bottom: 1rem; color: #d9e6d1; }
  .contact-form-wrapper input, .contact-form-wrapper textarea { padding: 12px; border: none; border-radius: 4px; font-family: inherit; }
  .contact-info h3 { color: var(--brand-gold); margin-bottom: 1rem; }
  .contact-info p { margin-bottom: 0.75rem; }
  .cta-text { margin-top: 1.5rem; font-style: italic; color: #d9e6d1; }
  .reviews-section { padding: 4rem 0; background: #f4f6f8; }
  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
  .review-card { background: white; border-radius: 18px; padding: 1.5rem; box-shadow: 0 14px 28px rgba(20, 36, 55, 0.08); }
  .review-text { color: var(--brand-ink); font-weight: 600; }
  .review-author { margin-top: 1rem; color: var(--brand-muted); }
  .cta-banner { background: var(--brand-green); padding: 3rem 1.5rem; text-align: center; color: white; }
  .cta-content { max-width: 720px; margin: 0 auto; }
  .cta-content h2 { font-size: 2rem; margin-bottom: 0.5rem; color: white; }
  .cta-content p { font-size: 1.1rem; margin-bottom: 1.5rem; color: #ffffff; }
  .cta-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.85rem; }
  .cta-button { display: inline-block; background: var(--brand-gold); color: var(--brand-navy-dark); padding: 12px 28px; border-radius: 50px; font-weight: 600; text-decoration: none; font-size: 1.1rem; transition: all 0.3s ease; border: 2px solid var(--brand-gold); }
  .cta-button:hover { background: #e1c317; color: var(--brand-navy-dark); }
  .square-button { display: inline-block; background: transparent; color: white; padding: 12px 28px; border-radius: 50px; font-weight: 700; text-decoration: none; font-size: 1.05rem; transition: all 0.3s ease; border: 2px solid rgba(255, 255, 255, 0.75); }
  .square-button:hover { text-decoration: none; background: rgba(255,255,255,0.12); border-color: white; }
  .cta-button i, .square-button i { margin-right: 8px; }
  @media (max-width: 768px) {
    .hero { min-height: 720px; padding: 6rem 1.25rem 5rem; align-items: flex-start; }
    .hero-logo { width: min(620px, 92vw); margin: 0 auto 2.25rem; }
    .hero-content h1 { font-size: 2.2rem; max-width: 12ch; }
    .hero-tagline { font-size: 1.05rem; margin-top: 1.15rem; }
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
