---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { buildBreadcrumbSchema } from '../../lib/seo';

const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Home', path: '/en/' },
  { name: 'About' }
]);
---

<Layout
  title="About Clinique du VR | RV Workshop in Gatineau-Ottawa"
  description="About Clinique du VR: RV workshop in Gatineau-Ottawa, operating since 2013 with RBQ credentials and regional service coverage."
  lang="en-CA"
  canonicalPath="/en/about/"
  frPath="/about/"
  enPath="/en/about/"
  schemas={[breadcrumbs]}
>
  <Header lang="en" />

  <main>
    <section class="about-hero">
      <div class="container hero-grid">
        <div>
          <h1>About Clinique du VR</h1>
          <p>Clinique du VR is a specialized workshop focused on RV inspection, maintenance, repair and detailing in Gatineau-Ottawa. The business supports RV, trailer and caravan owners with practical guidance and service work built around clarity, condition assessment and durable results.</p>
        </div>
        <figure class="brand-card">
          <img src="/clinique-du-vr-brand.jpg" alt="Clinique du VR — RV service in Gatineau-Ottawa" />
          <figcaption>Clinique du VR — workshop service for recreational vehicles in Gatineau-Ottawa</figcaption>
        </figure>
      </div>
    </section>

    <section class="about-body">
      <div class="container about-grid">
        <article class="about-card">
          <h2>Technical leadership and experience</h2>
          <p>Clinique du VR has supported RV owners since 2013 with a practical, attentive approach focused on durable work. The workshop emphasizes clear explanations, realistic condition assessment and recommendations that match how the vehicle is actually used.</p>
        </article>

        <article class="about-card">
          <h2>What the RBQ license means</h2>
          <p>RBQ number 5824-9764-01 signals that the company operates within a recognized Quebec regulatory framework. For a customer, that adds trust when handing over an RV for inspection, maintenance, repair or restorative work, especially where water intrusion, structure and higher-risk service areas are involved.</p>
        </article>

        <article class="about-card">
          <h2>Service area</h2>
          <p>Clinique du VR serves Gatineau and Ottawa first, while also helping customers across Outaouais, Laurentides and other areas of Quebec and Ontario when the project makes sense. That regional footprint matters for pre-purchase inspections, water leak repair, seasonal maintenance and pre-sale preparation.</p>
        </article>

        <article class="about-card">
          <h2>Workshop mission</h2>
          <p>The mission is straightforward: help RV owners understand the actual condition of the vehicle, prioritize the right work and avoid expensive surprises. That means direct communication, practical diagnosis and recommendations that match budget, use case and season.</p>
        </article>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .about-hero {
    padding: 4rem 0;
    background: linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 60%, #f4f6f8 60%, #f4f6f8 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.8fr);
    gap: 2rem;
    align-items: center;
  }

  .about-hero h1 {
    color: white;
  }

  .about-hero .hero-grid > div > p {
    color: white;
    max-width: 54ch;
  }

  .brand-card {
    margin: 0;
    background: white;
    border-radius: 20px;
    padding: 1.5rem;
    box-shadow: 0 16px 30px rgba(18, 35, 54, 0.18);
  }

  .brand-card img {
    width: 100%;
    height: auto;
    display: block;
  }

  .brand-card figcaption {
    margin-top: 1rem;
    color: var(--brand-muted);
    font-size: 0.95rem;
  }

  .about-body {
    padding: 4rem 0;
    background: #f4f6f8;
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .about-card {
    background: white;
    border-radius: 18px;
    padding: 1.5rem;
    box-shadow: 0 14px 28px rgba(20, 36, 55, 0.08);
  }

  .about-card p {
    margin-top: 0.75rem;
    color: var(--brand-muted);
  }

  @media (max-width: 900px) {
    .about-hero {
      background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
