---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import servicePagesData from '../../data/service-pages-en.json';
import { localAreaPagesEn } from '../../data/local-area-pages';
import { buildBreadcrumbSchema, buildCollectionPageSchema, buildFAQSchema, buildWebSiteSchema } from '../../lib/seo';
import type { ServicePage } from '../../data/service-page-types';
import siteSettings from '../../data/site-settings.json';

const servicePages = servicePagesData.items as ServicePage[];
const faqItems = [
  ...servicePages.flatMap((service) => service.faqs),
  ...localAreaPagesEn.flatMap((page) => page.faqs),
  {
    question: 'Do you only work in Gatineau?',
    answer: 'Our workshop is based in Gatineau, but we also support clients from Outaouais, Ottawa, and the Laurentides depending on the type of request.'
  },
  {
    question: 'When should I book an inspection instead of a repair?',
    answer: 'When the source of the issue is still unclear, inspection is often the right first step. When damage is already visible or confirmed, repair is usually the next move.'
  }
];

const schemas = [
  buildWebSiteSchema(),
  buildCollectionPageSchema({
    name: 'Clinique du VR FAQ',
    description: 'Frequently asked questions about inspection, maintenance, repair, and service areas for Clinique du VR.',
    path: '/en/faq/'
  }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Home', path: '/en/' },
    { name: 'FAQ' }
  ])
];
---

<Layout
  title="RV FAQ in Gatineau | Inspection, maintenance and repair | Clinique du VR"
  description="Clinique du VR FAQ about inspection, maintenance, water leak repair, service areas, and the right next step for your RV in Gatineau."
  lang="en-CA"
  canonicalPath="/en/faq/"
  frPath="/faq/"
  enPath="/en/faq/"
  schemas={schemas}
>
  <Header lang="en" />

  <main>
    <section class="interior-hero">
      <div class="container interior-hero-grid">
        <div class="interior-hero-copy">
          <p class="interior-eyebrow">Frequently asked questions</p>
          <h1>FAQ about RV services in Gatineau</h1>
          <p class="interior-lead">This page gathers the most common questions about water leaks, maintenance, repair, pre-purchase inspection, and service areas around Gatineau.</p>
        </div>

        <aside class="interior-hero-card">
          <div class="interior-hero-icon">
            <i class="fas fa-circle-question"></i>
          </div>
          <h2>Need a clear starting point?</h2>
          <p>We can help you understand the situation, choose the right service, and decide on the next useful step for your RV.</p>
          <a class="interior-hero-link" href="/en/contact/">Talk to us about your RV</a>
        </aside>
      </div>
    </section>

    <section class="interior-section">
      <div class="container interior-body-grid">
        <div class="interior-faq-list">
          {faqItems.map((item) => (
            <details class="interior-faq-item">
              <summary><h3>{item.question}</h3></summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>

        <aside class="interior-side-panel">
          <div class="interior-side-card interior-side-card-primary">
            <h3>Need a quick opinion?</h3>
            <p>We can point you toward inspection, maintenance, or repair based on the vehicle's current condition.</p>
            <a class="interior-side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
            <a class="interior-side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">Book online</a>
          </div>
          <div class="interior-side-card">
            <h3>Helpful pages</h3>
            <nav class="interior-service-nav" aria-label="Helpful pages">
              <a href="/en/choose-service/"><i class="fas fa-route"></i><span>Choose a service</span></a>
              <a href="/en/service-areas/"><i class="fas fa-map"></i><span>Service areas</span></a>
              <a href="/en/services/"><i class="fas fa-list"></i><span>All services</span></a>
              <a href="/en/contact/"><i class="fas fa-envelope"></i><span>Contact</span></a>
            </nav>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .interior-hero-copy h1 { max-width: 14ch; }
</style>
