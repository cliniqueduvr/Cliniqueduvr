---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildBreadcrumbSchema, buildFAQSchema } from '../lib/seo';

const symptomCards = [
  {
    title: 'Infiltration d’eau ou humidité',
    copy: "Si vous voyez des traces d'eau, des joints suspects ou de l'humidité, l'inspection est souvent la meilleure première étape pour confirmer l'état réel du VR.",
    href: '/services/inspection/',
    linkLabel: "Voir le service d'inspection"
  },
  {
    title: 'Joints fatigués ou toiture à reprendre',
    copy: "Quand les joints sèchent, craquent ou décollent, l'entretien sert à préserver l'étanchéité et à limiter les dommages plus coûteux.",
    href: '/services/entretien/',
    linkLabel: "Voir le service d'entretien"
  },
  {
    title: 'Dommages déjà visibles',
    copy: "Si l'eau a déjà causé des dommages au plancher, aux murs, à la toiture ou aux finis intérieurs, la réparation devient la bonne direction.",
    href: '/services/reparation/',
    linkLabel: 'Voir le service de réparation'
  },
  {
    title: 'Avant achat ou avant vente',
    copy: "Pour clarifier l'état réel d'un VR avant une transaction, commencez généralement par l'inspection afin d'identifier les points forts, les risques et les correctifs utiles.",
    href: '/services/inspection/',
    linkLabel: "Voir l'inspection avant transaction"
  },
  {
    title: 'Véhicule terni ou à remettre en valeur',
    copy: "Si le besoin est surtout visuel, l'esthétique permet d'améliorer la présentation, la propreté et la finition générale du véhicule.",
    href: '/services/esthetique/',
    linkLabel: "Voir le service d'esthétique"
  },
  {
    title: 'Vous hésitez entre deux services',
    copy: "Quand la situation n'est pas claire, contactez-nous avec des photos et une courte description du problème. Nous pourrons vous orienter vers la bonne première étape.",
    href: '/contact/',
    linkLabel: "Contacter l'atelier"
  }
];

const serviceAreas = [
  { name: 'Gatineau | Fuite d’eau', href: '/zones/fuite-eau-vr-gatineau/' },
  { name: 'Gatineau | Entretien', href: '/zones/entretien-vr-gatineau/' },
  { name: 'Outaouais', href: '/zones/inspection-vr-outaouais/' },
  { name: 'Ottawa', href: '/zones/reparation-vr-ottawa/' },
  { name: 'Laurentides', href: '/zones/infiltration-eau-roulotte-laurentides/' }
];
const faqs = [
  {
    question: 'Quelle est la meilleure première étape si je ne suis pas certain du problème?',
    answer: "Quand le problème n'est pas clair, l'inspection est souvent le meilleur point de départ. Elle permet de confirmer l'état réel du véhicule et d'éviter de partir dans la mauvaise direction."
  },
  {
    question: 'Quand choisir l’entretien au lieu de la réparation?',
    answer: "L'entretien convient surtout quand on veut prévenir une infiltration, reprendre des joints ou entretenir la toiture avant que des dommages importants apparaissent. Quand le dommage est déjà visible, la réparation est souvent plus appropriée."
  },
  {
    question: 'L’esthétique peut-elle être utile avant une vente?',
    answer: "Oui. L'esthétique peut améliorer la présentation du véhicule, mais si l'objectif est de clarifier son état réel avant une transaction, l'inspection reste généralement la première étape la plus utile."
  }
];

const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Accueil', path: '/' },
  { name: 'Quel service choisir ?' }
]);
---

<Layout
  title="Quel service choisir pour votre VR à Gatineau | Clinique du VR"
  description="Choisissez le bon service pour votre VR à Gatineau selon les symptômes observés: fuite d'eau, entretien de joints et de toiture, réparation, esthétique ou inspection avant achat."
  canonicalPath="/choisir-service/"
  frPath="/choisir-service/"
  enPath="/en/choose-service/"
  schemas={[breadcrumbs, buildFAQSchema(faqs)]}
>
  <Header />

  <main>
    <section class="page-header">
      <div class="container">
        <p class="eyebrow">Orientation pratique</p>
        <h1>Quel service choisir pour votre VR?</h1>
        <p>Utilisez cette page pour repérer le bon point de départ selon les symptômes visibles, l'état réel du véhicule et votre situation.</p>
      </div>
    </section>

    <section class="chooser-section">
      <div class="container">
        <div class="section-intro">
          <h2>Commencer par le bon service</h2>
          <p>Quand un VR présente plusieurs signes en même temps, il n'est pas toujours évident de savoir s'il faut commencer par une inspection, un entretien, une réparation ou un service esthétique. Les cartes ci-dessous vous aident à choisir la prochaine étape la plus utile.</p>
        </div>

        <div class="card-grid">
          {symptomCards.map((item) => (
            <a class="choice-card" href={item.href}>
              <h2>{item.title}</h2>
              <p>{item.copy}</p>
              <span>{item.linkLabel}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="areas-section">
      <div class="container">
        <h2>Zones desservies</h2>
        <p class="section-copy">Nous recevons des demandes provenant de l'Outaouais, d'Ottawa et des Laurentides selon le type de besoin et la situation du véhicule.</p>
        <div class="card-grid areas-grid">
          {serviceAreas.map((area) => (
            <a class="info-card choice-card" href={area.href}>
              <h3>{area.name}</h3>
              <p>Demandes fréquentes en inspection, entretien, réparation, esthétique et préparation avant transaction.</p>
              <span>Voir la page locale</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="faq-section">
      <div class="container">
        <h2>Questions fréquentes</h2>
        <div class="faq-list">
          {faqs.map((item) => (
            <article class="faq-card">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .page-header {
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 25%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 58%, #eef3f7 58%, #eef3f7 100%);
    color: white;
    padding: 4.5rem 0 3.8rem;
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: var(--brand-gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-header h1 {
    color: white;
    margin-bottom: 0.75rem;
    font-size: 3rem;
    max-width: 14ch;
  }

  .page-header p:last-child {
    margin: 0;
    max-width: 55ch;
    font-size: 1.08rem;
    color: #e7edf4;
  }

  .chooser-section,
  .areas-section,
  .faq-section {
    padding: 4rem 0;
    background: #f3f5f8;
  }

  .areas-section,
  .faq-section {
    padding-top: 0;
  }

  .section-intro {
    max-width: 64ch;
    margin-bottom: 1.5rem;
  }

  .section-intro p,
  .section-copy,
  .info-card p,
  .faq-card p,
  .choice-card p {
    color: var(--brand-muted);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .choice-card,
  .info-card,
  .faq-card {
    background: white;
    border-radius: 22px;
    padding: 1.6rem;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
  }

  .choice-card {
    display: grid;
    gap: 0.9rem;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .choice-card:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: 0 24px 44px rgba(21, 38, 58, 0.14);
  }

  .choice-card h2,
  .info-card h3,
  .faq-card h3 {
    margin: 0;
    color: var(--brand-navy);
  }

  .choice-card span {
    color: var(--brand-navy);
    font-weight: 700;
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .page-header {
      background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
      padding: 3.6rem 0 3rem;
    }

    .page-header h1 {
      font-size: 2.2rem;
      max-width: none;
    }

    .chooser-section,
    .areas-section,
    .faq-section {
      padding: 3rem 0;
      background: #f3f5f8;
    }

    .areas-section,
    .faq-section {
      padding-top: 0;
    }
  }
</style>
