---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildLocalBusinessSchema } from '../lib/seo';
import siteSettings from '../data/site-settings.json';
import homePage from '../data/home-page.json';

const rawFormspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || '';
const isFormConfigured = Boolean(rawFormspreeId && rawFormspreeId.startsWith('f/'));
const formAction = isFormConfigured ? `https://formspree.io/f/${rawFormspreeId}` : undefined;
const schemas = [buildLocalBusinessSchema({
  telephone: siteSettings.phone.href,
  email: siteSettings.email,
  facebookUrl: siteSettings.facebookUrl
})];

const meta = {
  title: homePage.metaTitle,
  description: homePage.metaDescription
};
---

<Layout title={meta.title} description={meta.description} canonicalPath="/" frPath="/" enPath="/en/" schemas={schemas}>
  <Header />

  <main>
    <section class="hero">
      <div class="hero-content">
        <img class="hero-logo" src={siteSettings.brandImage} alt={homePage.hero.logoAlt} />
        <h1>{homePage.hero.title}</h1>
        <p class="hero-tagline">{homePage.hero.tagline}</p>
      </div>
    </section>

    <!-- ABOUT & SERVICES INTRO -->
    <section class="intro-section">
      <div class="container intro-grid">
        <div class="intro-card">
          <div class="card-icon">
            <i class={homePage.introCard.icon}></i>
          </div>
          <h2>{homePage.introCard.heading}</h2>
          <p set:html={homePage.introCard.body} />
        </div>
      </div>
    </section>

    <!-- SERVICES OVERVIEW -->
    <section class="services-overview">
      <div class="container">
        <h2>{homePage.servicesOverview.title}</h2>
        <div class="services-grid">
          {homePage.servicesOverview.items.map((item) => (
            <a href={item.href} class="service-item">
              <i class={item.icon}></i>
              <span>{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="seo-copy">
      <div class="container seo-grid">
        {homePage.seoSections.map((section) => (
          <div>
            <h2>{section.heading}</h2>
            <p>{section.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA SECTION - FREE QUOTE -->
    <section class="cta-banner">
      <div class="container cta-content">
        <h2>{homePage.cta.heading}</h2>
        <p>{homePage.cta.subheading}</p>
        <div class="cta-actions">
          <a href={`tel:${siteSettings.phone.href}`} class="cta-button">
            <i class="fas fa-phone"></i> {siteSettings.phone.display}
          </a>
          <a href={siteSettings.squareBookingUrl} target="_blank" rel="noopener" class="square-button">
            <i class="fas fa-calendar-check"></i> {homePage.cta.squareLabel}
          </a>
        </div>
      </div>
    </section>

    <!-- CONTACT SECTION -->
    <section class="contact-section">
      <div class="container contact-grid">
        <div class="contact-form-wrapper">
          <h2>{homePage.contactForm.heading}</h2>
          <!-- TODO: Replace with actual Formspree form ID -->
          {!isFormConfigured && (
            <p class="form-note">{homePage.contactForm.unconfiguredNote}</p>
          )}
          <form action={formAction} method="POST">
            <input type="text" name="name" placeholder={homePage.contactForm.namePlaceholder} required />
            <input type="email" name="email" placeholder={homePage.contactForm.emailPlaceholder} required />
            <input type="text" name="subject" placeholder={homePage.contactForm.subjectPlaceholder} required />
            <textarea name="message" placeholder={homePage.contactForm.messagePlaceholder} rows="5" required></textarea>
            <button type="submit" disabled={!isFormConfigured}>{homePage.contactForm.submitLabel}</button>
          </form>
        </div>

        <div class="contact-info">
          <h3>{homePage.contactPanel.heading}</h3>
          <p><strong>Téléphone:</strong> <a href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a></p>
          <p><strong>Square:</strong> <a href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">{homePage.contactPanel.squareLabel}</a></p>
          <p><strong>Email:</strong> <a href={`mailto:${siteSettings.email}`}>{siteSettings.email}</a></p>
          <p><strong>Adresse:</strong> {siteSettings.address.fr}</p>
          <p><strong>Territoire desservi:</strong> {siteSettings.serviceArea.fr}</p>
          <p><strong>RBQ:</strong> {siteSettings.rbq} | <strong>Depuis:</strong> {siteSettings.sinceYear}</p>
          <p class="cta-text">{homePage.contactPanel.ctaText}</p>
        </div>
      </div>
    </section>

    <section class="reviews-section">
      <div class="container">
        <h2>{homePage.reviews.heading}</h2>
        <div class="reviews-grid">
          {homePage.reviews.items.map((review) => (
            <article class="review-card">
              <p class="review-text">"{review.quote}"</p>
              <p class="review-author">{review.author}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .hero {
    min-height: 640px;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.16), transparent 28%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 62%, #214f33 100%);
    text-align: center;
    color: white;
    padding: 5.5rem 1.5rem 4.5rem;
  }

  .hero-logo {
    width: min(760px, 88vw);
    height: auto;
    display: block;
    margin: 0 auto 2rem;
    filter: drop-shadow(0 18px 35px rgba(0, 0, 0, 0.25));
  }

  .hero-tagline {
    font-size: 1.2rem;
    letter-spacing: 2px;
    margin-top: 1rem;
    line-height: 1.5;
  }

  .hero-content h1 {
    color: white;
    max-width: 16ch;
    margin: 0 auto;
    line-height: 1.12;
  }

  .hero-content {
    width: min(980px, 100%);
  }

  .intro-section {
    padding: 4rem 0;
    background: white;
  }

  .intro-grid {
    display: flex;
    justify-content: center;
  }

  .intro-card {
    text-align: center;
    max-width: 720px;
  }

  .card-icon {
    font-size: 3rem;
    color: var(--brand-green);
    margin-bottom: 1rem;
  }

  .services-overview {
    padding: 4rem 0;
    background: var(--brand-surface);
  }

  .seo-copy {
    padding: 4rem 0;
    background: white;
  }

  .seo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .seo-grid p {
    margin-top: 0.75rem;
    color: var(--brand-muted);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .service-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem;
    background: white;
    border-radius: 8px;
    transition: all 0.3s;
    border: 2px solid transparent;
  }

  .service-item:hover {
    border-color: var(--brand-green);
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.1);
  }

  .service-item i {
    font-size: 2.5rem;
    color: var(--brand-navy);
  }

  .contact-section {
    padding: 4rem 0;
    background: var(--brand-navy);
    color: white;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .contact-form-wrapper h2 {
    color: white;
    margin-bottom: 1.5rem;
  }

  .contact-form-wrapper form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-note {
    margin-bottom: 1rem;
    color: #d9e6d1;
  }

  .contact-form-wrapper input,
  .contact-form-wrapper textarea {
    padding: 12px;
    border: none;
    border-radius: 4px;
    font-family: inherit;
  }

  .contact-info h3 {
    color: var(--brand-gold);
    margin-bottom: 1rem;
  }

  .contact-info p {
    margin-bottom: 0.75rem;
  }

  .cta-text {
    margin-top: 1.5rem;
    font-style: italic;
    color: #d9e6d1;
  }

  .reviews-section {
    padding: 4rem 0;
    background: #f4f6f8;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .review-card {
    background: white;
    border-radius: 18px;
    padding: 1.5rem;
    box-shadow: 0 14px 28px rgba(20, 36, 55, 0.08);
  }

  .review-text {
    color: var(--brand-ink);
    font-weight: 600;
  }

  .review-author {
    margin-top: 1rem;
    color: var(--brand-muted);
  }

  .cta-banner {
    background: var(--brand-green);
    padding: 3rem 1.5rem;
    text-align: center;
    color: white;
  }

  .cta-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: white;
  }

  .cta-content p {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    color: #ffffff;
  }

  .cta-button {
    display: inline-block;
    background: var(--brand-gold);
    color: var(--brand-navy-dark);
    padding: 12px 28px;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    border: 2px solid var(--brand-gold);
  }

  .cta-button:hover {
    background: #e1c317;
    color: var(--brand-navy-dark);
  }

  .cta-button i {
    margin-right: 8px;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
  }

  .square-button {
    display: inline-block;
    background: transparent;
    color: white;
    padding: 12px 28px;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    font-size: 1.05rem;
    transition: all 0.3s ease;
    border: 2px solid rgba(255, 255, 255, 0.75);
  }

  .square-button:hover {
    text-decoration: none;
    background: rgba(255,255,255,0.12);
    border-color: white;
  }

  .square-button i {
    margin-right: 8px;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 720px;
      padding: 6rem 1.25rem 5rem;
      align-items: flex-start;
    }

    .hero-logo {
      width: min(620px, 92vw);
      margin: 0 auto 2.25rem;
    }

    .hero-content h1 {
      font-size: 2.2rem;
      max-width: 12ch;
    }

    .hero-tagline {
      font-size: 1.05rem;
      margin-top: 1.15rem;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
