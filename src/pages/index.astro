---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || 'f/YOUR_FORM_ID';
const squareBookingUrl = 'https://app.squareup.com/appointments/book/lgocu4o42jy5zu/LGZ9VNRVZ6XXM/start';

const meta = {
  title: 'Clinique du VR | Entretien, reparation et esthetique',
  description: 'Clinique du VR offre entretien, reparation et esthetique avec un service professionnel et une prise en charge complete.'
};
---

<Layout title={meta.title} description={meta.description}>
  <Header />

  <main>
    <!-- HERO SECTION -->
    <section class="hero" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://www.demosolution.ca/images/Decontamination-bosco.jpg?w=1200&h=600&fit=crop');">
      <div class="hero-content">
        <img class="hero-logo" src="/clinique-du-vr-brand.jpg" alt="Clinique du VR" />
        <p class="hero-tagline">Entretien - reparation - esthetique</p>
      </div>
    </section>

    <!-- ABOUT & SERVICES INTRO -->
    <section class="intro-section">
      <div class="container intro-grid">
        <div class="intro-card">
          <div class="card-icon">
            <i class="fas fa-building"></i>
          </div>
        <h2>Pourquoi Choisir Clinique du VR?</h2>
          <p><strong>Service specialise et attentif</strong> pour l'entretien, la reparation et l'esthetique de VR. Rapidite, transparence, conformite reglementaire et execution soignee du debut a la fin.</p>
        </div>

        <div class="intro-card">
          <div class="card-icon">
            <i class="fas fa-wrench"></i>
          </div>
          <h2>Nos Services</h2>
          <p><strong>Entretien preventif</strong> • <strong>Reparations mecaniques et cosmetiques</strong> • <strong>Inspection de VR</strong> • <strong>Remise a niveau</strong> • <strong>Nettoyage et esthetique</strong> • <strong>Interventions sur mesure</strong></p>
        </div>
      </div>
    </section>

    <!-- SERVICES OVERVIEW -->
    <section class="services-overview">
      <div class="container">
        <h2>Nos Spécialités</h2>
        <div class="services-grid">
          <a href="/services/" class="service-item">
            <i class="fas fa-layer-group"></i>
            <span>Entretien</span>
          </a>
          <a href="/services/" class="service-item">
            <i class="fas fa-cloud"></i>
            <span>Reparation</span>
          </a>
          <a href="/services/" class="service-item">
            <i class="fas fa-flask"></i>
            <span>Inspection</span>
          </a>
          <a href="/services/" class="service-item">
            <i class="fas fa-hammer"></i>
            <span>Service atelier</span>
          </a>
          <a href="/services/" class="service-item">
            <i class="fas fa-wind"></i>
            <span>Esthetique</span>
          </a>
          <a href="/services/" class="service-item">
            <i class="fas fa-van"></i>
            <span>VR & Caravanes</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA SECTION - FREE QUOTE -->
    <section class="cta-banner">
      <div class="container cta-content">
        <h2>Demandez votre soumission gratuite</h2>
        <p>Inspection et devis sans obligation</p>
        <div class="cta-actions">
          <a href="tel:+15813373366" class="cta-button">
            <i class="fas fa-phone"></i> (581) 337-3366
          </a>
          <a href={squareBookingUrl} target="_blank" rel="noopener" class="square-button">
            <i class="fas fa-calendar-check"></i> Reserve maintenant
          </a>
        </div>
      </div>
    </section>

    <!-- CONTACT SECTION -->
    <section class="contact-section">
      <div class="container contact-grid">
        <div class="contact-form-wrapper">
          <h2>Contactez-Nous</h2>
          <form action={`https://formspree.io/${formspreeId}`} method="POST">
            <input type="text" name="name" placeholder="Votre nom" required />
            <input type="email" name="email" placeholder="Votre email" required />
            <input type="text" name="subject" placeholder="Sujet" required />
            <textarea name="message" placeholder="Votre message" rows="5" required></textarea>
            <button type="submit">Envoyer</button>
          </form>
        </div>

        <div class="contact-info">
          <h3>Informations de Contact</h3>
          <p><strong>Téléphone:</strong> <a href="tel:+15813373366">(581) 337-3366</a></p>
          <p><strong>Square:</strong> <a href={squareBookingUrl} target="_blank" rel="noopener">Reserve maintenant</a></p>
          <p><strong>Email:</strong> <a href="mailto:info@demosolution.ca">info@demosolution.ca</a></p>
          <p><strong>Adresse:</strong> 11 rue de Granby, Unite 18, Gatineau, QC</p>
          <p><strong>Territoire desservi:</strong> Gatineau, Ottawa, Laurentides, Outaouais, Quebec et Ontario</p>
          <p><strong>RBQ:</strong> 5824-9764-01 | <strong>Depuis:</strong> 2013</p>
          <p class="cta-text">Devis gratuit et confidentiel. Appelez-nous ou remplissez le formulaire.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .hero {
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center;
    text-align: center;
    color: white;
  }

  .hero-logo {
    width: min(760px, 92vw);
    height: auto;
    display: block;
    margin: 0 auto 1.5rem;
    filter: drop-shadow(0 18px 35px rgba(0, 0, 0, 0.25));
  }

  .hero-tagline {
    font-size: 1.5rem;
    letter-spacing: 2px;
  }

  .intro-section {
    padding: 4rem 0;
    background: white;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }

  .intro-card {
    text-align: center;
  }

  .card-icon {
    font-size: 3rem;
    color: var(--brand-green);
    margin-bottom: 1rem;
  }

  .services-overview {
    padding: 4rem 0;
    background: var(--brand-surface);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .service-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem;
    background: white;
    border-radius: 8px;
    transition: all 0.3s;
    border: 2px solid transparent;
  }

  .service-item:hover {
    border-color: var(--brand-green);
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.1);
  }

  .service-item i {
    font-size: 2.5rem;
    color: var(--brand-navy);
  }

  .contact-section {
    padding: 4rem 0;
    background: var(--brand-navy);
    color: white;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .contact-form-wrapper h2 {
    color: white;
    margin-bottom: 1.5rem;
  }

  .contact-form-wrapper form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-form-wrapper input,
  .contact-form-wrapper textarea {
    padding: 12px;
    border: none;
    border-radius: 4px;
    font-family: inherit;
  }

  .contact-info h3 {
    color: var(--brand-gold);
    margin-bottom: 1rem;
  }

  .contact-info p {
    margin-bottom: 0.75rem;
  }

  .cta-text {
    margin-top: 1.5rem;
    font-style: italic;
    color: #d9e6d1;
  }

  .cta-banner {
    background: var(--brand-green);
    padding: 3rem 1.5rem;
    text-align: center;
    color: white;
  }

  .cta-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: white;
  }

  .cta-content p {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    color: #ffffff;
  }

  .cta-button {
    display: inline-block;
    background: var(--brand-gold);
    color: var(--brand-navy-dark);
    padding: 12px 28px;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    border: 2px solid var(--brand-gold);
  }

  .cta-button:hover {
    background: #e1c317;
    color: var(--brand-navy-dark);
  }

  .cta-button i {
    margin-right: 8px;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
  }

  .square-button {
    display: inline-block;
    background: transparent;
    color: white;
    padding: 12px 28px;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    font-size: 1.05rem;
    transition: all 0.3s ease;
    border: 2px solid rgba(255, 255, 255, 0.75);
  }

  .square-button:hover {
    text-decoration: none;
    background: rgba(255,255,255,0.12);
    border-color: white;
  }

  .square-button i {
    margin-right: 8px;
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 2.5rem;
    }
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
