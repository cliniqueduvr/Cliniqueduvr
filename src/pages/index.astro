---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildLocalBusinessSchema } from '../lib/seo';

const rawFormspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || '';
const isFormConfigured = Boolean(rawFormspreeId && rawFormspreeId.startsWith('f/'));
const formAction = isFormConfigured ? `https://formspree.io/f/${rawFormspreeId}` : undefined;
const squareBookingUrl = 'https://app.squareup.com/appointments/book/lgocu4o42jy5zu/LGZ9VNRVZ6XXM/start';
const schemas = [buildLocalBusinessSchema()];

const meta = {
  title: 'Clinique du VR | Inspection, entretien et reparation VR a Gatineau-Ottawa',
  description: 'Clinique du VR offre inspection, entretien, reparation, esthetique et accompagnement vente achat pour VR a Gatineau-Ottawa.'
};
---

<Layout title={meta.title} description={meta.description} canonicalPath="/" frPath="/" enPath="/en/" schemas={schemas}>
  <Header />

  <main>
    <section class="hero">
      <div class="hero-content">
        <img class="hero-logo" src="/clinique-du-vr-brand.jpg" alt="Logo Clinique du VR — Entretien, reparation et esthetique de vehicules recreatifs" />
        <h1>Clinique du VR — Entretien, reparation et esthetique de VR a Gatineau-Ottawa</h1>
        <p class="hero-tagline">Votre spécialiste en infiltration d’eau en Outaouais</p>
      </div>
    </section>

    <!-- ABOUT & SERVICES INTRO -->
    <section class="intro-section">
      <div class="container intro-grid">
        <div class="intro-card">
          <div class="card-icon">
            <i class="fas fa-building"></i>
          </div>
          <h2>Pourquoi Choisir Clinique du VR?</h2>
          <p><strong>Service specialise et attentif</strong> pour l'entretien, la reparation et l'esthetique de VR. Rapidite, transparence, conformite reglementaire et execution soignee du debut a la fin.</p>
        </div>
      </div>
    </section>

    <!-- SERVICES OVERVIEW -->
    <section class="services-overview">
      <div class="container">
        <h2>Nos Spécialités</h2>
        <div class="services-grid">
          <a href="/services/inspection/" class="service-item">
            <i class="fas fa-clipboard-check"></i>
            <span>Inspection</span>
          </a>
          <a href="/services/entretien/" class="service-item">
            <i class="fas fa-screwdriver-wrench"></i>
            <span>Entretien</span>
          </a>
          <a href="/services/reparation/" class="service-item">
            <i class="fas fa-toolbox"></i>
            <span>Reparation</span>
          </a>
          <a href="/services/esthetique/" class="service-item">
            <i class="fas fa-spray-can-sparkles"></i>
            <span>Esthetique</span>
          </a>
          <a href="/services/vente-achat/" class="service-item">
            <i class="fas fa-van-shuttle"></i>
            <span>Vente et achat</span>
          </a>
        </div>
      </div>
    </section>

    <section class="seo-copy">
      <div class="container seo-grid">
        <div>
          <h2>Service VR a Gatineau-Ottawa</h2>
          <p>Clinique du VR accompagne les proprietaires de VR, roulottes et caravanes pour les besoins les plus frequents: inspection avant achat, entretien preventif, reparation de fuite d'eau, toiture, remise en etat et esthetique. Notre atelier a Gatineau dessert aussi Ottawa, l'Outaouais, les Laurentides ainsi que plusieurs clients au Quebec et en Ontario.</p>
        </div>
        <div>
          <h2>Une approche utile avant les travaux</h2>
          <p>Quand un vehicule presente des signes d usure, d infiltration ou de deterioration visuelle, il faut d abord clarifier l etat reel du VR. Nous vous aidons ensuite a choisir entre une inspection, un entretien, une reparation, un service esthetique ou une preparation avant vente selon ce qui est le plus utile.</p>
        </div>
      </div>
    </section>

    <!-- CTA SECTION - FREE QUOTE -->
    <section class="cta-banner">
      <div class="container cta-content">
        <h2>Demandez votre soumission gratuite</h2>
        <p>Inspection et devis sans obligation</p>
        <div class="cta-actions">
          <a href="tel:+15813373366" class="cta-button">
            <i class="fas fa-phone"></i> (581) 337-3366
          </a>
          <a href={squareBookingUrl} target="_blank" rel="noopener" class="square-button">
            <i class="fas fa-calendar-check"></i> Reserve maintenant
          </a>
        </div>
      </div>
    </section>

    <!-- CONTACT SECTION -->
    <section class="contact-section">
      <div class="container contact-grid">
        <div class="contact-form-wrapper">
          <h2>Contactez-Nous</h2>
          <!-- TODO: Replace with actual Formspree form ID -->
          {!isFormConfigured && (
            <p class="form-note">Le formulaire de contact n est pas encore configure en production. Utilisez le telephone ou la prise de rendez-vous Square en attendant.</p>
          )}
          <form action={formAction} method="POST">
            <input type="text" name="name" placeholder="Votre nom" required />
            <input type="email" name="email" placeholder="Votre email" required />
            <input type="text" name="subject" placeholder="Sujet" required />
            <textarea name="message" placeholder="Votre message" rows="5" required></textarea>
            <button type="submit" disabled={!isFormConfigured}>Envoyer</button>
          </form>
        </div>

        <div class="contact-info">
          <h3>Informations de Contact</h3>
          <p><strong>Téléphone:</strong> <a href="tel:+15813373366">(581) 337-3366</a></p>
          <p><strong>Square:</strong> <a href={squareBookingUrl} target="_blank" rel="noopener">Reserve maintenant</a></p>
          <p><strong>Email:</strong> <a href="mailto:info@demosolution.ca">info@demosolution.ca</a></p>
          <p><strong>Adresse:</strong> 11 rue de Granby, Unite 18, Gatineau, QC</p>
          <p><strong>Territoire desservi:</strong> Gatineau, Ottawa, Laurentides, Outaouais, Quebec et Ontario</p>
          <p><strong>RBQ:</strong> 5824-9764-01 | <strong>Depuis:</strong> 2013</p>
          <p class="cta-text">Devis gratuit et confidentiel. Appelez-nous ou remplissez le formulaire.</p>
        </div>
      </div>
    </section>

    <section class="reviews-section">
      <div class="container">
        <h2>Avis Google</h2>
        <div class="reviews-grid">
          <article class="review-card">
            <p class="review-text">"Cédric était à l’heure, a tout expliqué clairement et les résultats ont suivi comme promis. Deux pouces en l’air."</p>
            <p class="review-author">Jesse Brook</p>
          </article>
          <article class="review-card">
            <p class="review-text">"Service professionnel et courtois."</p>
            <p class="review-author">Stéphane Desgagné</p>
          </article>
          <article class="review-card">
            <p class="review-text">"Compagnie efficace, facile de communiquer avec eux. Travail professionnel, que du positif."</p>
            <p class="review-author">Philippe Albert</p>
          </article>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .hero {
    min-height: 640px;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.16), transparent 28%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 62%, #214f33 100%);
    text-align: center;
    color: white;
    padding: 5.5rem 1.5rem 4.5rem;
  }

  .hero-logo {
    width: min(760px, 88vw);
    height: auto;
    display: block;
    margin: 0 auto 2rem;
    filter: drop-shadow(0 18px 35px rgba(0, 0, 0, 0.25));
  }

  .hero-tagline {
    font-size: 1.2rem;
    letter-spacing: 2px;
    margin-top: 1rem;
    line-height: 1.5;
  }

  .hero-content h1 {
    color: white;
    max-width: 16ch;
    margin: 0 auto;
    line-height: 1.12;
  }

  .hero-content {
    width: min(980px, 100%);
  }

  .intro-section {
    padding: 4rem 0;
    background: white;
  }

  .intro-grid {
    display: flex;
    justify-content: center;
  }

  .intro-card {
    text-align: center;
    max-width: 720px;
  }

  .card-icon {
    font-size: 3rem;
    color: var(--brand-green);
    margin-bottom: 1rem;
  }

  .services-overview {
    padding: 4rem 0;
    background: var(--brand-surface);
  }

  .seo-copy {
    padding: 4rem 0;
    background: white;
  }

  .seo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .seo-grid p {
    margin-top: 0.75rem;
    color: var(--brand-muted);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .service-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem;
    background: white;
    border-radius: 8px;
    transition: all 0.3s;
    border: 2px solid transparent;
  }

  .service-item:hover {
    border-color: var(--brand-green);
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.1);
  }

  .service-item i {
    font-size: 2.5rem;
    color: var(--brand-navy);
  }

  .contact-section {
    padding: 4rem 0;
    background: var(--brand-navy);
    color: white;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .contact-form-wrapper h2 {
    color: white;
    margin-bottom: 1.5rem;
  }

  .contact-form-wrapper form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-note {
    margin-bottom: 1rem;
    color: #d9e6d1;
  }

  .contact-form-wrapper input,
  .contact-form-wrapper textarea {
    padding: 12px;
    border: none;
    border-radius: 4px;
    font-family: inherit;
  }

  .contact-info h3 {
    color: var(--brand-gold);
    margin-bottom: 1rem;
  }

  .contact-info p {
    margin-bottom: 0.75rem;
  }

  .cta-text {
    margin-top: 1.5rem;
    font-style: italic;
    color: #d9e6d1;
  }

  .reviews-section {
    padding: 4rem 0;
    background: #f4f6f8;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .review-card {
    background: white;
    border-radius: 18px;
    padding: 1.5rem;
    box-shadow: 0 14px 28px rgba(20, 36, 55, 0.08);
  }

  .review-text {
    color: var(--brand-ink);
    font-weight: 600;
  }

  .review-author {
    margin-top: 1rem;
    color: var(--brand-muted);
  }

  .cta-banner {
    background: var(--brand-green);
    padding: 3rem 1.5rem;
    text-align: center;
    color: white;
  }

  .cta-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: white;
  }

  .cta-content p {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    color: #ffffff;
  }

  .cta-button {
    display: inline-block;
    background: var(--brand-gold);
    color: var(--brand-navy-dark);
    padding: 12px 28px;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    border: 2px solid var(--brand-gold);
  }

  .cta-button:hover {
    background: #e1c317;
    color: var(--brand-navy-dark);
  }

  .cta-button i {
    margin-right: 8px;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
  }

  .square-button {
    display: inline-block;
    background: transparent;
    color: white;
    padding: 12px 28px;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    font-size: 1.05rem;
    transition: all 0.3s ease;
    border: 2px solid rgba(255, 255, 255, 0.75);
  }

  .square-button:hover {
    text-decoration: none;
    background: rgba(255,255,255,0.12);
    border-color: white;
  }

  .square-button i {
    margin-right: 8px;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 720px;
      padding: 6rem 1.25rem 5rem;
      align-items: flex-start;
    }

    .hero-logo {
      width: min(620px, 92vw);
      margin: 0 auto 2.25rem;
    }

    .hero-content h1 {
      font-size: 2.2rem;
      max-width: 12ch;
    }

    .hero-tagline {
      font-size: 1.05rem;
      margin-top: 1.15rem;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
