---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localAreaPagesFr } from '../data/local-area-pages';
import { buildBreadcrumbSchema, buildCollectionPageSchema, buildWebSiteSchema } from '../lib/seo';
import siteSettings from '../data/site-settings.json';

const schemas = [
  buildWebSiteSchema(),
  buildCollectionPageSchema({
    name: 'Zones desservies | Clinique du VR',
    description: 'Zones desservies par Clinique du VR depuis Gatineau pour inspection, entretien et réparation de VR.',
    path: '/zones-desservies/'
  }),
  buildBreadcrumbSchema([
    { name: 'Accueil', path: '/' },
    { name: 'Zones desservies' }
  ])
];
---

<Layout
  title="Zones desservies VR | Gatineau, Ottawa, Outaouais, Laurentides | Clinique du VR"
  description="Découvrez les zones desservies par Clinique du VR depuis Gatineau pour l'inspection, l'entretien et la réparation de VR, roulottes et caravanes."
  canonicalPath="/zones-desservies/"
  frPath="/zones-desservies/"
  enPath="/en/service-areas/"
  schemas={schemas}
>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Local SEO</p>
          <h1>Zones desservies autour de Gatineau</h1>
          <p class="lead">Notre atelier est à Gatineau. Nous accompagnons aussi des demandes venant d’Ottawa, de l’Outaouais et des Laurentides selon le type d’intervention, la nature du problème et le format atelier ou mobile.</p>
        </div>

        <aside class="hero-card">
          <div class="hero-icon">
            <i class="fas fa-map-location-dot"></i>
          </div>
          <h2>Besoin d'un point de départ clair?</h2>
          <p>On peut vous aider à comprendre la situation, à choisir le bon service et à décider de la prochaine étape utile pour votre VR.</p>
          <a class="hero-link" href="/contact/">Parler de votre VR</a>
        </aside>
      </div>
    </section>

    <section class="areas-section">
      <div class="container body-grid">
        <article class="content-main">
          <div class="areas-grid">
          {localAreaPagesFr.map((page) => (
            <a class="area-card" href={`/zones/${page.slug}/`}>
              <p class="area-name">{page.area}</p>
              <h2>{page.h1}</h2>
              <p>{page.intro}</p>
              <span>Voir la page locale</span>
            </a>
          ))}
          </div>

          <div class="content-grid">
          <article class="content-card">
            <h2>Quand une page locale est utile</h2>
            <p>Une page locale est utile quand vous cherchez un service précis avec une réalité géographique claire: fuite d’eau à Gatineau, entretien en Outaouais, réparation pour Ottawa ou infiltration sur une roulotte dans les Laurentides.</p>
          </article>

          <article class="content-card">
            <h2>Atelier à Gatineau, accompagnement régional</h2>
            <p>Le point de départ reste notre atelier de Gatineau. Selon le service demandé, nous pouvons orienter vers une inspection, un entretien ou une réparation, puis confirmer la meilleure prochaine étape avant déplacement ou réservation.</p>
          </article>

          <article class="content-card">
            <h2>Avant de réserver</h2>
            <p>Si vous hésitez encore entre plusieurs services, commencez par notre page d’orientation ou contactez-nous avec quelques photos du VR, la ville, le type de problème et le niveau d’urgence.</p>
            <p class="actions"><a href="/choisir-service/">Quel service choisir ?</a> · <a href="/contact/">Contacter l’atelier</a></p>
          </article>
          </div>
        </article>

        <aside class="side-panel">
          <div class="side-card side-card-primary">
            <h3>Besoin d'un avis rapide?</h3>
            <p>On peut vous orienter vers une inspection, un entretien ou une réparation selon l'état du véhicule.</p>
            <a class="side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
            <a class="side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">Réserver en ligne</a>
          </div>

          <div class="side-card">
            <h3>Autres services</h3>
            <nav class="service-nav" aria-label="Autres services">
              <a href="/services/inspection/"><i class="fas fa-clipboard-check"></i><span>Inspection</span></a>
              <a href="/services/entretien/"><i class="fas fa-screwdriver-wrench"></i><span>Entretien</span></a>
              <a href="/services/reparation/"><i class="fas fa-toolbox"></i><span>Réparation</span></a>
              <a href="/services/esthetique/"><i class="fas fa-spray-can-sparkles"></i><span>Esthétique VR</span></a>
            </nav>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-hero { position: relative; overflow: hidden; padding: 4.5rem 0 4rem; background: radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 32%), linear-gradient(135deg, var(--brand-navy-dark) 0%, #23476f 58%, #f4f6f8 58%, #f4f6f8 100%); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr); gap: 2rem; align-items: stretch; }
  .hero-copy { color: white; }
  .eyebrow { display: inline-flex; margin-bottom: 1.25rem; padding: 0.45rem 0.85rem; border-radius: 999px; background: rgba(255,255,255,0.12); color: var(--brand-gold); font-size: 0.85rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .page-hero h1 { color: white; margin-bottom: 1rem; max-width: 14ch; line-height: 1.05; }
  .lead { max-width: 64ch; color: #f5f7fa; font-size: 1.2rem; line-height: 1.7; }
  .hero-card { align-self: end; background: white; border-radius: 24px; padding: 2rem; box-shadow: 0 22px 44px rgba(16, 35, 56, 0.22); }
  .hero-icon { width: 4rem; height: 4rem; display: inline-flex; align-items: center; justify-content: center; border-radius: 18px; background: linear-gradient(135deg, var(--brand-green), #57af49); color: white; font-size: 1.5rem; margin-bottom: 1rem; }
  .hero-card h2 { font-size: 1.5rem; margin-bottom: 0.75rem; }
  .hero-card p { color: var(--brand-muted); margin-bottom: 1.25rem; }
  .hero-link { display: inline-flex; align-items: center; justify-content: center; width: 100%; min-height: 48px; padding: 0.85rem 1rem; border-radius: 999px; background: var(--brand-navy); color: white; font-weight: 700; text-decoration: none; }
  .hero-link:hover { text-decoration: none; background: var(--brand-navy-dark); }
  .areas-section { padding: 4rem 0; background: linear-gradient(180deg, #ffffff 0%, #ffffff 42%, #f3f5f8 42%, #f3f5f8 100%); }
  .body-grid { display: grid; grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr); gap: 2rem; align-items: start; }
  .content-main { display: grid; gap: 1.5rem; }
  .side-panel { display: grid; gap: 1.5rem; position: sticky; top: 7rem; align-self: start; }
  .areas-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
  .area-card { background: white; border-radius: 22px; padding: 1.75rem; box-shadow: 0 16px 34px rgba(24, 40, 61, 0.08); }
  .area-name { color: var(--brand-green-dark); font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.82rem; }
  .area-card h2 { font-size: 1.2rem; margin: 0.45rem 0 0.8rem; }
  .area-card p { color: var(--brand-muted); }
  .area-card span { display: inline-block; margin-top: 1rem; font-weight: 700; }
  .content-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem; margin-top: 2rem; }
  .content-card, .side-card { background: white; border-radius: 22px; padding: 1.75rem; box-shadow: 0 16px 34px rgba(24, 40, 61, 0.08); }
  .content-card p { margin-top: 0.75rem; color: var(--brand-muted); }
  .side-card-primary { background: var(--brand-navy-dark); color: white; }
  .side-card-primary h3 { color: white; }
  .side-card-primary p { color: #dbe4ee; }
  .side-card h3 { margin-bottom: 1rem; }
  .side-button { display: inline-flex; align-items: center; justify-content: center; width: 100%; min-height: 48px; border-radius: 999px; background: var(--brand-gold); color: var(--brand-navy-dark); font-weight: 700; text-decoration: none; margin: 0.25rem 0 0.75rem; }
  .side-button:hover { text-decoration: none; background: #e2c417; }
  .side-link { display: inline-flex; align-items: center; justify-content: center; width: 100%; min-height: 48px; padding: 0.55rem 1rem; border-radius: 999px; background: var(--brand-gold); border: 2px solid var(--brand-gold); color: var(--brand-navy-dark); font-weight: 700; text-decoration: none; }
  .side-link:hover { text-decoration: none; background: #e1c317; border-color: #e1c317; }
  .service-nav { display: grid; gap: 0.7rem; }
  .service-nav a { display: flex; align-items: center; gap: 0.8rem; min-height: 54px; padding: 0.9rem 1rem; border-radius: 16px; background: var(--brand-surface); color: var(--brand-ink); text-decoration: none; font-weight: 700; }
  .service-nav a:hover { text-decoration: none; background: #eaf1e6; }
  .service-nav i { color: var(--brand-green); }
  .actions { font-weight: 700; }
  @media (max-width: 768px) { .page-hero { background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%); padding: 3.8rem 0 2.8rem; } .hero-grid, .body-grid { grid-template-columns: 1fr; } .side-panel { position: static; } }
</style>
