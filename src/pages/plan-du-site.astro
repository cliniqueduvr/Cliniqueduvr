---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildBreadcrumbSchema } from '../lib/seo';
import siteSettings from '../data/site-settings.json';

const sections = [
  {
    title: 'Pages principales',
    links: [
      { href: '/', label: 'Accueil' },
      { href: '/services/', label: 'Services' },
      { href: '/choisir-service/', label: 'Quel service choisir ?' },
      { href: '/vente/', label: 'Vente' },
      { href: '/realisations/', label: 'Réalisations' },
      { href: '/about/', label: 'À propos' },
      { href: '/contact/', label: 'Contact' },
      { href: '/privacy/', label: 'Politique de confidentialité' }
    ]
  },
  {
    title: 'Services',
    links: [
      { href: '/services/inspection/', label: 'Inspection' },
      { href: '/services/entretien/', label: 'Entretien' },
      { href: '/services/reparation/', label: 'Réparation' },
      { href: '/services/esthetique/', label: 'Esthétique VR' },
      { href: '/services/esthetique-auto-camion/', label: 'Esthétique auto et camion' }
    ]
  },
  {
    title: 'Pages locales',
    links: [
      { href: '/zones/fuite-eau-vr-gatineau/', label: "Fuite d’eau de VR à Gatineau" },
      { href: '/zones/entretien-vr-gatineau/', label: 'Entretien de VR à Gatineau' },
      { href: '/zones/inspection-vr-outaouais/', label: 'Inspection de VR en Outaouais' },
      { href: '/zones/reparation-vr-ottawa/', label: 'Réparation de VR à Ottawa' },
      { href: '/zones/infiltration-eau-roulotte-laurentides/', label: "Infiltration d’eau de roulotte dans les Laurentides" }
    ]
  }
];

const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Accueil', path: '/' },
  { name: 'Plan du site' }
]);
---

<Layout
  title="Plan du site | Clinique du VR"
  description="Plan du site de Clinique du VR avec les pages principales, les services et les pages locales."
  canonicalPath="/plan-du-site/"
  frPath="/plan-du-site/"
  enPath="/en/site-map/"
  schemas={[breadcrumbs]}
>
  <Header />

  <main>
    <section class="page-header">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Navigation</p>
          <h1>Plan du site</h1>
          <p>Retrouvez ici les principales pages du site, les services disponibles et les pages locales reliées à nos zones desservies.</p>
        </div>

        <aside class="hero-card">
          <div class="hero-icon">
            <i class="fas fa-sitemap"></i>
          </div>
          <h2>Besoin d'un point de départ clair?</h2>
          <p>On peut vous aider à comprendre la situation, à choisir le bon service et à décider de la prochaine étape utile pour votre VR.</p>
          <a class="hero-link" href="/contact/">Parler de votre VR</a>
        </aside>
      </div>
    </section>

    <section class="sitemap-section">
      <div class="container body-grid">
        <article class="content-main sitemap-grid">
          {sections.map((section) => (
          <article class="sitemap-card">
            <h2>{section.title}</h2>
            <ul>
              {section.links.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </article>
        ))}
        </article>

        <aside class="side-panel">
          <div class="side-card side-card-primary">
            <h3>Besoin d'un avis rapide?</h3>
            <p>On peut vous orienter vers une inspection, un entretien ou une réparation selon l'état du véhicule.</p>
            <a class="side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
            <a class="side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">Réserver en ligne</a>
          </div>

          <div class="side-card">
            <h3>Autres services</h3>
            <nav class="service-nav" aria-label="Autres services">
              <a href="/services/inspection/"><i class="fas fa-clipboard-check"></i><span>Inspection</span></a>
              <a href="/services/entretien/"><i class="fas fa-screwdriver-wrench"></i><span>Entretien</span></a>
              <a href="/services/reparation/"><i class="fas fa-toolbox"></i><span>Réparation</span></a>
              <a href="/services/esthetique/"><i class="fas fa-spray-can-sparkles"></i><span>Esthétique VR</span></a>
            </nav>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-header { background: radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 32%), linear-gradient(135deg, var(--brand-navy-dark) 0%, #23476f 58%, #f4f6f8 58%, #f4f6f8 100%); padding: 4.5rem 0 4rem; }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr); gap: 2rem; align-items: stretch; }
  .hero-copy { color: white; }

  .eyebrow { display: inline-flex; margin-bottom: 1.25rem; padding: 0.45rem 0.85rem; border-radius: 999px; background: rgba(255,255,255,0.12); color: var(--brand-gold); font-size: 0.85rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }

  .page-header h1 { color: white; margin-bottom: 1rem; font-size: 3rem; line-height: 1.05; }

  .page-header p:last-child { margin: 0; max-width: 55ch; font-size: 1.2rem; line-height: 1.7; color: #f5f7fa; }
  .hero-card { align-self: end; background: white; border-radius: 24px; padding: 2rem; box-shadow: 0 22px 44px rgba(16, 35, 56, 0.22); }
  .hero-icon { width: 4rem; height: 4rem; display: inline-flex; align-items: center; justify-content: center; border-radius: 18px; background: linear-gradient(135deg, var(--brand-green), #57af49); color: white; font-size: 1.5rem; margin-bottom: 1rem; }
  .hero-card h2 { font-size: 1.5rem; margin-bottom: 0.75rem; }
  .hero-card p { color: var(--brand-muted); margin-bottom: 1.25rem; }
  .hero-link { display: inline-flex; align-items: center; justify-content: center; width: 100%; min-height: 48px; padding: 0.85rem 1rem; border-radius: 999px; background: var(--brand-navy); color: white; font-weight: 700; text-decoration: none; }
  .hero-link:hover { text-decoration: none; background: var(--brand-navy-dark); }

  .sitemap-section { padding: 4rem 0; background: linear-gradient(180deg, #ffffff 0%, #ffffff 42%, #f3f5f8 42%, #f3f5f8 100%); }
  .body-grid { display: grid; grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr); gap: 2rem; align-items: start; }
  .content-main { display: grid; gap: 1.5rem; }
  .side-panel { display: grid; gap: 1.5rem; position: sticky; top: 7rem; align-self: start; }

  .sitemap-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; }

  .sitemap-card, .side-card { background: white; border-radius: 22px; padding: 1.75rem; box-shadow: 0 16px 34px rgba(24, 40, 61, 0.08); }

  .sitemap-card h2 {
    margin-bottom: 1rem;
  }

  .sitemap-card ul {
    display: grid;
    gap: 0.75rem;
    padding-left: 1.2rem;
  }

  .sitemap-card a {
    color: var(--brand-navy);
    font-weight: 700;
  }
  .side-card-primary { background: var(--brand-navy-dark); color: white; }
  .side-card-primary h3 { color: white; }
  .side-card-primary p { color: #dbe4ee; }
  .side-card h3 { margin-bottom: 1rem; }
  .side-button { display: inline-flex; align-items: center; justify-content: center; width: 100%; min-height: 48px; border-radius: 999px; background: var(--brand-gold); color: var(--brand-navy-dark); font-weight: 700; text-decoration: none; margin: 0.25rem 0 0.75rem; }
  .side-button:hover { text-decoration: none; background: #e2c417; }
  .side-link { display: inline-flex; align-items: center; justify-content: center; width: 100%; min-height: 48px; padding: 0.55rem 1rem; border-radius: 999px; background: var(--brand-gold); border: 2px solid var(--brand-gold); color: var(--brand-navy-dark); font-weight: 700; text-decoration: none; }
  .side-link:hover { text-decoration: none; background: #e1c317; border-color: #e1c317; }
  .service-nav { display: grid; gap: 0.7rem; }
  .service-nav a { display: flex; align-items: center; gap: 0.8rem; min-height: 54px; padding: 0.9rem 1rem; border-radius: 16px; background: var(--brand-surface); color: var(--brand-ink); text-decoration: none; font-weight: 700; }
  .service-nav a:hover { text-decoration: none; background: #eaf1e6; }
  .service-nav i { color: var(--brand-green); }

  @media (max-width: 768px) {
    .page-header { background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%); padding: 3.6rem 0 3rem; }

    .page-header h1 {
      font-size: 2.2rem;
    }
    .hero-grid, .body-grid { grid-template-columns: 1fr; }
    .side-panel { position: static; }
  }
</style>
