---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildBreadcrumbSchema } from '../lib/seo';

const sections = [
  {
    title: 'Pages principales',
    links: [
      { href: '/', label: 'Accueil' },
      { href: '/services/', label: 'Services' },
      { href: '/choisir-service/', label: 'Quel service choisir ?' },
      { href: '/vente/', label: 'Vente' },
      { href: '/realisations/', label: 'Réalisations' },
      { href: '/about/', label: 'À propos' },
      { href: '/contact/', label: 'Contact' },
      { href: '/privacy/', label: 'Politique de confidentialité' }
    ]
  },
  {
    title: 'Services',
    links: [
      { href: '/services/inspection/', label: 'Inspection' },
      { href: '/services/entretien/', label: 'Entretien' },
      { href: '/services/reparation/', label: 'Réparation' },
      { href: '/services/esthetique/', label: 'Esthétique' }
    ]
  },
  {
    title: 'Pages locales',
    links: [
      { href: '/zones/inspection-vr-outaouais/', label: 'Inspection de VR en Outaouais' },
      { href: '/zones/reparation-vr-ottawa/', label: 'Réparation de VR à Ottawa' },
      { href: '/zones/infiltration-eau-roulotte-laurentides/', label: "Infiltration d’eau de roulotte dans les Laurentides" }
    ]
  }
];

const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Accueil', path: '/' },
  { name: 'Plan du site' }
]);
---

<Layout
  title="Plan du site | Clinique du VR"
  description="Plan du site de Clinique du VR avec les pages principales, les services et les pages locales."
  canonicalPath="/plan-du-site/"
  frPath="/plan-du-site/"
  enPath="/en/site-map/"
  schemas={[breadcrumbs]}
>
  <Header />

  <main>
    <section class="page-header">
      <div class="container">
        <p class="eyebrow">Navigation</p>
        <h1>Plan du site</h1>
        <p>Retrouvez ici les principales pages du site, les services disponibles et les pages locales reliées à nos zones desservies.</p>
      </div>
    </section>

    <section class="sitemap-section">
      <div class="container sitemap-grid">
        {sections.map((section) => (
          <article class="sitemap-card">
            <h2>{section.title}</h2>
            <ul>
              {section.links.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-header {
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 25%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 58%, #eef3f7 58%, #eef3f7 100%);
    color: white;
    padding: 4.5rem 0 3.8rem;
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: var(--brand-gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-header h1 {
    color: white;
    margin-bottom: 0.75rem;
    font-size: 3rem;
  }

  .page-header p:last-child {
    margin: 0;
    max-width: 55ch;
    font-size: 1.08rem;
    color: #e7edf4;
  }

  .sitemap-section {
    padding: 4rem 0;
    background: #f3f5f8;
  }

  .sitemap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .sitemap-card {
    background: white;
    border-radius: 22px;
    padding: 1.6rem;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
  }

  .sitemap-card h2 {
    margin-bottom: 1rem;
  }

  .sitemap-card ul {
    display: grid;
    gap: 0.75rem;
    padding-left: 1.2rem;
  }

  .sitemap-card a {
    color: var(--brand-navy);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .page-header {
      background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
      padding: 3.6rem 0 3rem;
    }

    .page-header h1 {
      font-size: 2.2rem;
    }
  }
</style>
