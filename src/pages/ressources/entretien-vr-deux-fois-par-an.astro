---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { buildArticleSchema, buildBreadcrumbSchema, buildFAQSchema, buildWebSiteSchema } from '../../lib/seo';
import siteSettings from '../../data/site-settings.json';

const title = "Entretien de VR 2 fois par an | Quoi faire au printemps et à l'automne";
const description = "Guide pratique pour l'entretien de VR deux fois par année: quoi vérifier au printemps et à l'automne pour les joints, la toiture, l'humidité et l'étanchéité.";
const faqs = [
  {
    question: "Pourquoi faire l'entretien de son VR deux fois par année?",
    answer: "Deux entretiens par année permettent de vérifier les joints, la toiture, les zones exposées à l’eau et les signes d’usure avant que de petites faiblesses deviennent des infiltrations plus coûteuses."
  },
  {
    question: "Que faut-il vérifier au printemps?",
    answer: "Au printemps, il faut surtout vérifier les joints, la toiture, la membrane, les ouvertures et les traces d’eau ou d’humidité apparues après l’hiver."
  },
  {
    question: "Que faut-il vérifier à l’automne?",
    answer: "À l’automne, l’objectif est de corriger les points faibles avant l’hivernage et d’éviter qu’un joint fatigué ou une petite faiblesse laisse entrer l’eau pendant la mauvaise saison."
  }
];
const schemas = [
  buildWebSiteSchema(),
  buildArticleSchema({
    headline: title,
    description,
    path: '/ressources/entretien-vr-deux-fois-par-an/'
  }),
  buildFAQSchema(faqs),
  buildBreadcrumbSchema([
    { name: 'Accueil', path: '/' },
    { name: 'Ressources', path: '/faq/' },
    { name: 'Entretien 2 fois par an' }
  ])
];
---

<Layout
  title={`${title} | Clinique du VR`}
  description={description}
  canonicalPath="/ressources/entretien-vr-deux-fois-par-an/"
  frPath="/ressources/entretien-vr-deux-fois-par-an/"
  enPath="/en/resources/twice-yearly-rv-maintenance/"
  schemas={schemas}
  ogType="article"
>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Ressource pratique</p>
          <h1>Entretien recommandé</h1>
          <p class="lead">Un entretien au printemps et un autre à l’automne donnent souvent le meilleur rapport entre prévention, tranquillité d’esprit et protection contre les infiltrations d’eau.</p>
        </div>

        <aside class="hero-card">
          <div class="hero-icon">
            <i class="fas fa-calendar-check"></i>
          </div>
          <h2>Rythme recommandé</h2>
          <ul>
            <li>Une vérification avant la saison</li>
            <li>Une autre avant l’hivernage</li>
            <li>Un regard prioritaire sur joints, toit et humidité</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="content-section">
      <div class="container body-grid">
        <article class="content-main">
          <div class="content-grid">
            <article class="content-card">
              <h2>Pourquoi deux entretiens par an</h2>
              <p>Le VR subit des variations de température, des UV, de la pluie, du gel et du mouvement sur la route. Deux moments de vérification par année permettent de repérer les joints fatigués, les zones de toiture vulnérables et les premiers signes d’humidité avant que le problème prenne de l’ampleur.</p>
            </article>

            <article class="content-card alt">
              <h2>Au printemps: quoi regarder</h2>
              <ul>
                <li>Les joints de mur et de toit.</li>
                <li>La membrane et les points de scellement.</li>
                <li>Les traces d’eau, d’odeur d’humidité ou de gonflement.</li>
                <li>Les ouvertures sensibles comme fenêtres, évents et raccords.</li>
              </ul>
            </article>

            <article class="content-card">
              <h2>À l’automne: quoi préparer</h2>
              <ul>
                <li>Corriger les joints secs, craqués ou qui décollent.</li>
                <li>Vérifier la toiture avant l’hivernage.</li>
                <li>Confirmer qu’aucune zone n’a commencé à prendre l’eau.</li>
                <li>Faire les reprises utiles avant les mois plus durs.</li>
              </ul>
            </article>

            <article class="content-card alt">
              <h2>Les erreurs fréquentes</h2>
              <p>L’erreur la plus fréquente est d’attendre de voir un gros dommage avant d’agir. L’autre erreur est de regarder seulement l’apparence sans confirmer l’état réel des zones de scellement, de toiture et des ouvertures.</p>
            </article>

            <article class="content-card">
              <h2>Quand demander un entretien plutôt qu’une inspection</h2>
              <p>Quand les joints et la toiture montrent surtout de l’usure normale ou prévisible, l’entretien est souvent la bonne étape. Si vous n’êtes pas certain de la source du problème ou si vous voyez déjà des signes d’humidité, l’inspection peut être plus logique avant d’intervenir.</p>
            </article>

            <article class="content-card">
              <h2>Un rythme simple à retenir</h2>
              <p>Le plus simple est souvent: une vérification au printemps avant la saison et une autre à l’automne avant la période plus rude. Ce rythme aide à garder une lecture claire de l’état du VR tout au long de l’année.</p>
            </article>
          </div>

          <section class="content-card alt faq-section">
            <h2>Questions fréquentes</h2>
            <div class="faq-list">
              {faqs.map((item) => (
                <details class="faq-card">
                  <summary><h3>{item.question}</h3></summary>
                  <p>{item.answer}</p>
                </details>
              ))}
            </div>
          </section>
        </article>

        <aside class="side-panel">
          <div class="side-card side-card-primary">
            <h3>Besoin d'un avis rapide?</h3>
            <p>On peut vous orienter vers une inspection, un entretien ou une réparation selon l'état du véhicule.</p>
            <a class="side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
            <a class="side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">Réserver en ligne</a>
          </div>

          <div class="side-card">
            <h3>Autres services</h3>
            <nav class="service-nav" aria-label="Autres services">
              <a href="/services/inspection/"><i class="fas fa-clipboard-check"></i><span>Inspection</span></a>
              <a href="/services/entretien/"><i class="fas fa-screwdriver-wrench"></i><span>Entretien</span></a>
              <a href="/services/reparation/"><i class="fas fa-toolbox"></i><span>Réparation</span></a>
              <a href="/services/esthetique/"><i class="fas fa-spray-can-sparkles"></i><span>Esthétique VR</span></a>
            </nav>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 32%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #23476f 58%, #f4f6f8 58%, #f4f6f8 100%);
    padding: 4.5rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr);
    gap: 2rem;
    align-items: stretch;
  }

  .hero-copy {
    color: white;
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 1.25rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: var(--brand-gold);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    color: white;
    max-width: 17ch;
    margin-bottom: 1rem;
    line-height: 1.05;
  }

  .lead {
    max-width: 60ch;
    color: #f5f7fa;
    font-size: 1.2rem;
    line-height: 1.7;
  }

  .hero-card {
    align-self: end;
    background: white;
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 22px 44px rgba(16, 35, 56, 0.22);
  }

  .hero-icon {
    width: 4rem;
    height: 4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    background: linear-gradient(135deg, var(--brand-green), #57af49);
    color: white;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .hero-card h2 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .hero-card p {
    color: var(--brand-muted);
    margin-bottom: 1.25rem;
  }

  .hero-card ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--brand-muted);
  }

  .hero-card li + li {
    margin-top: 0.55rem;
  }

  .content-section {
    padding: 4rem 0;
    background:
      linear-gradient(180deg, #ffffff 0%, #ffffff 42%, #f3f5f8 42%, #f3f5f8 100%);
  }

  .body-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr);
    gap: 2rem;
    align-items: start;
  }

  .content-main {
    display: grid;
    gap: 1.5rem;
  }

  .content-grid,
  .faq-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .content-card,
  .faq-card,
  .side-card {
    background: white;
    border-radius: 22px;
    padding: 1.75rem;
    box-shadow: 0 16px 34px rgba(24, 40, 61, 0.08);
  }

  .content-card.alt {
    background: linear-gradient(180deg, #f8fbf5 0%, #ffffff 100%);
  }

  .content-card p,
  .faq-card p,
  .side-card p {
    margin-top: 0.8rem;
    color: var(--brand-muted);
  }

  .content-card h2,
  .side-card h3 {
    margin-bottom: 1rem;
  }

  .content-card ul,
  .content-card ol {
    display: grid;
    gap: 0.85rem;
    padding-left: 1.2rem;
    color: var(--brand-ink);
  }

  .content-card li::marker {
    color: var(--brand-green);
    font-weight: 700;
  }

  .faq-card summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .faq-card summary::-webkit-details-marker {
    display: none;
  }

  .faq-card summary::after {
    content: '+';
    flex: 0 0 auto;
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1;
    color: var(--brand-navy);
  }

  .faq-card[open] summary::after {
    content: '-';
  }

  .faq-card h3 {
    margin: 0;
    font-size: 1rem;
  }

  .faq-section {
    display: grid;
    gap: 1rem;
  }

  .content-card li + li {
    margin-top: 0.45rem;
  }

  .side-panel {
    display: grid;
    gap: 1.5rem;
    position: sticky;
    top: 7rem;
    align-self: start;
  }

  .side-card-primary {
    background: var(--brand-navy-dark);
    color: white;
  }

  .side-card-primary h3 {
    color: white;
  }

  .side-card-primary p {
    color: #dbe4ee;
  }

  .side-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    border-radius: 999px;
    background: var(--brand-gold);
    color: var(--brand-navy-dark);
    font-weight: 700;
    text-decoration: none;
    margin: 0.25rem 0 0.75rem;
  }

  .side-button:hover {
    text-decoration: none;
    background: #e2c417;
  }

  .side-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    background: var(--brand-gold);
    border: 2px solid var(--brand-gold);
    color: var(--brand-navy-dark);
    font-weight: 700;
    text-decoration: none;
  }

  .side-link:hover {
    text-decoration: none;
    background: #e1c317;
    border-color: #e1c317;
  }

  .service-nav {
    display: grid;
    gap: 0.7rem;
  }

  .service-nav a {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    min-height: 54px;
    padding: 0.9rem 1rem;
    border-radius: 16px;
    background: var(--brand-surface);
    color: var(--brand-ink);
    text-decoration: none;
    font-weight: 700;
  }

  .service-nav a:hover {
    text-decoration: none;
    background: #eaf1e6;
  }

  .service-nav i {
    color: var(--brand-green);
  }

  .side-card span {
    font-weight: 700;
    color: var(--brand-navy);
  }

  @media (max-width: 768px) {
    .page-hero {
      background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
      padding: 3.8rem 0 2.8rem;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .content-section {
      padding: 3rem 0;
    }

    .body-grid {
      grid-template-columns: 1fr;
    }

    .side-panel {
      position: static;
    }
  }
</style>
