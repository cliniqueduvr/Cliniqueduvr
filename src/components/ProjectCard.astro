---
export interface Props {
  id: number;
  title: string;
  location: string;
  category: string;
  beforeImage: string;
  afterImage: string;
  beforeAlt: string;
  afterAlt: string;
  description: string;
  lang?: 'fr' | 'en';
}

const { id, title, location, category, beforeImage, afterImage, beforeAlt, afterAlt, description, lang = 'fr' } = Astro.props as Props;
const isEnglish = lang === 'en';
---

<article class="project-card">
  <div class="project-images">
    <figure class="before-image">
      <img src={beforeImage} alt={beforeAlt} loading="lazy" />
      <figcaption>{isEnglish ? 'Before' : 'Avant'}</figcaption>
    </figure>
    <figure class="after-image">
      <img src={afterImage} alt={afterAlt} loading="lazy" />
      <figcaption>{isEnglish ? 'After' : 'Après'}</figcaption>
    </figure>
  </div>

  <div class="project-content">
    <span class="category-badge">{category}</span>
    <h3>{title}</h3>
    <p class="location">
      <i class="fas fa-map-pin"></i> {location}
    </p>
    <p class="description">{description}</p>
  </div>
</article>

<style>
  .project-card {
    background: white;
    border: 1px solid rgba(6, 24, 12, 0.08);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(6, 24, 12, 0.06);
    transition: all 0.3s ease;
    display: grid;
    grid-template-rows: auto 1fr;
  }

  .project-card:hover {
    box-shadow: 0 8px 24px rgba(6, 24, 12, 0.12);
    border-color: rgba(6, 24, 12, 0.12);
    transform: translateY(-4px);
  }

  .project-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    width: 100%;
    height: 250px;
    overflow: hidden;
    background: #f4f7f4;
  }

  figure {
    margin: 0;
    height: 100%;
    overflow: hidden;
    position: relative;
  }

  figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  figcaption {
    position: absolute;
    top: 8px;
    left: 8px;
    background: rgba(23, 63, 105, 0.88);
    color: white;
    padding: 4px 12px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.85rem;
    z-index: 1;
  }

  .project-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .category-badge {
    display: inline-block;
    background: var(--brand-surface);
    color: var(--brand-green-dark);
    padding: 4px 12px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    width: fit-content;
    margin-bottom: 0.5rem;
  }

  .project-card h3 {
    margin: 0;
    font-size: 1.3rem;
    color: var(--brand-navy);
  }

  .location {
    color: var(--brand-muted);
    font-size: 0.9rem;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .location i {
    color: var(--brand-green);
    font-size: 0.85rem;
  }

  .description {
    color: var(--brand-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .project-images {
      height: 200px;
    }

    .project-card h3 {
      font-size: 1.1rem;
    }
  }
</style>
