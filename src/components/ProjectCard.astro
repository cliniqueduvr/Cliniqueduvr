---
export interface Props {
  id: number;
  title: string;
  location: string;
  category: string;
  description: string;
  lang?: 'fr' | 'en';
}

const { id, title, location, category, description, lang = 'fr' } = Astro.props as Props;
---

<article class="project-card">
  <div class="project-content">
    <span class="category-badge">{category}</span>
    <h3>{title}</h3>
    <p class="location">
      <i class="fas fa-map-pin"></i> {location}
    </p>
    <p class="description">{description}</p>
  </div>
</article>

<style>
  .project-card {
    background: white;
    border: 1px solid rgba(6, 24, 12, 0.08);
    border-radius: 1rem;
    box-shadow: 0 4px 12px rgba(6, 24, 12, 0.06);
    transition: all 0.3s ease;
  }

  .project-card:hover {
    box-shadow: 0 8px 24px rgba(6, 24, 12, 0.12);
    border-color: rgba(6, 24, 12, 0.12);
    transform: translateY(-4px);
  }

  .project-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .category-badge {
    display: inline-block;
    background: var(--brand-surface);
    color: var(--brand-green-dark);
    padding: 4px 12px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    width: fit-content;
    margin-bottom: 0.5rem;
  }

  .project-card h3 {
    margin: 0;
    font-size: 1.3rem;
    color: var(--brand-navy);
  }

  .location {
    color: var(--brand-muted);
    font-size: 0.9rem;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .location i {
    color: var(--brand-green);
    font-size: 0.85rem;
  }

  .description {
    color: var(--brand-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
    font-size: 0.95rem;
  }
  @media (max-width: 768px) {
    .project-card h3 {
      font-size: 1.1rem;
    }
  }
</style>
