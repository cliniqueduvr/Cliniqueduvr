---
import siteSettings from '../data/site-settings.json';

interface Props {
  title: string;
  lang?: 'fr' | 'en';
}

const { title, lang = 'fr' } = Astro.props as Props;
const latitude = 45.5073101;
const longitude = -75.5497803;
const popupLabel =
  lang === 'en'
    ? `Clinique du VR<br>${siteSettings.address.en}`
    : `Clinique du VR<br>${siteSettings.address.fr}`;
---

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<div
  class="contact-map"
  data-contact-map
  data-lat={String(latitude)}
  data-lng={String(longitude)}
  data-popup={popupLabel}
  data-title={title}
  data-logo={siteSettings.brandImage}
  aria-label={title}
></div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script is:inline>
  (() => {
    const mapRoot = document.querySelector('[data-contact-map]');
    if (!(mapRoot instanceof HTMLElement) || typeof window === 'undefined') return;

    const initMap = () => {
      const L = window.L;
      if (!L || mapRoot.dataset.mapReady === 'true') return;

      const lat = Number(mapRoot.dataset.lat);
      const lng = Number(mapRoot.dataset.lng);
      const popup = mapRoot.dataset.popup || '';
      const logo = mapRoot.dataset.logo || '';

      const map = L.map(mapRoot, {
        center: [lat, lng],
        zoom: 16,
        scrollWheelZoom: false
      });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        maxZoom: 19,
        subdomains: 'abcd',
        attribution: '&copy; OpenStreetMap contributors &copy; CARTO'
      }).addTo(map);

      const logoIcon = L.divIcon({
        className: 'contact-map-marker',
        html: `<div class="contact-map-marker__pin"><img src="${logo}" alt="Clinique du VR" /></div>`,
        iconSize: [76, 76],
        iconAnchor: [38, 68],
        popupAnchor: [0, -58]
      });

      L.marker([lat, lng], { icon: logoIcon }).addTo(map).bindPopup(popup);
      mapRoot.dataset.mapReady = 'true';
    };

    if (window.L) {
      initMap();
    } else {
      window.addEventListener('load', initMap, { once: true });
    }
  })();
</script>

<style>
  .contact-map {
    width: 100%;
    height: 400px;
    border: 0;
    overflow: hidden;
  }

  :global(.contact-map-marker) {
    background: transparent;
    border: 0;
  }

  :global(.contact-map-marker__pin) {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: white;
    border: 4px solid var(--brand-gold);
    box-shadow: 0 14px 28px rgba(20, 36, 55, 0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  :global(.contact-map-marker__pin::after) {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -14px;
    width: 22px;
    height: 22px;
    background: white;
    border-right: 4px solid var(--brand-gold);
    border-bottom: 4px solid var(--brand-gold);
    transform: translateX(-50%) rotate(45deg);
    border-bottom-right-radius: 4px;
  }

  :global(.contact-map-marker__pin img) {
    width: 52px;
    height: 52px;
    object-fit: contain;
    border-radius: 50%;
  }
</style>
