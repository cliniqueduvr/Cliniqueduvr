---
import CTABanner from './CTABanner.astro';
import type { LocalAreaPage } from '../data/local-area-pages';

interface Props {
  page: LocalAreaPage;
  lang?: 'fr' | 'en';
}

const { page, lang = 'fr' } = Astro.props as Props;
const isEnglish = lang === 'en';
---

<main>
  <section class="page-header">
    <div class="container">
      <p class="eyebrow">{page.eyebrow}</p>
      <h1>{page.h1}</h1>
      <p class="intro">{page.intro}</p>
      <p class="lead">{page.lead}</p>
      <div class="highlight-grid">
        {page.highlights.map((item) => (
          <span>{item}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container card-grid">
      {page.sections.map((section) => (
        <article class="info-card">
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <h2>{isEnglish ? 'Frequently asked questions' : 'Questions fréquentes'}</h2>
      <div class="faq-list">
        {page.faqs.map((item) => (
          <article class="faq-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="links-section">
    <div class="container card-grid">
      {page.links.map((item) => (
        <a class="info-card info-link" href={item.href}>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <span>{item.linkLabel}</span>
        </a>
      ))}
    </div>
  </section>

  <CTABanner
    lang={lang}
    heading={isEnglish ? `Need help in ${page.area}?` : `Besoin d'aide en ${page.area}?`}
    subheading={isEnglish ? 'Describe your vehicle and the issue you are seeing. We will point you to the right next step.' : 'Décrivez votre véhicule et le problème observé. Nous vous orienterons vers la bonne prochaine étape.'}
    squareLabel={isEnglish ? 'Book now' : 'Réserver en ligne'}
  />
</main>

<style>
  .page-header {
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 25%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #1f476d 58%, #eef3f7 58%, #eef3f7 100%);
    color: white;
    padding: 4.5rem 0 3.8rem;
  }

  .eyebrow {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: var(--brand-gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-header h1 {
    color: white;
    margin-bottom: 0.75rem;
    font-size: 3rem;
    max-width: 14ch;
  }

  .intro {
    max-width: 62ch;
    color: #e7edf4;
    font-size: 1.08rem;
    margin-bottom: 1rem;
  }

  .lead {
    max-width: 62ch;
    color: #dbe4ee;
  }

  .highlight-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  .highlight-grid span {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.75rem 1rem;
    border-radius: 14px;
    background: var(--brand-gold);
    border: 1px solid var(--brand-gold);
    color: var(--brand-navy-dark);
    font-weight: 700;
  }

  .content-section,
  .faq-section,
  .links-section {
    padding: 4rem 0;
    background: #f3f5f8;
  }

  .faq-section,
  .links-section {
    padding-top: 0;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .info-card,
  .faq-card {
    background: white;
    border-radius: 22px;
    padding: 1.6rem;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.08);
  }

  .info-card h2,
  .faq-card h3 {
    margin: 0 0 0.75rem;
    color: var(--brand-navy);
  }

  .info-card p,
  .faq-card p {
    margin: 0;
    color: var(--brand-muted);
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .info-link {
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 0.75rem;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .info-link:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: 0 24px 44px rgba(21, 38, 58, 0.14);
  }

  .info-link span {
    align-self: end;
    color: var(--brand-navy);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .page-header {
      background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
      padding: 3.6rem 0 3rem;
    }

    .page-header h1 {
      font-size: 2.2rem;
      max-width: none;
    }

    .content-section,
    .faq-section,
    .links-section {
      padding: 3rem 0;
      background: #f3f5f8;
    }

    .faq-section,
    .links-section {
      padding-top: 0;
    }
  }
</style>
