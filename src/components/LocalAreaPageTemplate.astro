---
import siteSettings from '../data/site-settings.json';
import type { LocalAreaPage } from '../data/local-area-pages';

interface Props {
  page: LocalAreaPage;
  lang?: 'fr' | 'en';
}

const { page, lang = 'fr' } = Astro.props as Props;
const isEnglish = lang === 'en';
const contactHref = isEnglish ? '/en/contact/' : '/contact/';
const faqHref = isEnglish ? '/en/faq/' : '/faq/';
const chooseServiceHref = isEnglish ? '/en/choose-service/' : '/choisir-service/';
const serviceAreasHref = isEnglish ? '/en/service-areas/' : '/zones-desservies/';
const projectsHref = isEnglish ? '/en/realisations/' : '/realisations/';
const servicesHref = isEnglish ? '/en/services/' : '/services/';

const quickAnswerTitle = isEnglish ? `Do you help in ${page.area}?` : `Intervenez-vous pour ${page.area} ?`;
const quickAnswerBody = isEnglish
  ? `Yes. Clinique du VR helps clients in ${page.area} from its Gatineau workshop and points each request toward inspection, maintenance, or repair depending on the actual condition of the RV or trailer.`
  : `Oui. Clinique du VR accompagne les demandes venant de ${page.area} à partir de son atelier de Gatineau et oriente chaque dossier vers une inspection, un entretien ou une réparation selon l’état réel du VR ou de la roulotte.`;

const practicalBlocks = isEnglish
  ? [
      {
        title: `Why this ${page.area} page is useful`,
        body: `This page answers the local question directly: what to do when the need is tied to ${page.area} and the issue involves moisture, seals, roof condition, inspection, maintenance, or repair.`
      },
      {
        title: 'What to prepare before contacting us',
        body: 'The most useful starting point is a short summary of the problem, a few photos, the vehicle type, and whether the issue is still a doubt or already visible damage.'
      },
      {
        title: 'Workshop in Gatineau, then the right next step',
        body: `Clients from ${page.area} often need the same thing first: clarity. The goal is to avoid booking the wrong service and move directly toward the useful next step.`
      }
    ]
  : [
      {
        title: `Pourquoi cette page locale pour ${page.area}`,
        body: `Cette page sert à répondre clairement à la question locale: quoi faire quand le besoin est lié à ${page.area} et que le problème touche l’humidité, les joints, la toiture, l’inspection, l’entretien ou la réparation.`
      },
      {
        title: 'Quoi préparer avant de nous écrire',
        body: "Le point de départ le plus utile est souvent une courte description du problème, quelques photos, le type de véhicule et le fait que le souci soit encore un doute ou déjà un dommage visible."
      },
      {
        title: "Atelier à Gatineau, bonne prochaine étape ensuite",
        body: `Les clients de ${page.area} ont souvent le même besoin au départ: obtenir une lecture claire de la situation. L’objectif est d’éviter de réserver le mauvais service et d’aller directement vers l’étape utile.`
      }
    ];

const decisionSteps = isEnglish
  ? [
      'Describe the issue, city, and vehicle type.',
      'Confirm whether the need sounds like inspection, maintenance, or repair.',
      'Move to the most useful next page or contact the workshop.'
    ]
  : [
      'Décrire le problème, la ville et le type de véhicule.',
      'Confirmer si le besoin ressemble surtout à une inspection, un entretien ou une réparation.',
      "Passer vers la page la plus utile ou contacter l’atelier."
    ];

const supportLinks = isEnglish
  ? [
      { href: chooseServiceHref, title: 'Which service should you choose?', body: 'Use the decision page if you are still hesitating between inspection, maintenance, or repair.' },
      { href: faqHref, title: 'Read the FAQ', body: 'See common questions about water leaks, maintenance timing, and service-area realities.' },
      { href: serviceAreasHref, title: 'Browse all service areas', body: 'Compare the local pages and see how Gatineau, Ottawa, Outaouais, and the Laurentides are covered.' },
      { href: projectsHref, title: 'Review real project examples', body: 'Check real workshop interventions before booking if you want more context.' }
    ]
  : [
      { href: chooseServiceHref, title: 'Quel service choisir ?', body: "Utilisez la page d’orientation si vous hésitez encore entre inspection, entretien ou réparation." },
      { href: faqHref, title: 'Lire la FAQ', body: "Consultez les questions fréquentes sur les fuites d’eau, l’entretien et les réalités des zones desservies." },
      { href: serviceAreasHref, title: 'Voir toutes les zones desservies', body: "Comparez les pages locales et voyez comment Gatineau, Ottawa, l’Outaouais et les Laurentides sont couverts." },
      { href: projectsHref, title: 'Voir des cas réels', body: "Consultez des interventions réelles avant de réserver si vous voulez plus de contexte." }
    ];

const localServiceLinks = isEnglish
  ? page.slug.includes('maintenance')
    ? [
        { href: '/en/services/maintenance/', icon: 'fas fa-screwdriver-wrench', label: 'Maintenance' },
        { href: '/en/services/inspection/', icon: 'fas fa-clipboard-check', label: 'Inspection' },
        { href: '/en/services/repair/', icon: 'fas fa-toolbox', label: 'Repair' },
        { href: '/en/services/', icon: 'fas fa-list', label: 'All services' }
      ]
    : page.slug.includes('repair') || page.slug.includes('water')
      ? [
          { href: '/en/services/inspection/', icon: 'fas fa-clipboard-check', label: 'Inspection' },
          { href: '/en/services/repair/', icon: 'fas fa-toolbox', label: 'Repair' },
          { href: '/en/resources/rv-water-intrusion/', icon: 'fas fa-droplet', label: 'Water intrusion' },
          { href: '/en/services/', icon: 'fas fa-list', label: 'All services' }
        ]
      : [
          { href: '/en/services/inspection/', icon: 'fas fa-clipboard-check', label: 'Inspection' },
          { href: '/en/services/maintenance/', icon: 'fas fa-screwdriver-wrench', label: 'Maintenance' },
          { href: '/en/services/repair/', icon: 'fas fa-toolbox', label: 'Repair' },
          { href: '/en/services/', icon: 'fas fa-list', label: 'All services' }
        ]
  : page.slug.includes('entretien')
    ? [
        { href: '/services/entretien/', icon: 'fas fa-screwdriver-wrench', label: 'Entretien' },
        { href: '/services/inspection/', icon: 'fas fa-clipboard-check', label: 'Inspection' },
        { href: '/services/reparation/', icon: 'fas fa-toolbox', label: 'Réparation' },
        { href: '/services/', icon: 'fas fa-list', label: 'Tous les services' }
      ]
    : page.slug.includes('reparation') || page.slug.includes('fuite') || page.slug.includes('infiltration')
      ? [
          { href: '/services/inspection/', icon: 'fas fa-clipboard-check', label: 'Inspection' },
          { href: '/services/reparation/', icon: 'fas fa-toolbox', label: 'Réparation' },
          { href: '/ressources/infiltration-eau-vr/', icon: 'fas fa-droplet', label: "Infiltration d'eau" },
          { href: '/services/', icon: 'fas fa-list', label: 'Tous les services' }
        ]
      : [
          { href: '/services/inspection/', icon: 'fas fa-clipboard-check', label: 'Inspection' },
          { href: '/services/entretien/', icon: 'fas fa-screwdriver-wrench', label: 'Entretien' },
          { href: '/services/reparation/', icon: 'fas fa-toolbox', label: 'Réparation' },
          { href: '/services/', icon: 'fas fa-list', label: 'Tous les services' }
        ];
---

<main>
  <section class="page-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{page.eyebrow}</p>
        <h1>{page.h1}</h1>
        <p class="intro">{page.intro}</p>
        <p class="lead">{page.lead}</p>

        <div class="hero-badges">
          {page.highlights.map((item) => (
            <span>{item}</span>
          ))}
        </div>
      </div>

      <aside class="hero-card">
        <div class="hero-icon">
          <i class="fas fa-map-location-dot"></i>
        </div>
        <h2>{quickAnswerTitle}</h2>
        <p>{quickAnswerBody}</p>
        <a class="hero-link" href={contactHref}>{isEnglish ? 'Talk to us about your RV' : 'Parler de votre VR'}</a>
      </aside>
    </div>
  </section>

  <section class="service-body">
    <div class="container body-grid">
      <article class="service-main">
        {page.sections.map((section, index) => (
          <section class:list={['content-card', index % 2 === 1 && 'alt']}>
            <h2>{section.title}</h2>
            <p class="section-copy">{section.body}</p>
          </section>
        ))}

        {practicalBlocks.map((section, index) => (
          <section class:list={['content-card', index % 2 === 0 && 'alt']}>
            <h2>{section.title}</h2>
            <p class="section-copy">{section.body}</p>
          </section>
        ))}

        <section class="content-card">
          <h2>{isEnglish ? 'A simple local decision path' : 'Un parcours local simple'}</h2>
          <ol>
            {decisionSteps.map((step) => (
              <li>{step}</li>
            ))}
          </ol>
        </section>

        <section class="content-card alt">
          <h2>{isEnglish ? 'Useful pages before you decide' : 'Pages utiles avant de décider'}</h2>
          <div class="link-card-grid">
            {page.links.map((item) => (
              <a class="link-card link-card-anchor" href={item.href}>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
                <span>{item.linkLabel}</span>
              </a>
            ))}
            {supportLinks.map((item) => (
              <a class="link-card link-card-anchor" href={item.href}>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
                <span>{isEnglish ? 'Learn more' : 'En savoir plus'}</span>
              </a>
            ))}
          </div>
        </section>

        <section class="content-card faq-section">
          <h2>{isEnglish ? 'Frequently asked questions' : 'Questions fréquentes'}</h2>
          <div class="faq-list">
            {page.faqs.map((item) => (
              <details class="faq-item">
                <summary><h3>{item.question}</h3></summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      </article>

      <aside class="service-side sticky">
        <div class="side-card side-card-primary">
          <h3>{isEnglish ? 'Need a clear next step?' : "Besoin d'une prochaine étape claire ?"}</h3>
          <p>{isEnglish ? `If your request comes from ${page.area}, the fastest route is to send a few photos and a short summary of the issue.` : `Si votre demande vient de ${page.area}, le plus rapide est d’envoyer quelques photos et un court résumé du problème.`}</p>
          <a class="side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
          <a class="side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">{isEnglish ? 'Book online' : 'Réserver en ligne'}</a>
        </div>

        <div class="side-card">
          <h3>{isEnglish ? 'Related services' : 'Services liés'}</h3>
          <nav class="service-nav" aria-label={isEnglish ? 'Related services' : 'Services liés'}>
            {localServiceLinks.map((item) => (
              <a href={item.href}>
                <i class={item.icon}></i>
                <span>{item.label}</span>
              </a>
            ))}
          </nav>
        </div>

        <div class="side-card">
          <h3>{isEnglish ? 'Other useful pages' : 'Autres pages utiles'}</h3>
          <nav class="service-nav" aria-label={isEnglish ? 'Other useful pages' : 'Autres pages utiles'}>
            <a href={chooseServiceHref}><i class="fas fa-route"></i><span>{isEnglish ? 'Choose a service' : 'Choisir un service'}</span></a>
            <a href={faqHref}><i class="fas fa-circle-question"></i><span>FAQ</span></a>
            <a href={serviceAreasHref}><i class="fas fa-map"></i><span>{isEnglish ? 'Service areas' : 'Zones desservies'}</span></a>
            <a href={projectsHref}><i class="fas fa-images"></i><span>{isEnglish ? 'Real projects' : 'Cas réels'}</span></a>
          </nav>
        </div>
      </aside>
    </div>
  </section>
</main>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 32%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #23476f 58%, #f4f6f8 58%, #f4f6f8 100%);
    padding: 4.5rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr);
    gap: 2rem;
    align-items: stretch;
  }

  .hero-copy {
    color: white;
  }

  .eyebrow {
    display: inline-flex;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: var(--brand-gold);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .hero-copy h1 {
    max-width: 18ch;
    margin-bottom: 1rem;
    color: white;
    line-height: 1.05;
  }

  .intro {
    max-width: 62ch;
    font-size: 1.08rem;
    color: #e7edf4;
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.06rem;
    line-height: 1.7;
    color: #dbe4ee;
    max-width: 60ch;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.75rem;
  }

  .hero-badges span {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.75rem 1rem;
    border-radius: 14px;
    background: var(--brand-gold);
    border: 1px solid var(--brand-gold);
    color: var(--brand-navy-dark);
    font-weight: 700;
    box-shadow: 0 10px 18px rgba(14, 31, 49, 0.14);
  }

  .hero-card {
    align-self: end;
    background: white;
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 22px 44px rgba(16, 35, 56, 0.22);
  }

  .hero-icon {
    width: 4rem;
    height: 4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    background: linear-gradient(135deg, var(--brand-green), #57af49);
    color: white;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .hero-card h2 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .hero-card p {
    color: var(--brand-muted);
    margin-bottom: 1.25rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    background: var(--brand-navy);
    color: white;
    font-weight: 700;
    text-decoration: none;
  }

  .hero-link:hover {
    text-decoration: none;
    background: var(--brand-navy-dark);
  }

  .service-body {
    padding: 4rem 0;
    background:
      linear-gradient(180deg, #ffffff 0%, #ffffff 42%, #f3f5f8 42%, #f3f5f8 100%);
  }

  .body-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr);
    gap: 2rem;
    align-items: start;
  }

  .service-main,
  .service-side {
    display: grid;
    gap: 1.5rem;
  }

  .content-card,
  .side-card {
    background: white;
    border-radius: 22px;
    padding: 1.75rem;
    box-shadow: 0 16px 34px rgba(24, 40, 61, 0.08);
  }

  .content-card.alt {
    background: linear-gradient(180deg, #f8fbf5 0%, #ffffff 100%);
  }

  .content-card h2,
  .side-card h3 {
    margin-bottom: 1rem;
  }

  .section-copy {
    color: var(--brand-muted);
  }

  .content-card ol {
    display: grid;
    gap: 0.85rem;
    padding-left: 1.2rem;
    color: var(--brand-ink);
  }

  .content-card li::marker {
    color: var(--brand-green);
    font-weight: 700;
  }

  .link-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .link-card {
    background: var(--brand-surface);
    border-radius: 16px;
    padding: 1rem;
  }

  .link-card-anchor {
    display: grid;
    gap: 0.55rem;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .link-card-anchor:hover {
    text-decoration: none;
    transform: translateY(-2px);
    background: #eaf1e6;
    box-shadow: 0 12px 24px rgba(21, 38, 58, 0.08);
  }

  .link-card h3,
  .faq-item h3 {
    font-size: 1rem;
    margin-bottom: 0.45rem;
  }

  .link-card p,
  .faq-item p {
    color: var(--brand-muted);
  }

  .link-card span {
    color: var(--brand-navy);
    font-weight: 700;
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .faq-item {
    border-bottom: 1px solid rgba(31, 58, 95, 0.08);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 0 1rem;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    flex: 0 0 auto;
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1;
    color: var(--brand-navy);
  }

  .faq-item[open] summary::after {
    content: '-';
  }

  .faq-item[open] summary {
    padding-bottom: 0.7rem;
  }

  .sticky {
    position: sticky;
    top: 7rem;
    align-self: start;
  }

  .side-card-primary {
    background: var(--brand-navy-dark);
    color: white;
  }

  .side-card-primary h3 {
    color: white;
  }

  .side-card-primary p {
    color: #dbe4ee;
  }

  .side-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    border-radius: 999px;
    background: var(--brand-gold);
    color: var(--brand-navy-dark);
    font-weight: 700;
    text-decoration: none;
    margin: 0.25rem 0 0.75rem;
  }

  .side-button:hover {
    text-decoration: none;
    background: #e2c417;
  }

  .side-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    background: var(--brand-gold);
    border: 2px solid var(--brand-gold);
    color: var(--brand-navy-dark);
    font-weight: 700;
    text-decoration: none;
  }

  .side-link:hover {
    text-decoration: none;
    background: #e1c317;
    border-color: #e1c317;
  }

  .service-nav {
    display: grid;
    gap: 0.7rem;
  }

  .service-nav a {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    min-height: 54px;
    padding: 0.9rem 1rem;
    border-radius: 16px;
    background: var(--brand-surface);
    color: var(--brand-ink);
    text-decoration: none;
    font-weight: 700;
  }

  .service-nav a:hover {
    text-decoration: none;
    background: #eaf1e6;
  }

  .service-nav i {
    color: var(--brand-green);
  }

  @media (max-width: 920px) {
    .hero-grid,
    .body-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      max-width: none;
    }

    .sticky {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 2.6rem 0 2.2rem;
      background:
        radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 38%),
        linear-gradient(180deg, var(--brand-navy-dark) 0%, #23476f 100%);
    }

    .eyebrow {
      margin-bottom: 0.85rem;
      font-size: 0.74rem;
    }

    .intro,
    .lead {
      font-size: 0.96rem;
      line-height: 1.55;
    }

    .hero-badges {
      gap: 0.55rem;
      margin-top: 1.15rem;
    }

    .hero-badges span {
      min-height: 38px;
      padding: 0.55rem 0.8rem;
      border-radius: 12px;
      font-size: 0.88rem;
    }

    .hero-badges span:nth-child(n+3) {
      display: none;
    }

    .service-body {
      padding: 2.35rem 0;
      background: #f3f5f8;
    }

    .content-card,
    .side-card,
    .hero-card {
      border-radius: 16px;
      padding: 1.05rem;
      box-shadow: 0 10px 24px rgba(24, 40, 61, 0.08);
    }

    .service-main,
    .service-side,
    .faq-list,
    .link-card-grid {
      gap: 0.9rem;
    }

    .content-card h2,
    .side-card h3 {
      margin-bottom: 0.75rem;
    }

    .content-card ol {
      gap: 0.65rem;
    }

    .link-card {
      padding: 0.85rem;
      border-radius: 14px;
    }

    .service-nav {
      gap: 0.55rem;
    }

    .service-nav a {
      min-height: 48px;
      padding: 0.7rem 0.85rem;
      border-radius: 14px;
      font-size: 0.94rem;
    }

    .side-button,
    .side-link,
    .hero-link {
      min-height: 44px;
      padding: 0.7rem 0.9rem;
      font-size: 0.95rem;
    }
  }
</style>
