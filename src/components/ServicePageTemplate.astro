---
import siteSettings from '../data/site-settings.json';
import type { ServicePage } from '../data/service-page-types';

interface Props {
  service: ServicePage;
  allServices: ServicePage[];
  lang?: 'fr' | 'en';
}

const { service, allServices, lang = 'fr' } = Astro.props as Props;
const otherServices = allServices.filter((item) => item.slug !== service.slug && item.slug !== 'vente-achat' && item.slug !== 'buying-selling');
const isEnglish = lang === 'en';
const contactHref = isEnglish ? '/en/contact/' : '/contact/';
const chooseServiceHref = isEnglish ? '/en/choose-service/' : '/choisir-service/';
const projectsHref = isEnglish ? '/en/realisations/' : '/realisations/';
const inspectionHref = isEnglish ? '/en/services/inspection/' : '/services/inspection/';
const servicesHref = isEnglish ? '/en/services/' : '/services/';
const serviceHref = (slug: string) => isEnglish ? `/en/services/${slug}/` : `/services/${slug}/`;
const localGuide = isEnglish
  ? service.slug === 'inspection' || service.slug === 'repair'
    ? {
        href: '/en/areas/rv-water-leak-gatineau/',
        title: 'RV water leak in Gatineau',
        copy: 'Visit the local page focused on water leaks, moisture, seals, and the right next step in Gatineau.'
      }
    : service.slug === 'maintenance'
      ? {
          href: '/en/areas/rv-maintenance-gatineau/',
          title: 'RV maintenance in Gatineau',
          copy: 'Use the local maintenance page if your main need is seal, roof, or membrane care in Gatineau.'
        }
      : null
  : service.slug === 'inspection' || service.slug === 'reparation'
    ? {
        href: '/zones/fuite-eau-vr-gatineau/',
        title: "Fuite d'eau de VR à Gatineau",
        copy: "Consultez la page locale dédiée si votre priorité est une fuite d'eau, l'humidité ou des joints suspects à Gatineau."
      }
    : service.slug === 'entretien'
      ? {
          href: '/zones/entretien-vr-gatineau/',
          title: 'Entretien de VR à Gatineau',
          copy: "Utilisez la page locale d'entretien si votre besoin principal touche les joints, la toiture ou la membrane à Gatineau."
        }
      : null;
const serviceAreas = isEnglish
  ? ['Outaouais', 'Ottawa', 'Laurentides']
  : ['Outaouais', 'Ottawa', 'Laurentides'];
const baseHelpfulLinks = isEnglish
  ? [
      {
        href: contactHref,
        title: 'Contact us about your RV',
        copy: 'Describe the issue, the vehicle, and your situation to get the right next step.'
      },
      {
        href: projectsHref,
        title: 'See real workshop projects',
        copy: 'Browse examples of repairs, restoration work, and before-and-after improvements.'
      },
      {
        href: inspectionHref,
        title: 'Inspection before buying or selling',
        copy: 'If your situation involves a transaction, start with the inspection section to clarify the real condition of the vehicle.'
      },
      {
        href: chooseServiceHref,
        title: 'Which service fits best?',
        copy: 'Use our guidance page if you are not sure whether you need inspection, maintenance, repair, or detailing.'
      },
      {
        href: servicesHref,
        title: 'Compare our other services',
        copy: 'If this service is close but not exact, review the full list to choose the best fit.'
      }
    ]
  : [
      {
        href: contactHref,
        title: 'Parlez-nous de votre VR',
        copy: 'Décrivez le problème, le véhicule et votre situation pour obtenir la bonne prochaine étape.'
      },
      {
        href: projectsHref,
        title: 'Voir des interventions réelles',
        copy: 'Consultez des exemples de réparations, de remises en état et d’améliorations avant-après.'
      },
      {
        href: inspectionHref,
        title: 'Inspection avant achat ou vente',
        copy: 'Si votre situation touche une transaction, commencez par la section inspection pour clarifier l’état réel du véhicule.'
      },
      {
        href: chooseServiceHref,
        title: 'Quel service choisir ?',
        copy: 'Utilisez notre page d’orientation si vous hésitez entre inspection, entretien, réparation ou esthétique.'
      },
      {
        href: servicesHref,
        title: 'Comparer les autres services',
        copy: 'Si ce service est proche de votre besoin sans être exact, parcourez la liste complète.'
      }
    ];
const helpfulLinks = [...(localGuide ? [localGuide] : []), ...baseHelpfulLinks];
const isWorkshopOnlyDetailing = service.slug === 'esthetique-auto-camion' || service.slug === 'auto-truck-detailing';
const proofStats = service.proofStats ?? [];
const proofPoints = service.proofPoints ?? [];
const caseStudies = service.caseStudies ?? [];
const fallbackProofContent = isEnglish
  ? ({
      inspection: {
        title: 'Why this inspection is often the best first move',
        intro: 'When the source of a leak is still unclear, the most expensive mistake is usually waiting or booking the wrong type of work first.',
        stats: [
          { value: '$49.99', label: 'Workshop inspection' },
          { value: '$149.99', label: 'Mobile inspection within 40 km' },
          { value: 'Moisture meter', label: 'Included to support visual findings' }
        ],
        points: [
          { title: 'Quick to trigger', text: 'It gives you a useful answer fast when the issue still looks like a doubt rather than a confirmed repair file.' },
          { title: 'Cost-oriented', text: 'Catching water early can keep a tired seal from turning into walls, flooring, or interior rebuild work.' },
          { title: 'Clear next step', text: 'It helps separate inspection, maintenance, and repair instead of blending them together.' }
        ]
      },
      maintenance: {
        title: 'What good maintenance protects',
        intro: 'Maintenance is not cosmetic spending. It is what keeps water out and avoids the roof, wall, and flooring files that start with tired sealing points.',
        stats: [
          { value: '2x / year', label: 'Recommended rhythm before and after the season' },
          { value: 'Wall + roof', label: 'Seals and exposed areas covered' },
          { value: 'Workshop or mobile', label: 'Depending on the assignment' }
        ],
        points: [
          { title: 'Prevention before repair', text: 'Working on seals at the right time usually costs far less than opening a real water-damage file later.' },
          { title: 'Roof-first logic', text: 'Roof surfaces, openings, and membranes are among the first areas where prevention pays off.' },
          { title: 'Better seasonal timing', text: 'Maintenance reduces last-minute surprises before travel or after storage.' }
        ]
      },
      repair: {
        title: 'What matters in a real water-damage repair',
        intro: 'A real repair is more than making a surface look better. It starts with the source, treats the affected materials, and restores the vehicle in a credible way.',
        stats: [
          { value: 'Roof to floor', label: 'Work on the areas affected by water' },
          { value: 'Insurance or private', label: 'Approach adjusted to your file' },
          { value: 'Source first', label: 'Diagnosis before rebuild work' }
        ],
        points: [
          { title: 'Cause before cosmetics', text: 'The goal is to avoid closing a damaged area without really addressing where the water came from.' },
          { title: 'Materials treated as a whole', text: 'Roof, walls, flooring, coverings, and interior sections often have to be understood together.' },
          { title: 'Clearer repair logic', text: 'You get a more defensible path for private work or for an insurance-backed file.' }
        ]
      },
      detailing: {
        title: 'What a real RV detailing service should improve',
        intro: 'This page is not just about washing a large vehicle. It is about presentation, gloss, and a finish that actually looks more sale-ready and better cared for.',
        stats: [
          { value: 'Interior + exterior', label: 'Cleaning built around RV size and surfaces' },
          { value: 'Polish + wax', label: 'Visual improvement and finish enhancement' },
          { value: 'Workshop or mobile', label: 'Depending on access and assignment' }
        ],
        points: [
          { title: 'Built for larger formats', text: 'RVs and motorhomes need a different approach than small-vehicle detailing.' },
          { title: 'Useful before sale or season', text: 'This service is strongest when the goal is a cleaner, brighter, more credible presentation.' },
          { title: 'Clearer finish quality', text: 'Polishing and waxing help move the vehicle beyond a simple rinse or surface clean.' }
        ]
      },
      'auto-truck-detailing': {
        title: 'Why this separate workshop-only detailing page matters',
        intro: 'Keeping auto and truck detailing separate from RV detailing makes the offer easier to understand and keeps the workshop standard more consistent.',
        stats: [
          { value: 'Workshop only', label: 'Controlled execution conditions' },
          { value: 'Auto + truck', label: 'Dedicated offer, not mixed with RV work' },
          { value: 'Polish + finish', label: 'Focused on visible presentation' }
        ],
        points: [
          { title: 'Cleaner scope', text: 'Clients immediately know this page is dedicated to cars and trucks only.' },
          { title: 'More consistent finish', text: 'Workshop conditions help control the detailing result more tightly.' },
          { title: 'Better page clarity', text: 'Separating the offers avoids confusion between vehicle types and service expectations.' }
        ]
      },
      'buying-selling': {
        title: 'What makes this service valuable before a transaction',
        intro: 'Buying and selling decisions are easier when the vehicle condition is clearer, the priorities are identified, and the presentation is more credible.',
        stats: [
          { value: 'Buyer or seller', label: 'Support adapted to the transaction side' },
          { value: 'Inspection + prep', label: 'Useful before listing or before purchase' },
          { value: 'Priority fixes', label: 'Focus on the most useful corrections first' }
        ],
        points: [
          { title: 'Better price logic', text: 'A more clearly documented vehicle is easier to price, defend, or negotiate.' },
          { title: 'Less guesswork', text: 'It helps separate cosmetic work from real structural or water-related concerns.' },
          { title: 'Clearer next step', text: 'You can decide more rationally whether to repair, buy, sell, or postpone.' }
        ]
      }
    } as const)[service.slug]
  : ({
      inspection: {
        title: 'Pourquoi cette inspection est souvent la meilleure première étape',
        intro: "Quand la source d'une fuite n'est pas claire, l'erreur la plus coûteuse est souvent d'attendre ou de réserver le mauvais type de travail en premier.",
        stats: [
          { value: '49,99 $', label: 'Inspection en atelier' },
          { value: '149,99 $', label: 'Inspection mobile dans 40 km' },
          { value: 'Humidimètre', label: 'Inclus pour appuyer le constat visuel' }
        ],
        points: [
          { title: 'Rapide à déclencher', text: "Elle donne une réponse utile rapidement quand le problème ressemble encore à un doute plutôt qu'à un vrai dossier de réparation." },
          { title: 'Orientée coût évité', text: "Repérer l'eau tôt évite qu'un joint fatigué devienne un mur, un plancher ou une reprise intérieure." },
          { title: 'Bonne prochaine étape', text: "Elle aide à séparer inspection, entretien et réparation au lieu de tout mélanger." }
        ]
      },
      entretien: {
        title: 'Ce que protège un bon entretien',
        intro: "L'entretien n'est pas une dépense cosmétique. C'est ce qui garde l'eau à l'extérieur et ce qui évite les dossiers de toiture, de murs et de plancher.",
        stats: [
          { value: '2x / an', label: 'Rythme recommandé avant et après saison' },
          { value: 'Mur + toit', label: 'Joints et zones exposées traités' },
          { value: 'Atelier ou mobile', label: "Selon le type d'intervention" }
        ],
        points: [
          { title: 'Prévenir avant réparer', text: "Reprendre les joints au bon moment coûte souvent bien moins qu'un vrai dossier de dommages d'eau." },
          { title: 'Logique toit en premier', text: 'Toiture, ouvertures et membrane font partie des zones où la prévention paie le plus.' },
          { title: 'Meilleur rythme de saison', text: "L'entretien réduit les mauvaises surprises juste avant les voyages ou après l'entreposage." }
        ]
      },
      reparation: {
        title: "Ce qui compte dans une vraie réparation d'infiltration",
        intro: "Une vraie réparation ne consiste pas seulement à améliorer l'apparence d'une surface. Elle part de la source, traite les matériaux touchés et remet le véhicule dans un état crédible.",
        stats: [
          { value: 'Toit à plancher', label: "Intervention sur les zones touchées par l'eau" },
          { value: 'Assurance ou privé', label: 'Approche adaptée à votre dossier' },
          { value: 'Source en premier', label: 'Diagnostic avant reconstruction' }
        ],
        points: [
          { title: 'Cause avant cosmétique', text: "Le but est d'éviter de refermer une zone touchée sans traiter la vraie origine de l'eau." },
          { title: 'Matériaux vus ensemble', text: 'Toit, murs, plancher, revêtements et sections intérieures doivent souvent être compris ensemble.' },
          { title: 'Démarche plus claire', text: "Vous obtenez une logique de réparation plus défendable, en privé comme en assurance." }
        ]
      },
      esthetique: {
        title: "Ce qu'un vrai service d'esthétique VR doit améliorer",
        intro: "Cette page ne sert pas à promettre un simple lavage. Elle sert à montrer une amélioration visuelle nette, une meilleure brillance et une présentation plus crédible du véhicule.",
        stats: [
          { value: 'Intérieur + extérieur', label: 'Nettoyage pensé pour les grands formats' },
          { value: 'Polissage + cirage', label: 'Mise en valeur et finition' },
          { value: 'Atelier ou route', label: 'Selon le véhicule et le mandat' }
        ],
        points: [
          { title: 'Pensé pour les grands formats', text: 'Un VR ou un motorisé demande une approche différente de celle d’un petit véhicule.' },
          { title: 'Utile avant vente ou saison', text: 'Le service prend sa valeur quand le but est une présentation plus propre, brillante et crédible.' },
          { title: 'Finition plus nette', text: 'Polissage et cirage permettent d’aller plus loin qu’un simple nettoyage de surface.' }
        ]
      },
      'esthetique-auto-camion': {
        title: "Pourquoi cette page atelier seulement est utile",
        intro: "Séparer l'offre auto et camion de l'offre VR rend le service plus clair et permet de garder un standard d'exécution plus constant en atelier.",
        stats: [
          { value: 'Atelier seulement', label: "Conditions d'exécution contrôlées" },
          { value: 'Auto + camion', label: 'Offre dédiée, séparée des VR' },
          { value: 'Polissage + finition', label: 'Accent sur la présentation visible' }
        ],
        points: [
          { title: 'Portée plus claire', text: 'Le client comprend immédiatement que cette page est dédiée aux autos et camions seulement.' },
          { title: 'Finition plus constante', text: "Les conditions d'atelier aident à mieux contrôler le résultat final." },
          { title: 'Offre mieux cadrée', text: "La séparation évite les confusions entre types de véhicules et attentes de service." }
        ]
      },
      'vente-achat': {
        title: 'Ce qui donne de la valeur à ce service avant transaction',
        intro: "Acheter ou vendre devient plus simple quand l'état du véhicule est plus clair, que les priorités sont identifiées et que la présentation inspire davantage confiance.",
        stats: [
          { value: 'Acheteur ou vendeur', label: 'Accompagnement selon le côté de la transaction' },
          { value: 'Inspection + préparation', label: 'Utile avant achat ou mise en vente' },
          { value: 'Correctifs prioritaires', label: 'Focus sur les bonnes actions en premier' }
        ],
        points: [
          { title: 'Prix plus défendable', text: 'Un véhicule mieux documenté est plus facile à afficher, expliquer ou négocier.' },
          { title: 'Moins de zones grises', text: 'Le service aide à distinguer le cosmétique des vrais enjeux structurels ou liés à l’eau.' },
          { title: 'Décision plus claire', text: 'Vous pouvez décider plus rationnellement entre réparer, acheter, vendre ou attendre.' }
        ]
      }
    } as const)[service.slug];
const resolvedProofTitle = service.proofTitle ?? fallbackProofContent?.title;
const resolvedProofIntro = service.proofIntro ?? fallbackProofContent?.intro;
const resolvedProofStats = proofStats.length > 0 ? proofStats : fallbackProofContent?.stats ?? [];
const resolvedProofPoints = proofPoints.length > 0 ? proofPoints : fallbackProofContent?.points ?? [];
---

<main>
  <section class="service-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{service.eyebrow}</p>
        <h1 class:list={[
          (service.slug === 'inspection' || service.slug === 'entretien' || service.slug === 'maintenance' || service.slug === 'reparation' || service.slug === 'repair' || service.slug === 'esthetique' || service.slug === 'detailing' || service.slug === 'esthetique-auto-camion' || service.slug === 'auto-truck-detailing') && 'hero-title-wide',
          service.slug === 'inspection' && 'hero-title-wider'
        ]}>{service.h1}</h1>
        <p class="opening">{service.opening}</p>
        <p class="lead">{service.lead}</p>
        <p class="intro">{service.intro}</p>
        {service.heroPromise && <p class="hero-promise">{service.heroPromise}</p>}

        <div class="hero-badges">
          {service.highlights.map((item) => (
            <span>{item}</span>
          ))}
        </div>
      </div>

      <aside class="hero-card">
        <div class="hero-icon">
          <i class={service.icon}></i>
        </div>
        <h2>{isEnglish ? 'Need a practical starting point?' : 'Besoin d’un point de départ clair?'}</h2>
        <p>{isEnglish ? 'We can help you understand the situation, choose the right service and decide on the next useful step for your RV.' : 'On peut vous aider à comprendre la situation, à choisir le bon service et à décider de la prochaine étape utile pour votre VR.'}</p>
        <a class="hero-link" href={contactHref}>{isEnglish ? 'Talk to us about your RV' : 'Parler de votre VR'}</a>
      </aside>
    </div>
  </section>

  <section class="service-body">
      <div class="container body-grid">
      <article class="service-main">
        {(resolvedProofStats.length > 0 || resolvedProofPoints.length > 0) && (
          <section class="content-card alt">
            <h2>{resolvedProofTitle ?? (isEnglish ? 'Proof and concrete outcomes' : 'Preuves et résultats concrets')}</h2>
            {resolvedProofIntro && <p class="section-copy">{resolvedProofIntro}</p>}
            {resolvedProofStats.length > 0 && (
              <div class="proof-stats-grid">
                {resolvedProofStats.map((item) => (
                  <article class="proof-stat-card">
                    <strong>{item.value}</strong>
                    <span>{item.label}</span>
                  </article>
                ))}
              </div>
            )}
            {resolvedProofPoints.length > 0 && (
              <div class="why-choose-grid">
                {resolvedProofPoints.map((item) => (
                  <article class="why-card">
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </article>
                ))}
              </div>
            )}
          </section>
        )}

        <section class="content-card">
          <h2>{service.includedTitle}</h2>
          <p class="section-copy">{service.detailIntro}</p>
          <ul>
            {service.included.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <section class="content-card alt">
          <h2>{service.situationsTitle}</h2>
          <ul>
            {service.situations.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        {caseStudies.length > 0 && (
          <section class="content-card">
            <h2>{service.caseStudiesTitle ?? (isEnglish ? 'Real examples related to this service' : 'Exemples réels liés à ce service')}</h2>
            {service.caseStudiesIntro && <p class="section-copy">{service.caseStudiesIntro}</p>}
            <div class="link-card-grid">
              {caseStudies.map((item) => (
                item.href ? (
                  <a class="link-card link-card-anchor" href={item.href}>
                    <h3>{item.title}</h3>
                    {item.meta && <p class="link-card-meta">{item.meta}</p>}
                    <p>{item.text}</p>
                    <span>{isEnglish ? 'See the case' : 'Voir le cas'}</span>
                  </a>
                ) : (
                  <article class="link-card">
                    <h3>{item.title}</h3>
                    {item.meta && <p class="link-card-meta">{item.meta}</p>}
                    <p>{item.text}</p>
                  </article>
                )
              ))}
            </div>
          </section>
        )}

        <section class="content-card">
          <h2>{isEnglish ? 'How we work' : 'Notre façon de travailler'}</h2>
          <p class="section-copy">{service.processIntro}</p>
          <ol>
            {service.process.map((item) => (
              <li>{item}</li>
            ))}
          </ol>
        </section>

        <section class="content-card alt">
          <h2>{service.whyChooseTitle}</h2>
          <p class="section-copy">{service.whyChooseIntro}</p>
          <div class="why-choose-grid">
            {service.whyChoose.map((item) => (
              <article class="why-card">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </section>

        {!isWorkshopOnlyDetailing && (
          <section class="content-card alt">
            <h2>{isEnglish ? 'Useful links before you decide' : 'Liens utiles avant de décider'}</h2>
            <div class="link-card-grid">
              {helpfulLinks.map((item) => (
                <a class="link-card link-card-anchor" href={item.href}>
                  <h3>{item.title}</h3>
                  <p>{item.copy}</p>
                  <span>{isEnglish ? 'Learn more' : 'En savoir plus'}</span>
                </a>
              ))}
            </div>
          </section>
        )}

        <section class="content-card faq-section">
          <h2>{service.faqTitle}</h2>
          <div class="faq-list">
            {service.faqs.map((item) => (
              <details class="faq-item">
                <summary><h3>{item.question}</h3></summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      </article>

      <aside class="service-side sticky">
        <div class="side-card side-card-primary">
          <h3>{isEnglish ? 'Need a quick opinion?' : "Besoin d'un avis rapide?"}</h3>
          <p>{isEnglish ? 'We can point you toward inspection, maintenance or repair based on the actual condition of the vehicle.' : "On peut vous orienter vers une inspection, un entretien ou une réparation selon l'état du véhicule."}</p>
          <a class="side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
          <a class="side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">{isEnglish ? 'Book online' : 'Réserver en ligne'}</a>
        </div>

        <div class="side-card">
          <h3>{isEnglish ? 'Other services' : 'Autres services'}</h3>
          <nav class="service-nav" aria-label={isEnglish ? 'Other services' : 'Autres services'}>
            {otherServices.map((item) => (
              <a href={serviceHref(item.slug)}>
                <i class={item.icon}></i>
                <span>{item.navLabel}</span>
              </a>
            ))}
          </nav>
        </div>

        {!isWorkshopOnlyDetailing && (
          <div class="side-card">
            <h3>{isEnglish ? 'Service areas' : 'Zones desservies'}</h3>
            <nav class="service-nav" aria-label={isEnglish ? 'Service areas' : 'Zones desservies'}>
              {serviceAreas.map((area) => (
                <a href={isEnglish ? '/en/service-areas/' : '/zones-desservies/'}>
                  <i class="fas fa-map-marker-alt"></i>
                  <span>{area}</span>
                </a>
              ))}
            </nav>
          </div>
        )}
      </aside>
    </div>
  </section>

</main>

<style>
  .service-hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 32%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #23476f 58%, #f4f6f8 58%, #f4f6f8 100%);
    padding: 4.5rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr);
    gap: 2rem;
    align-items: stretch;
  }

  .hero-copy {
    color: white;
  }

  .eyebrow {
    display: inline-flex;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: var(--brand-gold);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .hero-copy h1 {
    max-width: 12ch;
    margin-bottom: 1rem;
    color: white;
    line-height: 1.05;
  }

  .hero-copy h1.hero-title-wide {
    max-width: 17ch;
  }

  .hero-copy h1.hero-title-wider {
    max-width: 20ch;
  }

  .lead {
    font-size: 1.2rem;
    line-height: 1.7;
    color: #f5f7fa;
    max-width: 60ch;
  }

  .opening {
    max-width: 64ch;
    font-size: 1.08rem;
    color: #dbe4ee;
    margin-bottom: 1rem;
  }

