---
import siteSettings from '../data/site-settings.json';
import type { ServicePage } from '../data/service-page-types';

interface Props {
  service: ServicePage;
  allServices: ServicePage[];
  lang?: 'fr' | 'en';
}

const { service, allServices, lang = 'fr' } = Astro.props as Props;
const otherServices = allServices.filter((item) => item.slug !== service.slug && item.slug !== 'vente-achat' && item.slug !== 'buying-selling');
const isEnglish = lang === 'en';
const contactHref = isEnglish ? '/en/contact/' : '/contact/';
const chooseServiceHref = isEnglish ? '/en/choose-service/' : '/choisir-service/';
const projectsHref = isEnglish ? '/en/realisations/' : '/realisations/';
const inspectionHref = isEnglish ? '/en/services/inspection/' : '/services/inspection/';
const servicesHref = isEnglish ? '/en/services/' : '/services/';
const serviceHref = (slug: string) => isEnglish ? `/en/services/${slug}/` : `/services/${slug}/`;
const serviceAreas = isEnglish
  ? ['Outaouais', 'Ottawa', 'Laurentides']
  : ['Outaouais', 'Ottawa', 'Laurentides'];
const helpfulLinks = isEnglish
  ? [
      {
        href: contactHref,
        title: 'Contact us about your RV',
        copy: 'Describe the issue, the vehicle, and your situation to get the right next step.'
      },
      {
        href: projectsHref,
        title: 'See real workshop projects',
        copy: 'Review examples of repairs, restoration work, and before-and-after improvements.'
      },
      {
        href: inspectionHref,
        title: 'Inspection before buying or selling',
        copy: 'If your situation involves a transaction, start with the inspection section to clarify the real condition of the vehicle.'
      },
      {
        href: chooseServiceHref,
        title: 'Which service fits best?',
        copy: 'Use our guidance page if you are not sure whether you need inspection, maintenance, repair, or detailing.'
      },
      {
        href: servicesHref,
        title: 'Compare our other services',
        copy: 'If this service is close but not exact, review the full list to choose the best fit.'
      }
    ]
  : [
      {
        href: contactHref,
        title: 'Parlez-nous de votre VR',
        copy: 'Décrivez le problème, le véhicule et votre situation pour obtenir la bonne prochaine étape.'
      },
      {
        href: projectsHref,
        title: 'Voir des interventions réelles',
        copy: 'Consultez des exemples de réparations, de remises en état et d’améliorations avant-après.'
      },
      {
        href: inspectionHref,
        title: 'Inspection avant achat ou vente',
        copy: 'Si votre situation touche une transaction, commencez par la section inspection pour clarifier l’état réel du véhicule.'
      },
      {
        href: chooseServiceHref,
        title: 'Quel service choisir ?',
        copy: 'Utilisez notre page d’orientation si vous hésitez entre inspection, entretien, réparation ou esthétique.'
      },
      {
        href: servicesHref,
        title: 'Comparer les autres services',
        copy: 'Si ce service est proche de votre besoin sans être exact, parcourez la liste complète.'
      }
    ];
---

<main>
  <section class="service-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{service.eyebrow}</p>
        <h1 class:list={[
          (service.slug === 'inspection' || service.slug === 'entretien' || service.slug === 'maintenance' || service.slug === 'reparation' || service.slug === 'repair' || service.slug === 'esthetique' || service.slug === 'detailing') && 'hero-title-wide',
          service.slug === 'inspection' && 'hero-title-wider'
        ]}>{service.h1}</h1>
        <p class="opening">{service.opening}</p>
        <p class="lead">{service.lead}</p>
        <p class="intro">{service.intro}</p>

        <div class="hero-badges">
          {service.highlights.map((item) => (
            <span>{item}</span>
          ))}
        </div>
      </div>

      <aside class="hero-card">
        <div class="hero-icon">
          <i class={service.icon}></i>
        </div>
        <h2>{isEnglish ? 'Need a practical starting point?' : 'Besoin d’un point de départ clair?'}</h2>
        <p>{isEnglish ? 'We can help you understand the situation, choose the right service and decide on the next useful step for your RV.' : 'On peut vous aider à comprendre la situation, à choisir le bon service et à décider de la prochaine étape utile pour votre VR.'}</p>
        <a class="hero-link" href={contactHref}>{isEnglish ? 'Talk to us about your RV' : 'Parler de votre VR'}</a>
      </aside>
    </div>
  </section>

  <section class="service-body">
    <div class="container body-grid">
      <article class="service-main">
        <section class="content-card">
          <h2>{service.includedTitle}</h2>
          <p class="section-copy">{service.detailIntro}</p>
          <ul>
            {service.included.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <section class="content-card alt">
          <h2>{service.situationsTitle}</h2>
          <ul>
            {service.situations.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <section class="content-card">
          <h2>{isEnglish ? 'How we work' : 'Notre façon de travailler'}</h2>
          <p class="section-copy">{service.processIntro}</p>
          <ol>
            {service.process.map((item) => (
              <li>{item}</li>
            ))}
          </ol>
        </section>

        <section class="content-card alt">
          <h2>{service.whyChooseTitle}</h2>
          <p class="section-copy">{service.whyChooseIntro}</p>
          <div class="why-choose-grid">
            {service.whyChoose.map((item) => (
              <article class="why-card">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="content-card">
          <h2>{isEnglish ? 'Areas served for this service' : 'Zones desservies pour ce service'}</h2>
          <p class="section-copy">
            {isEnglish
              ? 'This service is offered from our Gatineau workshop and according to the type of work, may also involve nearby travel or regional support.'
              : 'Ce service est offert à partir de notre atelier de Gatineau et, selon le type d’intervention, peut aussi inclure un déplacement à proximité ou un accompagnement régional.'}
          </p>
          <div class="link-card-grid">
            {serviceAreas.map((area) => (
              <article class="link-card">
                <h3>{area}</h3>
                <p>
                  {isEnglish
                    ? `Support available for ${service.navLabel.toLowerCase()} requests in and around ${area}.`
                    : `Accompagnement offert pour les demandes de ${service.navLabel.toLowerCase()} à ${area} et dans les environs.`}
                </p>
              </article>
            ))}
          </div>
        </section>

        <section class="content-card alt">
          <h2>{isEnglish ? 'Useful links before you decide' : 'Liens utiles avant de décider'}</h2>
          <div class="link-card-grid">
            {helpfulLinks.map((item) => (
              <a class="link-card link-card-anchor" href={item.href}>
                <h3>{item.title}</h3>
                <p>{item.copy}</p>
                <span>{isEnglish ? 'Learn more' : 'En savoir plus'}</span>
              </a>
            ))}
          </div>
        </section>

        <section class="content-card faq-section">
          <h2>{service.faqTitle}</h2>
          <div class="faq-list">
            {service.faqs.map((item) => (
              <article class="faq-item">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </section>
      </article>

      <aside class="service-side">
        <div class="side-card sticky">
          <h3>{isEnglish ? 'Need a quick opinion?' : "Besoin d'un avis rapide?"}</h3>
          <p>{isEnglish ? 'We can point you toward inspection, maintenance or repair based on the actual condition of the vehicle.' : "On peut vous orienter vers une inspection, un entretien ou une réparation selon l'état du véhicule."}</p>
          <a class="side-button" href={`tel:${siteSettings.phone.href}`}>{siteSettings.phone.display}</a>
          <a class="side-link" href={siteSettings.squareBookingUrl} target="_blank" rel="noopener">{isEnglish ? 'Book your appointment' : 'Réserver en ligne'}</a>
        </div>

        <div class="side-card">
          <h3>{isEnglish ? 'Other services' : 'Autres services'}</h3>
          <nav class="service-nav" aria-label={isEnglish ? 'Other services' : 'Autres services'}>
            {otherServices.map((item) => (
              <a href={serviceHref(item.slug)}>
                <i class={item.icon}></i>
                <span>{item.navLabel}</span>
              </a>
            ))}
          </nav>
        </div>
      </aside>
    </div>
  </section>

</main>

<style>
  .service-hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 32%),
      linear-gradient(135deg, var(--brand-navy-dark) 0%, #23476f 58%, #f4f6f8 58%, #f4f6f8 100%);
    padding: 4.5rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr);
    gap: 2rem;
    align-items: stretch;
  }

  .hero-copy {
    color: white;
  }

  .eyebrow {
    display: inline-flex;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: var(--brand-gold);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .hero-copy h1 {
    max-width: 12ch;
    margin-bottom: 1rem;
    color: white;
    line-height: 1.05;
  }

  .hero-copy h1.hero-title-wide {
    max-width: 17ch;
  }

  .hero-copy h1.hero-title-wider {
    max-width: 20ch;
  }

  .lead {
    font-size: 1.2rem;
    line-height: 1.7;
    color: #f5f7fa;
    max-width: 60ch;
  }

  .opening {
    max-width: 64ch;
    font-size: 1.08rem;
    color: #dbe4ee;
    margin-bottom: 1rem;
  }

  .intro {
    margin-top: 1rem;
    max-width: 62ch;
    color: #dbe4ee;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.75rem;
  }

  .hero-badges span {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.75rem 1rem;
    border-radius: 14px;
    background: var(--brand-gold);
    border: 1px solid var(--brand-gold);
    color: var(--brand-navy-dark);
    font-weight: 700;
    box-shadow: 0 10px 18px rgba(14, 31, 49, 0.14);
  }

  .hero-card {
    align-self: end;
    background: white;
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 22px 44px rgba(16, 35, 56, 0.22);
  }

  .hero-icon {
    width: 4rem;
    height: 4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    background: linear-gradient(135deg, var(--brand-green), #57af49);
    color: white;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .hero-card h2 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .hero-card p {
    color: var(--brand-muted);
    margin-bottom: 1.25rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    background: var(--brand-navy);
    color: white;
    font-weight: 700;
    text-decoration: none;
  }

  .hero-link:hover {
    text-decoration: none;
    background: var(--brand-navy-dark);
  }

  .service-body {
    padding: 4rem 0;
    background:
      linear-gradient(180deg, #ffffff 0%, #ffffff 42%, #f3f5f8 42%, #f3f5f8 100%);
  }

  .body-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr);
    gap: 2rem;
    align-items: start;
  }

  .service-main,
  .service-side {
    display: grid;
    gap: 1.5rem;
  }

  .content-card,
  .side-card {
    background: white;
    border-radius: 22px;
    padding: 1.75rem;
    box-shadow: 0 16px 34px rgba(24, 40, 61, 0.08);
  }

  .content-card.alt {
    background: linear-gradient(180deg, #f8fbf5 0%, #ffffff 100%);
  }

  .content-card h2,
  .side-card h3 {
    margin-bottom: 1rem;
  }

  .content-card ul,
  .content-card ol {
    display: grid;
    gap: 0.85rem;
    padding-left: 1.2rem;
    color: var(--brand-ink);
  }

  .section-copy {
    margin-bottom: 1rem;
    color: var(--brand-muted);
  }

  .content-card li::marker {
    color: var(--brand-green);
    font-weight: 700;
  }

  .why-choose-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .link-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .why-card {
    background: var(--brand-surface);
    border-radius: 16px;
    padding: 1rem;
  }

  .link-card {
    background: var(--brand-surface);
    border-radius: 16px;
    padding: 1rem;
  }

  .link-card-anchor {
    display: grid;
    gap: 0.55rem;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .link-card-anchor:hover {
    text-decoration: none;
    transform: translateY(-2px);
    background: #eaf1e6;
    box-shadow: 0 12px 24px rgba(21, 38, 58, 0.08);
  }

  .why-card h3,
  .faq-item h3,
  .link-card h3 {
    font-size: 1rem;
    margin-bottom: 0.45rem;
  }

  .why-card p,
  .faq-item p,
  .link-card p {
    color: var(--brand-muted);
  }

  .link-card span {
    color: var(--brand-navy);
    font-weight: 700;
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .faq-item {
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(31, 58, 95, 0.08);
  }

  .faq-item:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .sticky {
    position: sticky;
    top: 7rem;
    background: var(--brand-navy-dark);
    color: white;
  }

  .sticky h3 {
    color: white;
  }

  .sticky p {
    color: #dbe4ee;
  }

  .side-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    border-radius: 999px;
    background: var(--brand-gold);
    color: var(--brand-navy-dark);
    font-weight: 700;
    text-decoration: none;
    margin: 0.25rem 0 0.75rem;
  }

  .side-button:hover {
    text-decoration: none;
    background: #e2c417;
  }

  .side-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    background: var(--brand-gold);
    border: 2px solid var(--brand-gold);
    color: var(--brand-navy-dark);
    font-weight: 700;
    text-decoration: none;
  }

  .side-link:hover {
    text-decoration: none;
    background: #e1c317;
    border-color: #e1c317;
  }

  .service-nav {
    display: grid;
    gap: 0.7rem;
  }

  .service-nav a {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    min-height: 54px;
    padding: 0.9rem 1rem;
    border-radius: 16px;
    background: var(--brand-surface);
    color: var(--brand-ink);
    text-decoration: none;
    font-weight: 700;
  }

  .service-nav a:hover {
    text-decoration: none;
    background: #eaf1e6;
  }

  .service-nav i {
    color: var(--brand-green);
  }

  @media (max-width: 920px) {
    .hero-grid,
    .body-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      max-width: none;
    }
    
    .hero-copy h1.hero-title-wide {
      max-width: none;
    }

    .sticky {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .service-hero {
      padding: 3.25rem 0 3rem;
      background:
        radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 38%),
        linear-gradient(180deg, var(--brand-navy-dark) 0%, #23476f 100%);
    }

    .lead {
      font-size: 1.05rem;
    }

    .service-body {
      padding: 3rem 0;
      background: #f3f5f8;
    }

    .content-card,
    .side-card,
    .hero-card {
      border-radius: 18px;
      padding: 1.3rem;
    }
  }
</style>
