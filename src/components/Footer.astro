---
export interface Props {
  lang?: 'fr' | 'en';
}

const squareBookingUrl = 'https://app.squareup.com/appointments/book/lgocu4o42jy5zu/LGZ9VNRVZ6XXM/start';
const { lang = 'fr' } = Astro.props as Props;
const isEnglish = lang === 'en';
---

<footer class="footer">
  <div class="container footer-content">
    <div class="footer-col">
      <img class="footer-brand" src="/clinique-du-vr-brand.jpg" alt="Clinique du VR" />
      <p>{isEnglish ? 'RV maintenance, repair and detailing with a clear, careful and service-oriented approach.' : 'Entretien, reparation et esthetique de VR avec une approche claire, soignee et orientee service.'}</p>
    </div>
    <div class="footer-col">
      <h4>{isEnglish ? 'Contact' : 'Contact'}</h4>
      <p>
        <strong>{isEnglish ? 'Phone:' : 'Téléphone:'}</strong> <a href="tel:+15813373366">(581) 337-3366</a><br>
        <strong>Square:</strong> <a href={squareBookingUrl} target="_blank" rel="noopener">{isEnglish ? 'Book now' : 'Prendre rendez-vous'}</a><br>
        <strong>Email:</strong> <a href="mailto:info@demosolution.ca">info@demosolution.ca</a><br>
        <strong>RBQ:</strong> 5824-9764-01
      </p>
    </div>
    <div class="footer-col">
      <h4>{isEnglish ? 'Services' : 'Services'}</h4>
      <ul>
        <li><a href={isEnglish ? '/en/services/' : '/services/'}>{isEnglish ? 'Maintenance' : 'Entretien'}</a></li>
        <li><a href={isEnglish ? '/en/services/' : '/services/'}>{isEnglish ? 'Repair' : 'Reparation'}</a></li>
        <li><a href={isEnglish ? '/en/services/' : '/services/'}>{isEnglish ? 'Inspection' : 'Inspection'}</a></li>
        <li><a href={isEnglish ? '/en/services/' : '/services/'}>{isEnglish ? 'RV Detailing' : 'Esthetique VR'}</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>{isEnglish ? 'Follow Us' : 'Nous Suivre'}</h4>
      <a href="https://www.facebook.com/profile.php?id=61588265661776" target="_blank" rel="noopener">
        <i class="fab fa-facebook"></i> Facebook
      </a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; 2026 Clinique du VR. {isEnglish ? 'All rights reserved.' : 'Tous droits réservés.'}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--brand-navy);
    color: white;
    padding: 3rem 0 0;
    margin-top: 4rem;
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    padding: 2rem;
  }

  .footer-brand {
    height: 68px;
    width: auto;
    display: block;
    margin-bottom: 1rem;
    background: white;
    border-radius: 10px;
    padding: 0.35rem;
  }

  .footer-col h4 {
    color: var(--brand-gold);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .footer-col a {
    color: white;
  }

  .footer-col ul {
    list-style: none;
  }

  .footer-col ul li {
    margin: 0.5rem 0;
  }

  .footer-bottom {
    background: var(--brand-navy-dark);
    padding: 1rem;
    text-align: center;
    border-top: 3px solid var(--brand-green);
  }

  .footer-bottom a {
    color: var(--brand-gold);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
    }
  }
</style>
