---
import siteSettings from '../data/site-settings.json';
import servicePagesFr from '../data/service-pages.json';
import servicePagesEn from '../data/service-pages-en.json';
import { localAreaPagesFr, localAreaPagesEn } from '../data/local-area-pages';

export interface Props {
  lang?: 'fr' | 'en';
}

const { lang = 'fr' } = Astro.props as Props;
const isEnglish = lang === 'en';
const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const frToEnServiceSlug = new Map(servicePagesFr.items.map((service) => [service.slug, service.alternateSlug]));
const enToFrServiceSlug = new Map(servicePagesEn.items.map((service) => [service.slug, service.alternateSlug]));
const frAreaToEnSlug = new Map(localAreaPagesEn.map((page) => [page.area, page.slug]));
const enAreaToFrSlug = new Map(localAreaPagesFr.map((page) => [page.area, page.slug]));
const frToEnAreaSlug = new Map(localAreaPagesFr.map((page) => [page.slug, frAreaToEnSlug.get(page.area)]));
const enToFrAreaSlug = new Map(localAreaPagesEn.map((page) => [page.slug, enAreaToFrSlug.get(page.area)]));

function getAlternatePath(pathname: string, targetLang: 'fr' | 'en') {
  const normalizedPath = pathname.endsWith('/') ? pathname : `${pathname}/`;

  const staticFrToEn: Record<string, string> = {
    '/': '/en/',
    '/about/': '/en/about/',
    '/choisir-service/': '/en/choose-service/',
    '/contact/': '/en/contact/',
    '/plan-du-site/': '/en/site-map/',
    '/privacy/': '/en/privacy/',
    '/realisations/': '/en/realisations/',
    '/services/': '/en/services/',
    '/vente/': '/en/sales/',
    '/services/vente-achat/': '/en/services/buying-selling/'
  };

  const staticEnToFr: Record<string, string> = {
    '/en/': '/',
    '/en/about/': '/about/',
    '/en/choose-service/': '/choisir-service/',
    '/en/contact/': '/contact/',
    '/en/site-map/': '/plan-du-site/',
    '/en/privacy/': '/privacy/',
    '/en/realisations/': '/realisations/',
    '/en/services/': '/services/',
    '/en/sales/': '/vente/',
    '/en/services/buying-selling/': '/services/vente-achat/'
  };

  if (targetLang === 'en') {
    if (staticFrToEn[normalizedPath]) return staticFrToEn[normalizedPath];
    if (normalizedPath.startsWith('/services/')) {
      const slug = normalizedPath.replace('/services/', '').replaceAll('/', '');
      return `/en/services/${frToEnServiceSlug.get(slug) ?? slug}/`;
    }
    if (normalizedPath.startsWith('/zones/')) {
      const slug = normalizedPath.replace('/zones/', '').replaceAll('/', '');
      return `/en/areas/${frToEnAreaSlug.get(slug) ?? slug}/`;
    }
    return normalizedPath.startsWith('/en/') ? normalizedPath : `/en${normalizedPath}`;
  }

  if (staticEnToFr[normalizedPath]) return staticEnToFr[normalizedPath];
  if (normalizedPath.startsWith('/en/services/')) {
    const slug = normalizedPath.replace('/en/services/', '').replaceAll('/', '');
    return `/services/${enToFrServiceSlug.get(slug) ?? slug}/`;
  }
  if (normalizedPath.startsWith('/en/areas/')) {
    const slug = normalizedPath.replace('/en/areas/', '').replaceAll('/', '');
    return `/zones/${enToFrAreaSlug.get(slug) ?? slug}/`;
  }
  return normalizedPath.startsWith('/en/') ? normalizedPath.replace(/^\/en/, '') || '/' : normalizedPath;
}

const homeHref = isEnglish ? '/en/' : '/';
const frHref = getAlternatePath(currentPath, 'fr');
const enHref = getAlternatePath(currentPath, 'en');
const smsHref = `sms:${siteSettings.phone.href}`;
const isActivePath = (href: string) => {
  if (href === '/') return currentPath === '/';
  if (href === '/en/') return currentPath === '/en/';
  return currentPath === href || currentPath.startsWith(href);
};
const serviceMenuItems = (isEnglish ? servicePagesEn.items : servicePagesFr.items)
  .filter((service) => service.slug !== 'vente-achat' && service.slug !== 'buying-selling')
  .map((service) => ({
    label: service.navLabel,
    href: isEnglish ? `/en/services/${service.slug}/` : `/services/${service.slug}/`,
    active: currentPath === (isEnglish ? `/en/services/${service.slug}/` : `/services/${service.slug}/`)
  }));
const navItems = isEnglish
  ? [
      { label: 'Home', href: '/en/' },
      { label: 'Services', href: '/en/services/' },
      { label: 'Projects', href: '/en/realisations/' },
      { label: 'Sales', href: '/en/sales/' },
      { label: 'About', href: '/en/about/' },
      { label: 'Contact', href: '/en/contact/' }
    ]
  : [
      { label: 'Accueil', href: '/' },
      { label: 'Services', href: '/services/' },
      { label: 'Réalisations', href: '/realisations/' },
      { label: 'Vente', href: '/vente/' },
      { label: 'À Propos', href: '/about/' },
      { label: 'Contact', href: '/contact/' }
    ];
---

<header class="header">
  <div class="topbar">
    <div class="container topbar-inner">
      <div class="topbar-left">
        <a href={`tel:${siteSettings.phone.href}`} class="topbar-phone">{siteSettings.phone.display}</a>
        <a href={smsHref} class="sms-link">{isEnglish ? 'Text us' : 'Message texte'}</a>
        <a href={siteSettings.squareBookingUrl} target="_blank" rel="noopener" class="square-link">{isEnglish ? 'Book online' : 'Réserver en ligne'}</a>
      </div>
      <div class="topbar-right">
        <div class="lang-switch">
          <a href={frHref} class:list={['lang-pill', !isEnglish && 'active']}>FR</a>
          <a href={enHref} class:list={['lang-pill', isEnglish && 'active']}>EN</a>
        </div>
        <a href={siteSettings.facebookUrl} target="_blank" rel="noopener" title="Facebook">
          <i class="fab fa-facebook"></i>
        </a>
        <a href={siteSettings.tiktokUrl} target="_blank" rel="noopener" title="TikTok" aria-label="TikTok">
          <i class="fab fa-tiktok"></i>
        </a>
      </div>
    </div>
  </div>

  <nav class="navbar">
    <div class="container navbar-inner">
      <a href={homeHref} class="logo">
        <img src={siteSettings.brandImage} alt={isEnglish ? 'Clinique du VR — RV service in Gatineau' : 'Clinique du VR — Service de VR à Gatineau'} />
      </a>
      <div class="nav-panel" id="site-nav" data-nav-panel>
        <ul class="nav-menu">
          {navItems.map(item => (
            item.href === (isEnglish ? '/en/services/' : '/services/')
              ? (
                <li class="nav-item-with-children">
                  <div class="nav-link-row">
                    <a
                      href={item.href}
                      class:list={[isActivePath(item.href) && 'active']}
                      aria-current={isActivePath(item.href) ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                    <button
                      class="submenu-toggle"
                      type="button"
                      aria-label={isEnglish ? 'Show services' : 'Afficher les services'}
                      aria-expanded="false"
                      data-submenu-toggle
                    >
                      <i class="fas fa-chevron-down" aria-hidden="true"></i>
                    </button>
                  </div>
                  <ul class="submenu" data-submenu>
                    {serviceMenuItems.map((serviceItem) => (
                      <li>
                        <a
                          href={serviceItem.href}
                          class:list={[serviceItem.active && 'active']}
                          aria-current={serviceItem.active ? 'page' : undefined}
                        >
                          {serviceItem.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </li>
              )
              : (
                <li>
                  <a
                    href={item.href}
                    class:list={[isActivePath(item.href) && 'active']}
                    aria-current={isActivePath(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              )
          ))}
        </ul>
        <div class="mobile-social-links">
          <span>{isEnglish ? 'Follow us' : 'Nous suivre'}</span>
          <div class="mobile-social-row">
            <a href={siteSettings.facebookUrl} target="_blank" rel="noopener">
              <i class="fab fa-facebook" aria-hidden="true"></i>
              <span>Facebook</span>
            </a>
            <a href={siteSettings.tiktokUrl} target="_blank" rel="noopener">
              <i class="fab fa-tiktok" aria-hidden="true"></i>
              <span>TikTok</span>
            </a>
          </div>
        </div>
      </div>
      <button class="hamburger" type="button" aria-label={isEnglish ? 'Open menu' : 'Ouvrir le menu'} aria-expanded="false" aria-controls="site-nav" data-nav-toggle>
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector('.header');
    if (!header) return;

    const toggle = header.querySelector('[data-nav-toggle]');
    const panel = header.querySelector('[data-nav-panel]');
    if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;
    const submenuToggles = Array.from(panel.querySelectorAll('[data-submenu-toggle]'));

    const closeSubmenus = () => {
      submenuToggles.forEach((submenuToggle) => {
        if (!(submenuToggle instanceof HTMLButtonElement)) return;
        submenuToggle.setAttribute('aria-expanded', 'false');
        submenuToggle.closest('.nav-item-with-children')?.removeAttribute('data-submenu-open');
      });
    };

    const closeMenu = () => {
      closeSubmenus();
      header.removeAttribute('data-menu-open');
      toggle.setAttribute('aria-expanded', 'false');
    };

    toggle.addEventListener('click', () => {
      const isOpen = header.getAttribute('data-menu-open') === 'true';
      if (isOpen) {
        closeMenu();
        return;
      }

      header.setAttribute('data-menu-open', 'true');
      toggle.setAttribute('aria-expanded', 'true');
    });

    submenuToggles.forEach((submenuToggle) => {
      if (!(submenuToggle instanceof HTMLButtonElement)) return;

      submenuToggle.addEventListener('click', (event) => {
        event.preventDefault();
        const navItem = submenuToggle.closest('.nav-item-with-children');
        if (!(navItem instanceof HTMLElement)) return;

        const isOpen = navItem.getAttribute('data-submenu-open') === 'true';
        closeSubmenus();

        if (isOpen) return;

        navItem.setAttribute('data-submenu-open', 'true');
        submenuToggle.setAttribute('aria-expanded', 'true');
      });
    });

    panel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > 768) closeMenu();
    });
  })();
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .topbar {
    background: var(--brand-navy);
    color: white;
    padding: 0.75rem 0;
    font-size: 0.9rem;
  }

  .topbar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .topbar-left {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .topbar-left a, .topbar-left span {
    color: white;
  }

  .topbar-phone {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .sms-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: var(--brand-green);
    border: 2px solid var(--brand-green);
    color: white !important;
    font-weight: 700;
  }

  .sms-link:hover {
    text-decoration: none;
    background: var(--brand-green-dark);
    border-color: var(--brand-green-dark);
  }

  .square-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: var(--brand-gold);
    color: var(--brand-navy-dark) !important;
    border: 2px solid var(--brand-gold);
    font-weight: 700;
  }

  .square-link:hover {
    text-decoration: none;
    background: #e1c317;
    border-color: #e1c317;
  }

  .topbar-right a {
    color: white;
    font-size: 1.2rem;
    margin-left: 1rem;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .lang-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.3rem;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.35);
    font-size: 0.8rem !important;
    font-weight: 700;
    margin-left: 0 !important;
  }

  .lang-pill.active {
    background: var(--brand-gold);
    color: var(--brand-navy-dark) !important;
    border-color: var(--brand-gold);
  }

  .navbar {
    background: white;
    padding: 1rem 0;
    position: relative;
  }

  .navbar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .logo img {
    height: 64px;
    width: auto;
    display: block;
  }

  .nav-panel {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-menu {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  .nav-menu > li {
    position: relative;
  }

  .nav-item-with-children::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 0.8rem;
  }

  .nav-menu a {
    color: var(--brand-ink);
    font-weight: 500;
    text-transform: uppercase;
    font-size: 0.9rem;
  }

  .nav-link-row {
    display: block;
  }

  .submenu-toggle {
    display: none;
  }

  .submenu {
    display: none;
    position: absolute;
    top: calc(100% + 0.2rem);
    left: 0;
    min-width: 240px;
    list-style: none;
    margin: 0;
    padding: 0.6rem 0;
    background: white;
    border: 1px solid rgba(23, 48, 79, 0.08);
    border-radius: 16px;
    box-shadow: 0 18px 34px rgba(21, 38, 58, 0.12);
    z-index: 30;
  }

  .submenu::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 28px;
    width: 14px;
    height: 14px;
    background: white;
    border-top: 1px solid rgba(23, 48, 79, 0.08);
    border-left: 1px solid rgba(23, 48, 79, 0.08);
    transform: rotate(45deg);
  }

  .submenu li {
    border-bottom: 0;
  }

  .submenu a {
    display: block;
    padding: 0.7rem 1rem;
    font-size: 0.86rem;
    white-space: nowrap;
  }

  .nav-item-with-children:hover .submenu,
  .nav-item-with-children:focus-within .submenu {
    display: block;
  }

  .nav-menu a:hover {
    color: var(--brand-green);
    text-decoration: none;
  }

  .nav-menu a.active {
    color: var(--brand-green);
    font-weight: 700;
  }

  .mobile-social-links {
    display: none;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    background: none;
    border: none;
    cursor: pointer;
    gap: 0.5rem;
    padding: 0;
  }

  .hamburger span {
    width: 25px;
    height: 3px;
    background: var(--brand-navy);
  }

  @media (max-width: 768px) {
    .nav-item-with-children::after {
      display: none;
    }

    .topbar {
      padding: 0.4rem 0;
    }

    .topbar-inner {
      flex-direction: row;
      align-items: stretch;
      gap: 0.75rem;
    }

    .topbar-left {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
      width: 100%;
    }

    .topbar-right {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 0.55rem;
      width: auto;
    }

    .topbar-right .lang-switch {
      display: none;
    }

    .topbar-phone {
      min-height: 34px;
      justify-content: flex-start;
      font-size: 0.92rem;
    }

    .sms-link,
    .square-link {
      min-height: 34px;
      width: auto;
      justify-content: center;
      text-align: center;
      padding: 0.35rem 0.7rem;
      font-size: 0.84rem;
    }

    .sms-link {
      display: none;
    }

    .square-link {
      white-space: nowrap;
    }

    .topbar-right a {
      margin-left: 0;
    }

    .topbar-right > a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
    }

    .lang-pill {
      min-width: 1.95rem;
      padding: 0.18rem 0.42rem;
      font-size: 0.72rem !important;
    }

    .navbar {
      padding: 0.55rem 0;
    }

    .logo img {
      height: 42px;
    }

    .nav-panel {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      display: none;
      flex-direction: column;
      align-items: stretch;
      gap: 0.8rem;
      background: white;
      padding: 0.85rem 1rem 1rem;
      border-top: 1px solid rgba(23, 48, 79, 0.08);
      box-shadow: 0 18px 34px rgba(21, 38, 58, 0.12);
      max-height: calc(100vh - 96px);
      overflow: auto;
    }

    .header[data-menu-open='true'] .nav-panel {
      display: flex;
    }

    .nav-menu {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .nav-menu li {
      border-bottom: 1px solid rgba(23, 48, 79, 0.08);
    }

    .nav-link-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .nav-menu a {
      display: block;
      padding: 0.68rem 0;
      font-size: 0.84rem;
    }

    .nav-item-with-children > .nav-link-row > a {
      flex: 1;
    }

    .submenu-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 0;
      background: transparent;
      color: var(--brand-navy);
      cursor: pointer;
      padding: 0;
      transition: transform 0.2s ease;
    }

    .nav-item-with-children[data-submenu-open='true'] .submenu-toggle {
      transform: rotate(180deg);
    }

    .submenu {
      list-style: none;
      padding: 0 0 0.35rem 0.9rem;
      margin: 0;
    }

    .nav-item-with-children[data-submenu-open='true'] .submenu {
      display: block;
    }

    .submenu li {
      border-bottom: 0;
    }

    .submenu a {
      padding: 0.45rem 0;
      font-size: 0.8rem;
      text-transform: none;
      color: var(--brand-muted);
    }

    .mobile-social-links {
      display: grid;
      gap: 0.5rem;
      padding-top: 0.1rem;
    }

    .mobile-social-links > span {
      color: var(--brand-muted);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .mobile-social-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
    }

    .mobile-social-row a {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.55rem 0.8rem;
      border: 1px solid rgba(31, 58, 95, 0.12);
      border-radius: 999px;
      color: var(--brand-navy);
      font-size: 0.82rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .mobile-social-row a:hover {
      text-decoration: none;
      border-color: rgba(31, 58, 95, 0.24);
    }

    .mobile-social-row i {
      font-size: 0.95rem;
    }

    .hamburger {
      display: flex;
      min-width: 42px;
      min-height: 42px;
      align-items: center;
      justify-content: center;
      gap: 0.28rem;
    }

    .hamburger span {
      width: 22px;
      height: 2px;
    }
  }
</style>
