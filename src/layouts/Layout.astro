---
import siteSettings from '../data/site-settings.json';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  lang?: 'fr-CA' | 'en-CA';
  canonicalPath?: string;
  frPath?: string;
  enPath?: string;
  schemas?: object[];
  ogType?: 'website' | 'article';
  noindex?: boolean;
}

import { absoluteUrl, BRAND_IMAGE } from '../lib/seo';

const {
  title,
  description,
  lang = 'fr-CA',
  canonicalPath = Astro.url.pathname,
  frPath,
  enPath,
  schemas = [],
  ogType = 'website',
  noindex = false
} = Astro.props as Props;

const canonicalUrl = absoluteUrl(canonicalPath);
const ogLocale = lang === 'fr-CA' ? 'fr_CA' : 'en_CA';
const alternateFr = frPath ? absoluteUrl(frPath) : undefined;
const alternateEn = enPath ? absoluteUrl(enPath) : undefined;
const isEnglish = lang === 'en-CA';
const googleAdsId = siteSettings.googleAdsId?.trim() || '';
const googleAdsConversions = {
  phone: siteSettings.googleAdsConversions?.phone?.trim() || '',
  email: siteSettings.googleAdsConversions?.email?.trim() || '',
  booking: siteSettings.googleAdsConversions?.booking?.trim() || '',
  form: siteSettings.googleAdsConversions?.form?.trim() || ''
};
const hasGoogleAds = googleAdsId.length > 0;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    {alternateFr && <link rel="alternate" hreflang="fr-CA" href={alternateFr} />}
    {alternateEn && <link rel="alternate" hreflang="en-CA" href={alternateEn} />}
    {alternateFr && <link rel="alternate" hreflang="x-default" href={alternateFr} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={BRAND_IMAGE} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={BRAND_IMAGE} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    {hasGoogleAds && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(googleAdsId)}`}></script>
    )}
    {hasGoogleAds && (
      <script is:inline define:vars={{ googleAdsId, googleAdsConversions, squareBookingUrl: siteSettings.squareBookingUrl }}>
        (() => {
          const storageKey = 'cliniqueduvr-cookie-consent';
          let hasConsent = false;

          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = window.gtag || gtag;

          gtag('consent', 'default', {
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            analytics_storage: 'denied',
            wait_for_update: 500
          });
          gtag('js', new Date());
          gtag('config', googleAdsId);

          function grantConsent() {
            if (hasConsent) return;
            hasConsent = true;
            window.gtag('consent', 'update', {
              ad_storage: 'granted',
              ad_user_data: 'granted',
              ad_personalization: 'granted',
              analytics_storage: 'granted'
            });
          }

          function trackConversion(type) {
            if (typeof window.gtag !== 'function') return;

            const label = googleAdsConversions?.[type];
            window.gtag('event', `${type}_contact`, {
              event_category: 'engagement',
              event_label: type
            });

            if (label) {
              window.gtag('event', 'conversion', {
                send_to: `${googleAdsId}/${label}`
              });
            }
          }

          function installTracking() {
            if (window.__cliniqueduvrAdsTrackingInstalled) return;
            window.__cliniqueduvrAdsTrackingInstalled = true;
            window.cliniqueTrackConversion = trackConversion;

            document.addEventListener('click', (event) => {
              const target = event.target;
              if (!(target instanceof Element)) return;
              const link = target.closest('a[href]');
              if (!(link instanceof HTMLAnchorElement)) return;

              const href = link.getAttribute('href') || '';

              if (href.startsWith('tel:')) {
                trackConversion('phone');
                return;
              }

              if (href.startsWith('mailto:')) {
                trackConversion('email');
                return;
              }

              if (href === squareBookingUrl) {
                trackConversion('booking');
              }
            });

            const url = new URL(window.location.href);
            const isContactSuccess =
              url.searchParams.get('sent') === '1' &&
              (url.pathname === '/contact/' || url.pathname === '/en/contact/');
            const isThankYouPage = url.pathname === '/merci/' || url.pathname === '/en/thank-you/';

            if (isContactSuccess || isThankYouPage) {
              trackConversion('form');
            }
          }

          try {
            if (window.localStorage.getItem(storageKey) === 'accepted') {
              grantConsent();
              installTracking();
            } else {
              window.addEventListener('cliniqueduvr:cookie-consent-accepted', () => {
                grantConsent();
                installTracking();
              }, { once: true });
            }
          } catch {
            window.addEventListener('cliniqueduvr:cookie-consent-accepted', () => {
              grantConsent();
              installTracking();
            }, { once: true });
          }
        })();
      </script>
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Oswald:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <style is:global>
      :root {
        --brand-navy: #1f3a5f;
        --brand-navy-dark: #17304f;
        --brand-green: #3a8d2f;
        --brand-green-dark: #2f7426;
        --brand-gold: #f2d21b;
        --brand-ink: #2b2b2b;
        --brand-muted: #5f6872;
        --brand-surface: #f4f6f8;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Lato', sans-serif;
        line-height: 1.6;
        color: var(--brand-ink);
        background: white;
      }

      .mobile-action-bar {
        display: none;
      }

      h1, h2, h3 {
        font-family: 'Oswald', sans-serif;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
      }

      h1 {
        font-size: 3rem;
        line-height: 1.2;
      }

      h2 {
        font-size: 2rem;
        color: var(--brand-navy);
      }

      h3 {
        font-size: 1.3rem;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      a {
        color: var(--brand-navy);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      button, .btn {
        background: var(--brand-navy);
        color: white;
        border: none;
        padding: 12px 24px;
        font-size: 1rem;
        cursor: pointer;
        border-radius: 4px;
        transition: background 0.3s;
      }

      button:hover, .btn:hover {
        background: var(--brand-navy-dark);
        text-decoration: none;
      }

      .interior-hero {
        position: relative;
        overflow: hidden;
        padding: 4.5rem 0 4rem;
        background:
          radial-gradient(circle at top left, rgba(242, 210, 27, 0.18), transparent 32%),
          linear-gradient(135deg, var(--brand-navy-dark) 0%, #23476f 58%, #f4f6f8 58%, #f4f6f8 100%);
      }

      .interior-hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr);
        gap: 2rem;
        align-items: stretch;
      }

      .interior-hero-copy {
        color: white;
      }

      .interior-eyebrow {
        display: inline-flex;
        margin-bottom: 1.25rem;
        padding: 0.45rem 0.85rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.12);
        color: var(--brand-gold);
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .interior-hero-copy h1 {
        color: white;
        margin-bottom: 1rem;
        max-width: 14ch;
        line-height: 1.05;
      }

      .interior-lead,
      .interior-hero-copy > p:last-child {
        max-width: 62ch;
        color: #f5f7fa;
        font-size: 1.12rem;
        line-height: 1.7;
      }

      .interior-hero-card {
        align-self: end;
        background: white;
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 22px 44px rgba(16, 35, 56, 0.22);
      }

      .interior-hero-icon {
        width: 4rem;
        height: 4rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 18px;
        background: linear-gradient(135deg, var(--brand-green), #57af49);
        color: white;
        font-size: 1.5rem;
        margin-bottom: 1rem;
      }

      .interior-hero-card h2 {
        font-size: 1.5rem;
        margin-bottom: 0.75rem;
      }

      .interior-hero-card p {
        color: var(--brand-muted);
        margin-bottom: 1.25rem;
      }

      .interior-hero-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-height: 48px;
        padding: 0.85rem 1rem;
        border-radius: 999px;
        background: var(--brand-navy);
        color: white;
        font-weight: 700;
        text-decoration: none;
      }

      .interior-hero-link:hover {
        text-decoration: none;
        background: var(--brand-navy-dark);
      }

      .interior-section {
        padding: 4rem 0;
        background: linear-gradient(180deg, #ffffff 0%, #ffffff 42%, #f3f5f8 42%, #f3f5f8 100%);
      }

      .interior-body-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr);
        gap: 2rem;
        align-items: start;
      }

      .interior-content-main,
      .interior-side-panel {
        display: grid;
        gap: 1.5rem;
      }

      .interior-side-panel {
        position: sticky;
        top: 7rem;
        align-self: start;
      }

      .interior-card,
      .interior-side-card {
        background: white;
        border-radius: 22px;
        padding: 1.75rem;
        box-shadow: 0 16px 34px rgba(24, 40, 61, 0.08);
      }

      .interior-card-alt {
        background: linear-gradient(180deg, #f8fbf5 0%, #ffffff 100%);
      }

      .interior-card h2,
      .interior-side-card h3 {
        margin-bottom: 1rem;
      }

      .interior-card p,
      .interior-side-card p,
      .interior-copy {
        color: var(--brand-muted);
      }

      .interior-side-card-primary {
        background: var(--brand-navy-dark);
        color: white;
      }

      .interior-side-card-primary h3 {
        color: white;
      }

      .interior-side-card-primary p {
        color: #dbe4ee;
      }

      .interior-side-button,
      .interior-side-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-height: 48px;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
      }

      .interior-side-button {
        margin: 0.25rem 0 0.75rem;
        background: var(--brand-gold);
        color: var(--brand-navy-dark);
      }

      .interior-side-link {
        padding: 0.55rem 1rem;
        background: var(--brand-gold);
        border: 2px solid var(--brand-gold);
        color: var(--brand-navy-dark);
      }

      .interior-side-button:hover,
      .interior-side-link:hover {
        text-decoration: none;
        background: #e1c317;
        border-color: #e1c317;
      }

      .interior-service-nav {
        display: grid;
        gap: 0.7rem;
      }

      .interior-service-nav a {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        min-height: 54px;
        padding: 0.9rem 1rem;
        border-radius: 16px;
        background: var(--brand-surface);
        color: var(--brand-ink);
        text-decoration: none;
        font-weight: 700;
      }

      .interior-service-nav a:hover {
        text-decoration: none;
        background: #eaf1e6;
      }

      .interior-service-nav i {
        color: var(--brand-green);
      }

      .interior-faq-list {
        display: grid;
        gap: 1rem;
      }

      .interior-faq-item {
        background: white;
        border-radius: 22px;
        padding: 1.75rem;
        box-shadow: 0 16px 34px rgba(24, 40, 61, 0.08);
      }

      .interior-faq-item summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .interior-faq-item summary::-webkit-details-marker {
        display: none;
      }

      .interior-faq-item summary::after {
        content: '+';
        flex: 0 0 auto;
        font-size: 1.4rem;
        font-weight: 700;
        line-height: 1;
        color: var(--brand-navy);
      }

      .interior-faq-item[open] summary::after {
        content: '-';
      }

      .interior-faq-item h3 {
        font-size: 1rem;
        letter-spacing: 0.04em;
        margin: 0;
      }

      .interior-faq-item p {
        margin-top: 0.8rem;
        color: var(--brand-muted);
      }

      @media (max-width: 768px) {
        h1 {
          font-size: 2.05rem;
          line-height: 1.05;
          letter-spacing: 1px;
        }

        h2 {
          font-size: 1.6rem;
          line-height: 1.1;
          letter-spacing: 1px;
        }

        h3 {
          font-size: 1.1rem;
          letter-spacing: 1px;
        }

        .container {
          padding: 0 1rem;
        }

        body {
          padding-bottom: calc(62px + env(safe-area-inset-bottom, 0px));
        }

        .mobile-action-bar {
          position: fixed;
          left: 0;
          right: 0;
          bottom: 0;
          z-index: 120;
          display: grid;
          grid-template-columns: 1fr 1fr;
          background: rgba(255, 255, 255, 0.96);
          backdrop-filter: blur(10px);
          box-shadow: 0 -12px 30px rgba(18, 39, 61, 0.18);
          padding-bottom: env(safe-area-inset-bottom, 0px);
        }

        .mobile-action {
          min-height: 52px;
          display: flex;
          align-items: center;
          justify-content: center;
          color: white;
          font-size: 1rem;
        }

        .mobile-action:hover {
          text-decoration: none;
        }

        .mobile-action-email {
          background: #cb5a46;
        }

        .mobile-action-phone {
          background: #5fcf83;
        }

        .interior-hero {
          background: linear-gradient(180deg, var(--brand-navy-dark) 0%, #1f476d 100%);
          padding: 3.8rem 0 2.8rem;
        }

        .interior-hero-grid,
        .interior-body-grid {
          grid-template-columns: 1fr;
        }

        .interior-hero-card,
        .interior-card,
        .interior-side-card,
        .interior-faq-item {
          padding: 1.35rem;
          border-radius: 20px;
        }

        .interior-side-panel {
          position: static;
        }

        .interior-card h2,
        .interior-side-card h3,
        .interior-hero-card h2 {
          font-size: 1.35rem;
        }

        .interior-lead,
        .interior-hero-copy > p:last-child {
          font-size: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <slot />
    {hasGoogleAds && <CookieConsent lang={isEnglish ? 'en' : 'fr'} hasGoogleAds={hasGoogleAds} />}
    <div class="mobile-action-bar" aria-label={isEnglish ? 'Quick contact actions' : 'Actions de contact rapide'}>
      <a
        class="mobile-action mobile-action-email"
        href={`mailto:${siteSettings.email}`}
        aria-label={isEnglish ? 'Send an email' : 'Envoyer un courriel'}
      >
        <i class="fas fa-envelope" aria-hidden="true"></i>
      </a>
      <a
        class="mobile-action mobile-action-phone"
        href={`tel:${siteSettings.phone.href}`}
        aria-label={isEnglish ? 'Call now' : 'Appeler maintenant'}
      >
        <i class="fas fa-phone" aria-hidden="true"></i>
      </a>
    </div>
  </body>
</html>
